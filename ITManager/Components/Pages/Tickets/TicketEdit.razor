    private static DateTime? GetCreatedAtUtcFromTicket(Ticket ticket)
    {
        try
        {
            var t = ticket.GetType();

            var prop = t.GetProperty("CreatedAtUtc", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("CreatedAt", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("TicketCreatedAtUtc", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("TicketCreatedAt", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("created_at", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("createdAt", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop is null)
                return null;

            var raw = prop.GetValue(ticket);
            if (raw is null)
                return null;

            if (raw is DateTime dt)
                return EnsureUtc(dt);

            if (raw is DateTimeOffset dto)
                return EnsureUtc(dto.UtcDateTime);

            return null;
        }
        catch
        {
            return null;
        }
    }

    private static void SetCreatedAtUtcOnTicket(Ticket ticket, DateTime utcValue)
    {
        try
        {
            var t = ticket.GetType();

            var candidates = new[]
            {
                "CreatedAtUtc",
                "CreatedAt",
                "TicketCreatedAtUtc",
                "TicketCreatedAt",
                "created_at",
                "createdAt"
            };

            foreach (var name in candidates)
            {
                var p = t.GetProperty(name, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
                if (p is null || !p.CanWrite)
                    continue;

                if (p.PropertyType == typeof(DateTime))
                {
                    p.SetValue(ticket, EnsureUtc(utcValue));
                    return;
                }

                if (p.PropertyType == typeof(DateTime?))
                {
                    p.SetValue(ticket, (DateTime?)EnsureUtc(utcValue));
                    return;
                }
            }
        }
        catch
        {
        }
    }

    private void EnsureCreatedAtOnTicket(Ticket ticket)
    {
        var current = GetCreatedAtUtcFromTicket(ticket);
        if (current.HasValue)
        {
            _createdAtUtc = current.Value;
            return;
        }

        if (_createdAtUtc.HasValue)
        {
            SetCreatedAtUtcOnTicket(ticket, _createdAtUtc.Value);
        }
    }

    private void EnsureRequestDateOnTicket(Ticket ticket)
    {
        if (ticket.TicketRequestDate.HasValue)
        {
            _requestDateUtc = EnsureUtc(ticket.TicketRequestDate.Value);
            return;
        }

        if (_requestDateUtc.HasValue)
        {
            ticket.TicketRequestDate = _requestDateUtc.Value;
        }
    }

    private async Task UpdateTicketThroughAdapterAsync(Ticket ticket)
    {
        var svc = (object)TicketsService;
        var t = svc.GetType();

        var methods = t.GetMethods(BindingFlags.Public | BindingFlags.Instance)
            .Where(m => string.Equals(m.Name, "UpdateTicketAsync", StringComparison.Ordinal))
            .ToList();

        if (methods.Count == 0)
            throw new InvalidOperationException("TicketsService.UpdateTicketAsync not found.");

        EnsureCreatedAtOnTicket(ticket);
        EnsureRequestDateOnTicket(ticket);

        // PRIORITY: zachowaj wartość z DB (TicketEdit nie zmienia zapisu)
        var weightPriority = GetWeightPriorityFromTicketSafe(ticket);

        foreach (var mi in methods)
        {
            var ps = mi.GetParameters();
            if (ps.Length == 1 && ps[0].ParameterType.IsAssignableFrom(ticket.GetType()))
            {
                var resObj = mi.Invoke(svc, new object[] { ticket });
                if (resObj is Task task)
                {
                    await task;
                    return;
                }
            }
        }

        var createdAtUtc = GetCreatedAtUtcFromTicket(ticket) ?? _createdAtUtc;
        var requestDateUtc = ticket.TicketRequestDate.HasValue ? EnsureUtc(ticket.TicketRequestDate.Value) : _requestDateUtc;

        var values = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase)
        {
            ["id"] = Convert.ToInt64(ticket.Id),
            ["ticketId"] = Convert.ToInt64(ticket.Id),

            ["title"] = (ticket.TicketTitle ?? string.Empty).Trim(),
            ["ticketTitle"] = (ticket.TicketTitle ?? string.Empty).Trim(),

            ["problemDescription"] = (ticket.ProblemDescription ?? string.Empty).Trim(),
            ["description"] = (ticket.ProblemDescription ?? string.Empty).Trim(),

            ["categoryName"] = (ticket.TicketCategoryName ?? string.Empty).Trim(),
            ["ticketCategoryName"] = (ticket.TicketCategoryName ?? string.Empty).Trim(),

            ["urgencyName"] = (ticket.TicketUrgencyName ?? string.Empty).Trim(),
            ["ticketUrgencyName"] = (ticket.TicketUrgencyName ?? string.Empty).Trim(),

            ["impactName"] = (ticket.TicketImpactName ?? string.Empty).Trim(),
            ["ticketImpactName"] = (ticket.TicketImpactName ?? string.Empty).Trim(),

            ["requesterName"] = (ticket.TicketRequesterName ?? string.Empty).Trim(),
            ["ticketRequesterName"] = (ticket.TicketRequesterName ?? string.Empty).Trim(),

            ["operatorName"] = (ticket.TicketOperatorName ?? string.Empty).Trim(),
            ["keeperName"] = (ticket.TicketOperatorName ?? string.Empty).Trim(),
            ["ticketOperatorName"] = (ticket.TicketOperatorName ?? string.Empty).Trim(),

            ["statusName"] = (ticket.TicketStatusesName ?? string.Empty).Trim(),
            ["ticketStatusesName"] = (ticket.TicketStatusesName ?? string.Empty).Trim(),

            ["requestDate"] = requestDateUtc,
            ["ticketRequestDate"] = requestDateUtc,

            ["createdAt"] = createdAtUtc,
            ["createdAtUtc"] = createdAtUtc,
            ["ticketCreatedAt"] = createdAtUtc,
            ["ticketCreatedAtUtc"] = createdAtUtc,
            ["created"] = createdAtUtc,

            // PRIORITY: dopasuj do podpisu TicketsService.UpdateTicketAsync(..., int weightPriority)
            ["weightPriority"] = weightPriority,
            ["ticketPriorityValue"] = weightPriority,
            ["ticket_priority_value"] = weightPriority,
            ["weight_priority"] = weightPriority,
            ["priorityValue"] = weightPriority,
            ["priority"] = weightPriority
        };

        foreach (var mi in methods.OrderByDescending(m => m.GetParameters().Length))
        {
            var ps = mi.GetParameters();
            var args = new object?[ps.Length];
            var ok = true;

            for (var i = 0; i < ps.Length; i++)
            {
                var p = ps[i];
                var pname = (p.Name ?? string.Empty).Trim();

                if (values.TryGetValue(pname, out var v))
                {
                    args[i] = CoerceToParameterType(v, p.ParameterType);
                    continue;
                }

                if (p.ParameterType == typeof(DateTime) || p.ParameterType == typeof(DateTime?))
                {
                    var pn = pname.ToLowerInvariant();

                    var looksLikeCreated = pn.Contains("created");
                    if (looksLikeCreated && createdAtUtc.HasValue)
                    {
                        args[i] = CoerceToParameterType(createdAtUtc.Value, p.ParameterType);
                        continue;
                    }

                    var looksLikeRequestDate = pn.Contains("request") && pn.Contains("date");
                    if (looksLikeRequestDate && requestDateUtc.HasValue)
                    {
                        args[i] = CoerceToParameterType(requestDateUtc.Value, p.ParameterType);
                        continue;
                    }

                    args[i] = null;
                    continue;
                }

                // PRIORITY: jeśli jakiś parametr int dotyczy priority, zawsze podaj wartość z DB
                if (p.ParameterType == typeof(int) || p.ParameterType == typeof(int?))
                {
                    if (pname.Contains("priority", StringComparison.OrdinalIgnoreCase))
                    {
                        args[i] = CoerceToParameterType(weightPriority, p.ParameterType);
                        continue;
                    }

                    args[i] = p.ParameterType == typeof(int) ? 0 : null;
                    continue;
                }

                if (p.ParameterType == typeof(long) || p.ParameterType == typeof(long?))
                {
                    args[i] = Convert.ToInt64(ticket.Id);
                    continue;
                }

                if (p.ParameterType == typeof(string))
                {
                    args[i] = string.Empty;
                    continue;
                }

                if (p.HasDefaultValue)
                {
                    args[i] = p.DefaultValue;
                    continue;
                }

                ok = false;
                break;
            }

            if (!ok)
                continue;

            var resObj = mi.Invoke(svc, args);
            if (resObj is Task task)
            {
                await task;
                return;
            }
        }

        throw new InvalidOperationException("No compatible overload for TicketsService.UpdateTicketAsync was found.");
    }

    private static object? CoerceToParameterType(object? value, Type targetType)
    {
        if (value is null)
            return null;

        var nonNullable = Nullable.GetUnderlyingType(targetType) ?? targetType;

        try
        {
            if (nonNullable.IsInstanceOfType(value))
                return value;

            if (nonNullable == typeof(string))
                return value.ToString() ?? string.Empty;

            if (nonNullable == typeof(long))
                return Convert.ToInt64(value);

            if (nonNullable == typeof(int))
                return Convert.ToInt32(value);

            if (nonNullable == typeof(bool))
                return Convert.ToBoolean(value);

            if (nonNullable == typeof(DateTime))
            {
                if (value is DateTime dt)
                    return EnsureUtc(dt);

                if (value is DateTimeOffset dto)
                    return EnsureUtc(dto.UtcDateTime);

                if (value is string s && DateTime.TryParse(s, out var parsed))
                    return EnsureUtc(parsed);
            }

            return Convert.ChangeType(value, nonNullable);
        }
        catch
        {
            return value;
        }
    }

    // =========================
    // PRIORITY: live preview helpers (best-effort)
    // =========================

    private void RecalculatePriorityPreview()
    {
        _hasPriorityPreviewScore = false;
        _priorityPreviewScore = 0;

        if (string.IsNullOrWhiteSpace(_selectedImpact) || string.IsNullOrWhiteSpace(_selectedUrgency))
            return;

        if (!_priorityWeightsLoaded)
            return;

        if (!_impactWeights.TryGetValue(_selectedImpact, out var iw))
            return;

        if (!_urgencyWeights.TryGetValue(_selectedUrgency, out var uw))
            return;

        var raw = iw * uw;
        _priorityPreviewScore = ClampPriorityScore(raw);
        _hasPriorityPreviewScore = _priorityPreviewScore > 0;
    }

    private async Task LoadPriorityWeightsSafeAsync()
    {
        try
        {
            _urgencyWeights.Clear();
            _impactWeights.Clear();
            _priorityWeightsLoaded = false;

            // PRIORYTET: JEDNO ŹRÓDŁO PRAWDY jak w TicketIndex
            // TicketsService.GetImpactAndUrgencyDictionaryAsync -> dbo.ticket_impacts / dbo.ticket_urgencies
            var ok = await TryLoadWeightsFromImpactUrgencyDictionaryAsync();

            // Fallback tylko gdy nie udało się pobrać słowników
            if (!ok)
            {
                _urgencyWeights[LevelLow] = 2;
                _urgencyWeights[LevelMedium] = 4;
                _urgencyWeights[LevelHigh] = 6;
                _urgencyWeights[LevelCritical] = 10;

                _impactWeights[LevelInfo] = 1;
                _impactWeights[LevelLow] = 2;
                _impactWeights[LevelMedium] = 5;
                _impactWeights[LevelHigh] = 7;
                _impactWeights[LevelCritical] = 10;
            }

            _priorityWeightsLoaded = _urgencyWeights.Count > 0 && _impactWeights.Count > 0;

            RecalculatePriorityPreview();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[TicketEdit.LoadPriorityWeightsSafeAsync] ERROR: {ex}");
            _priorityWeightsLoaded = false;
        }
    }

    private async Task<bool> TryLoadWeightsFromImpactUrgencyDictionaryAsync()
    {
        try
        {
            var dict = await TicketsService.GetImpactAndUrgencyDictionaryAsync();
            if (dict is null)
                return false;

            var any = false;

            if (dict.Impacts != null)
            {
                foreach (var item in dict.Impacts)
                {
                    var name = NormalizeLevel(item?.Name);
                    if (string.IsNullOrWhiteSpace(name))
                        continue;

                    var w = item?.Weight ?? 0;
                    if (w <= 0)
                        continue;

                    _impactWeights[name] = w;
                    any = true;
                }
            }

            if (dict.Urgencies != null)
            {
                foreach (var item in dict.Urgencies)
                {
                    var name = NormalizeLevel(item?.Name);
                    if (string.IsNullOrWhiteSpace(name))
                        continue;

                    var w = item?.Weight ?? 0;
                    if (w <= 0)
                        continue;

                    _urgencyWeights[name] = w;
                    any = true;
                }
            }

            // Minimalne sanity: musimy mieć przynajmniej 1 wagę w obu słownikach
            return _impactWeights.Count > 0 && _urgencyWeights.Count > 0 && any;
        }
        catch
        {
            return false;
        }
    }

