    private static string NormalizeLevel(string? raw)
    {
        var s = (raw ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(s))
            return string.Empty;

        if (string.Equals(s, LevelEmergency, StringComparison.OrdinalIgnoreCase))
            return LevelCritical;

        if (string.Equals(s, LevelCritical, StringComparison.OrdinalIgnoreCase)) return LevelCritical;
        if (string.Equals(s, LevelHigh, StringComparison.OrdinalIgnoreCase)) return LevelHigh;
        if (string.Equals(s, LevelMedium, StringComparison.OrdinalIgnoreCase)) return LevelMedium;
        if (string.Equals(s, LevelLow, StringComparison.OrdinalIgnoreCase)) return LevelLow;
        if (string.Equals(s, LevelInfo, StringComparison.OrdinalIgnoreCase)) return LevelInfo;

        return s;
    }

