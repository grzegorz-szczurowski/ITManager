@using ITManager.Models
@using ITManager.Services
@using ITManager.Services.Auth
@using ITManager.Services.Tickets
@using MudBlazor
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Authorization
@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading
@using System.Threading.Tasks
@using System.Reflection

@inject TicketsService TicketsService
@inject UsersService UsersService
@inject CurrentUserContextService CurrentUserContextService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<TicketEdit> L
@inject TimeZoneService TimeZoneService

<MudPaper Class="pa-4" Elevation="0">

    @if (_loading)
    {
        <MudProgressCircular Size="Size.Large" Class="mx-auto" />
    }
    else if (!_canViewModule)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            @L["NoPermissionView"]
        </MudAlert>
    }
    else if (_isCreateMode && !_canCreateMode)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            @L["NoPermissionCreate"]
        </MudAlert>
    }
    else if (!_isCreateMode && !_canViewThisTicket)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            @L["NoPermissionView"]
        </MudAlert>
    }
    else if (!_isCreateMode && _ticket is null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            @L["TicketNotFound"]
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="2">

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">

                <MudStack Spacing="0" AlignItems="AlignItems.Start">
                    <MudText Typo="Typo.h5">
                        @(_isCreateMode? L["NewTicketHeaderTitle"].Value : (_ticket!.TicketTitle ?? string.Empty))
                    </MudText>

                    @if (_isCreateMode)
                    {
                        <MudText Typo="Typo.subtitle2" Style="opacity:0.75;">
                            @L["CreateModeSubtitle"]
                        </MudText>
                    }
                </MudStack>

                @if (!_isCreateMode)
                {
                    <MudText Typo="Typo.subtitle1" Style="opacity:0.85; font-weight:600;">
                        @TicketNumberDisplay
                    </MudText>
                }

            </MudStack>

            @if (!_isCreateMode && _showAssignHint)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="pa-3 assign-alert">
                    @if (_canAssign)
                    {
                        <div class="assign-hint-row">
                            <MudText Typo="Typo.body2" Class="assign-hint-text">
                                @L["AssignHintText"]
                            </MudText>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Info"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       Disabled="@(!_canAssign || _busy)"
                                       OnClick="AssignToMeAsync"
                                       Class="assign-hint-btn">
                                @L["AssignToMeButton"]
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight:700;">
                                @LocalizeOrDefault("QueueInfoTitle", "Zgłoszenie jest w kolejce")
                            </MudText>
                            <MudText Typo="Typo.caption" Style="opacity:0.85; line-height:1.35;">
                                @LocalizeOrDefault("QueueInfoText", "To zgłoszenie nie ma jeszcze przypisanego operatora. Zostanie podjęte, gdy ktoś z IT je przypisze.")
                            </MudText>
                        </MudStack>
                    }

                </MudAlert>
            }

            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                    @_loadError
                </MudAlert>
            }

            <MudGrid GutterSize="3">

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                        <MudStack Spacing="2">

                            <MudStack Spacing="1" Class="category-block">
                                <MudText Typo="Typo.subtitle2">@L["CategoryTitle"]</MudText>

                                <MudToggleGroup T="string"
                                                Exclusive="true"
                                                @bind-Value="_selectedCategory"
                                                Disabled="@(!_canEditForm || (_disableCategoryEdits && !_isCreateMode) || _busy)"
                                                Class="segmented-toggle segmented-toggle-sm"
                                                FullWidth="true">
                                    @foreach (var c in _categoryOptions)
                                    {
                                        <MudToggleItem Value="@c">
                                            <span>@GetCategoryLabel(c)</span>
                                        </MudToggleItem>
                                    }
                                </MudToggleGroup>

                                @if (_isCreateMode && _submitAttempted && !IsCategoryValid())
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                        @LocalizeOrDefault("CategoryRequired", "Wybierz kategorię zgłoszenia.")
                                    </MudText>
                                }

                                @if (!_isCreateMode && _canEditForm && _disableCategoryEdits)
                                {
                                    <MudText Typo="Typo.caption" Style="opacity:0.75;">
                                        @LocalizeOrDefault("CategoryEditRestrictedHint", "Zmiana kategorii jest ograniczona do operatorów z uprawnieniami Assigned lub All.")
                                    </MudText>
                                }
                            </MudStack>

                            <MudDivider />

                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">@L["UrgencyTitle"]</MudText>

                                <MudToggleGroup T="string"
                                                Exclusive="true"
                                                Value="@_selectedUrgency"
                                                ValueChanged="OnUrgencyChanged"
                                                Disabled="@(!_canEditForm || (_disableUrgencyImpactEdits && !_isCreateMode) || _busy)"
                                                Class="segmented-toggle"
                                                FullWidth="true">
                                    @foreach (var u in _urgencyOptions)
                                    {
                                        var css = GetSeverityToggleClass(u);

                                        <MudToggleItem Value="@u" Class="@css">
                                            <span>@LevelLabel(u)</span>
                                        </MudToggleItem>
                                    }
                                </MudToggleGroup>

                                <MudText Typo="Typo.caption" Class="toggle-desc">
                                    @GetUrgencyDescriptionOrHint()
                                </MudText>

                                @if (!_isCreateMode && _canEditForm && _disableUrgencyImpactEdits)
                                {
                                    <MudText Typo="Typo.caption" Style="opacity:0.75;">
                                        @LocalizeOrDefault("UrgencyImpactEditRestrictedHint", "Zmiana pilności i wpływu jest ograniczona do operatorów z uprawnieniami Assigned lub All.")
                                    </MudText>
                                }
                            </MudStack>

                            <MudDivider />

                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">@L["ImpactTitle"]</MudText>

                                <MudToggleGroup T="string"
                                                Exclusive="true"
                                                Value="@_selectedImpact"
                                                ValueChanged="OnImpactChanged"
                                                Disabled="@(!_canEditForm || (_disableUrgencyImpactEdits && !_isCreateMode) || _busy)"
                                                Class="segmented-toggle"
                                                FullWidth="true">
                                    @foreach (var i in _impactOptions)
                                    {
                                        var css = GetSeverityToggleClass(i);

                                        <MudToggleItem Value="@i" Class="@css">
                                            <span>@LevelLabel(i)</span>
                                        </MudToggleItem>
                                    }
                                </MudToggleGroup>

                                <MudText Typo="Typo.caption" Class="toggle-desc">
                                    @GetImpactDescriptionOrHint()
                                </MudText>
                            </MudStack>

                            <MudDivider />

                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">@L["PriorityTitle"]</MudText>

                                <MudToggleGroup T="string"
                                                Exclusive="true"
                                                Value="@PriorityDisplayText"
                                                Disabled="true"
                                                Class="priority-toggle"
                                                FullWidth="true">
                                    <MudToggleItem Value="@PriorityDisplayText" Class="@GetPriorityToggleClass()">
                                        <span>@PriorityDisplayText</span>
                                    </MudToggleItem>
                                </MudToggleGroup>
                            </MudStack>

                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                        <MudStack Spacing="2">

                            <MudGrid GutterSize="2">
                                <MudItem xs="12" md="6">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@($"{L["RequesterTitle"]}")</MudText>

                                        <MudAutocomplete T="string"
                                                         @bind-Value="_requesterName"
                                                         Dense="true"
                                                         Margin="Margin.Dense"
                                                         Variant="Variant.Text"
                                                         Disabled="@(!_canEditForm || !_canEditRequester || _busy)"
                                                         SearchFunc="SearchRequesterAsync"
                                                         ToStringFunc="@(x => x)"
                                                         Clearable="true"
                                                         CoerceText="true"
                                                         CoerceValue="true"
                                                         ResetValueOnEmptyText="true"
                                                         MinCharacters="0"
                                                         MaxItems="50" />

                                    </MudStack>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@($"{L["OperatorTitle"]}")</MudText>

                                        <MudAutocomplete T="string"
                                                         @bind-Value="_operatorName"
                                                         Dense="true"
                                                         Margin="Margin.Dense"
                                                         Variant="Variant.Text"
                                                         Disabled="@(!_canEditForm || !_canChangeOperator || _busy)"
                                                         SearchFunc="SearchOperatorAsync"
                                                         ToStringFunc="@(x => x)"
                                                         Clearable="true"
                                                         CoerceText="true"
                                                         CoerceValue="true"
                                                         ResetValueOnEmptyText="true"
                                                         MinCharacters="0"
                                                         MaxItems="50" />
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                            <MudTextField T="string"
                                          Label="@L["TitleLabel"]"
                                          @bind-Value="_titleText"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Dense="true"
                                          Disabled="@(!_canEditForm || (!_isCreateMode && !_canEditTitleExisting) || _busy)"
                                          Error="@(_submitAttempted && (_isCreateMode || _canEditTitleExisting) && !IsTitleValid())"
                                          ErrorText=" " />

                            @if (_submitAttempted && (_isCreateMode || _canEditTitleExisting) && !IsTitleValid())
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error">
                                    @L["TitleTooShort"]
                                </MudText>
                            }

                            @if (!_isCreateMode)
                            {
                                <MudDivider />

                                <MudStack Spacing="2">

                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.subtitle2">@L["ActionsTitle"]</MudText>

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Add"
                                                   Disabled="@(!_canAddAction || _busy)"
                                                   OnClick="AddActionAsync">
                                            @L["AddButton"]
                                        </MudButton>
                                    </MudStack>

                                    @if (_actionsLoading)
                                    {
                                        <MudProgressCircular Size="Size.Medium" Class="mx-auto" />
                                    }
                                    else
                                    {
                                        <MudDataGrid T="TicketsService.TicketActionRow"
                                                     Items="@_actions"
                                                     Dense="true"
                                                     Hover="true"
                                                     Elevation="0"
                                                     Outlined="true"
                                                     Bordered="true"
                                                     Filterable="false"
                                                     SortMode="SortMode.Multiple"
                                                     RowClick="OnActionRowClickAsync"
                                                     RowClassFunc="ActionRowClass">

                                            <Columns>
                                                <PropertyColumn Property="x => x.CreatedAt"
                                                                Title="@L["GridColDate"]"
                                                                Sortable="true"
                                                                CellClass="actions-col-date">
                                                    <CellTemplate>
                                                        @FormatDateTime(context.Item.CreatedAt)
                                                    </CellTemplate>
                                                </PropertyColumn>

                                                <PropertyColumn Property="x => x.CreatedByDisplayName"
                                                                Title="@L["GridColAddedBy"]"
                                                                Sortable="true"
                                                                CellClass="actions-col-user" />

                                                @if (_showPublicColumn)
                                                {
                                                    <PropertyColumn Property="x => x.IsPublic"
                                                                    Title="@L["GridColPublic"]"
                                                                    Sortable="true"
                                                                    CellClass="actions-col-public">
                                                        <CellTemplate>
                                                            @if (context.Item.IsPublic)
                                                            {
                                                                <MudTooltip Text="@L["PublicTooltipAll"]">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Public" />
                                                                </MudTooltip>
                                                            }
                                                            else
                                                            {
                                                                <MudTooltip Text="@L["PublicTooltipRestricted"]">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Lock" />
                                                                </MudTooltip>
                                                            }
                                                        </CellTemplate>
                                                    </PropertyColumn>
                                                }

                                                <PropertyColumn Property="x => x.ActionText"
                                                                Title="@L["GridColDescription"]"
                                                                Sortable="false"
                                                                CellClass="actions-col-text" />

                                                <TemplateColumn Title="@L["GridColStatus"]" CellClass="actions-col-status">
                                                    <CellTemplate>
                                                        @{
                                                            var status = GetActionTargetStatusName(context.Item);
                                                            if (string.IsNullOrWhiteSpace(status))
                                                            {
                                                                <MudText Typo="Typo.body2" Style="opacity:0.7;">-</MudText>
                                                            }
                                                            else
                                                            {
                                                                <MudText Typo="Typo.body2">@status</MudText>
                                                            }
                                                        }
                                                    </CellTemplate>
                                                </TemplateColumn>

                                            </Columns>

                                            <NoRecordsContent>
                                                <MudText Typo="Typo.body2" Class="pa-2">
                                                    @L["NoActions"]
                                                </MudText>
                                            </NoRecordsContent>

                                        </MudDataGrid>
                                    }

                                </MudStack>
                            }

                        </MudStack>
                    </MudPaper>
                </MudItem>

            </MudGrid>

            <MudDivider Class="mt-2" />

            <MudPaper Elevation="0" Class="ticketedit-footer pa-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Close"
                               Disabled="@_busy"
                               OnClick="BackToReturnUrl">
                        @LocalizeOrDefault("CancelButton", "Anuluj")
                    </MudButton>

                    @if (!_isCreateMode)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@(!_canSave || _busy)"
                                   OnClick="SaveAsync">
                            @L["SaveButton"]
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   Disabled="@(!_canCreateMode || _busy)"
                                   OnClick="CreateAsync">
                            @L["CreateButton"]
                        </MudButton>
                    }

                </MudStack>
            </MudPaper>

            <MudOverlay Visible="@_busy"
                        DarkBackground="true"
                        AutoClose="false"
                        Absolute="true"
                        Class="ticketedit-overlay">
                <MudPaper Class="pa-6 ticketedit-overlay-card">
                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">@L["Working"]</MudText>
                    </MudStack>
                </MudPaper>
            </MudOverlay>

        </MudStack>
    }

</MudPaper>

<style>
    .assign-alert {
        border-radius: 10px;
    }

    .assign-hint-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .assign-hint-text {
        opacity: 0.9;
    }

    .ticketedit-footer {
        position: sticky;
        bottom: 0;
        z-index: 5;
        background: var(--mud-palette-surface);
        border-radius: 10px;
    }

    .segmented-toggle .mud-toggle-item {
        min-height: 40px;
        font-weight: 600;
    }

    .segmented-toggle-sm .mud-toggle-item {
        min-height: 36px;
        font-weight: 600;
    }

    .toggle-desc {
        opacity: 0.8;
        line-height: 1.35;
        margin-top: 6px;
        min-height: 38px;
    }

    .priority-toggle .mud-toggle-item {
        min-height: 44px;
        font-weight: 800;
        letter-spacing: 0.3px;
    }

    .sev-critical {
        background-color: rgba(211, 47, 47, 0.15);
        border: 1px solid #0288D1;
    }

    .sev-high {
        background-color: rgba(245, 124, 0, 0.15);
        border: 1px solid #0288D1;
    }

    .sev-medium {
        background-color: rgba(249, 168, 37, 0.15);
        border: 1px solid #0288D1;
    }

    .sev-low {
        background-color: rgba(46, 125, 50, 0.15);
        border: 1px solid #0288D1;
    }

    .sev-info {
        background-color: rgba(2, 136, 209, 0.15);
        border: 1px solid #0288D1;
    }

    .segmented-toggle .mud-toggle-item.sev-critical.mud-selected,
    .segmented-toggle .mud-toggle-item.sev-critical.mud-toggle-item-selected {
        background-color: #D32F2F !important;
        color: #FFFFFF !important;
        border: 1px solid #0288D1 !important;
    }

    .segmented-toggle .mud-toggle-item.sev-high.mud-selected,
    .segmented-toggle .mud-toggle-item.sev-high.mud-toggle-item-selected {
        background-color: #F57C00 !important;
        color: #FFFFFF !important;
        border: 1px solid #0288D1 !important;
