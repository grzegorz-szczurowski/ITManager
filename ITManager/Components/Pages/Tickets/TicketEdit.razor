    private async Task<Ticket?> LoadTicketByRouteAsync()
    {
        var tc = (TicketCode ?? string.Empty).Trim();

        // Preferuj ticket_code (np. WAL000001) dla route /tickets/{TicketCode} gdy nie jest to create mode.
        if (!string.IsNullOrWhiteSpace(tc) && !IsCreateModeRoute())
        {
            return await TicketsService.GetTicketByCodeAsync(tc);
        }

        if (Id > 0)
            return await TicketsService.GetTicketByIdAsync(Id);

        if (!string.IsNullOrWhiteSpace(tc) && int.TryParse(tc, out var asId) && asId > 0)
            return await TicketsService.GetTicketByIdAsync(asId);

        return null;
    }

    private async Task<Ticket?> GetTicketByCodeThroughAdapterAsync(string ticketCode)
    {
        var svc = (object)TicketsService;
        var t = svc.GetType();

        var methods = t.GetMethods(BindingFlags.Public | BindingFlags.Instance)
            .Where(m =>
                string.Equals(m.Name, "GetTicketByCodeAsync", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(m.Name, "GetTicketByTicketCodeAsync", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(m.Name, "GetTicketByCode", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(m.Name, "GetTicketByTicketCode", StringComparison.OrdinalIgnoreCase))
            .ToList();

        foreach (var mi in methods.OrderByDescending(m => m.GetParameters().Length))
        {
            var ps = mi.GetParameters();
            if (ps.Length < 1)
                continue;

            if (ps[0].ParameterType != typeof(string))
                continue;

            var resObj = mi.Invoke(svc, new object?[] { ticketCode });

            if (resObj is Task<Ticket?> tTicket)
                return await tTicket;

            if (resObj is Task<Ticket> tTicket2)
                return await tTicket2;

            if (resObj is Task task)
            {
                await task;
                return null;
            }

            if (resObj is Ticket direct)
                return direct;
        }

        return null;
    }

