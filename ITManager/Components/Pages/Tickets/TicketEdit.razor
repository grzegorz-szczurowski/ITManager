            PermEditAll
        );

        _canEditUrgencyImpactExisting = ctx.IsAuthenticated && ctx.IsActive == true && HasAny(PermEditAll, PermEditAssigned);
        _canEditCategoryExisting = _canEditUrgencyImpactExisting;

        _canEditTitleExisting = ctx.IsAuthenticated && ctx.IsActive == true && HasAny(PermEditAll, PermEditAssigned);

        if (!_canViewModule)
        {
            _loading = false;
            return;
        }

        _userTimeZone = await TimeZoneService.GetUserTimeZoneAsync();

        // PRIORITY: załaduj wagi do live preview (best-effort, bez wpływu na zapis)
        await LoadPriorityWeightsSafeAsync();

        await LoadAsync();
        _loading = false;
    }

    private bool IsCreateModeRoute()
    {
        if (Id > 0)
            return false;

        var tc = (TicketCode ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(tc))
            return true;

        if (string.Equals(tc, "0", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(tc, "new", StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private string BuildTicketNumberDisplay()
    {
        if (_ticket is null)
            return string.Empty;

        var code = GetTicketCodeFromTicket(_ticket);
        if (!string.IsNullOrWhiteSpace(code))
            return $"#{code}";

        return $"#{_ticket.Id}";
    }

    private string GetTicketCodeFromTicket(Ticket ticket)
    {
        try
        {
            var t = ticket.GetType();

            var p = t.GetProperty("TicketCode", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("ticket_code", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            var val = p?.GetValue(ticket);
            var s = (val?.ToString() ?? string.Empty).Trim();

            return s;
        }
        catch
        {
            return string.Empty;
        }
    }

    private string LocalizeOrDefault(string key, string fallbackPl)
    {
        var localized = L[key];
        if (localized is null)
            return fallbackPl;

        var val = localized.Value ?? string.Empty;
        if (string.IsNullOrWhiteSpace(val))
            return fallbackPl;

        if (string.Equals(val, key, StringComparison.Ordinal))
            return fallbackPl;

        return val;
    }

