            return dt;

        return DateTime.SpecifyKind(dt, DateTimeKind.Utc);
    }

    private async Task<IEnumerable<string>> SearchRequesterAsync(string value, CancellationToken ct)
    {
        try
        {
            var search = (value ?? string.Empty).Trim();
            if (ct.IsCancellationRequested)
                return Enumerable.Empty<string>();

            var all = await UsersService.GetActiveUserDisplayNamesAsync();

            var list = (all ?? new List<string>())
                .Select(s => (s ?? string.Empty).Trim())
                .Where(s => !string.IsNullOrWhiteSpace(s));

            if (string.IsNullOrWhiteSpace(search))
                return list.OrderBy(s => s).Take(50).ToList();

            return list
                .Where(s => s.Contains(search, StringComparison.OrdinalIgnoreCase))
                .OrderBy(s => s)
                .Take(50)
                .ToList();
        }
        catch
        {
            return Enumerable.Empty<string>();
        }
    }

