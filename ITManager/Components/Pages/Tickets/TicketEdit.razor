                continue;

            object? reqObj = null;

            try { reqObj = Activator.CreateInstance(p0.ParameterType); }
            catch { reqObj = null; }

            if (reqObj is null)
                continue;

            TrySetProp(reqObj, "Title", title);
            TrySetProp(reqObj, "TicketTitle", title);

            TrySetProp(reqObj, "FirstActionText", problemDescription);

            TrySetProp(reqObj, "ProblemDescription", problemDescription);
            TrySetProp(reqObj, "Description", problemDescription);

            TrySetProp(reqObj, "ImpactName", impactName);
            TrySetProp(reqObj, "TicketImpactName", impactName);

            TrySetProp(reqObj, "UrgencyName", urgencyName);
            TrySetProp(reqObj, "TicketUrgencyName", urgencyName);

            TrySetProp(reqObj, "CategoryName", categoryName);
            TrySetProp(reqObj, "TicketCategoryName", categoryName);

            if (!string.IsNullOrWhiteSpace(requesterName))
            {
                TrySetProp(reqObj, "RequesterDisplayName", requesterName);
                TrySetProp(reqObj, "RequesterName", requesterName);
                TrySetProp(reqObj, "TicketRequesterName", requesterName);
                TrySetProp(reqObj, "CreatedByName", requesterName);
            }

            var resObj = mi.Invoke(svc, new object?[] { reqObj });

            if (resObj is Task<long> tLong)
                return await tLong;

            if (resObj is Task<int> tInt)
                return await tInt;

            if (resObj is Task task)
            {
                await task;
                throw new InvalidOperationException("TicketsService.CreateTicketAsync returned Task without ID.");
            }
        }

        var values = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase)
        {
            ["title"] = title,
            ["ticketTitle"] = title,

            ["problemDescription"] = problemDescription,
            ["description"] = problemDescription,

            ["impactName"] = impactName,
            ["ticketImpactName"] = impactName,

            ["urgencyName"] = urgencyName,
            ["ticketUrgencyName"] = urgencyName,

            ["categoryName"] = categoryName,
            ["ticketCategoryName"] = categoryName,
            ["category"] = categoryName,
        };

        if (!string.IsNullOrWhiteSpace(requesterName))
        {
            values["requesterName"] = requesterName;
            values["ticketRequesterName"] = requesterName;
            values["createdByName"] = requesterName;
        }

        foreach (var mi in methods.OrderByDescending(m => m.GetParameters().Length))
        {
            var ps = mi.GetParameters();
            if (ps.Length < 4)
                continue;

            if (ps[0].ParameterType != typeof(string) ||
                ps[1].ParameterType != typeof(string) ||
                ps[2].ParameterType != typeof(string) ||
                ps[3].ParameterType != typeof(string))
            {
                continue;
            }

            var args = new object?[ps.Length];
            var ok = true;

            for (var i = 0; i < ps.Length; i++)
            {
                var p = ps[i];
                var pname = p.Name ?? string.Empty;

                if (values.TryGetValue(pname, out var v))
                {
                    args[i] = CoerceToParameterType(v, p.ParameterType);
                    continue;
                }

                if (p.HasDefaultValue)
                {
                    args[i] = p.DefaultValue;
                    continue;
                }

                if (p.ParameterType == typeof(string))
                {
                    args[i] = string.Empty;
                    continue;
                }

                if (p.ParameterType == typeof(int) || p.ParameterType == typeof(int?) ||
                    p.ParameterType == typeof(long) || p.ParameterType == typeof(long?) ||
                    p.ParameterType == typeof(bool) || p.ParameterType == typeof(bool?) ||
                    p.ParameterType == typeof(DateTime) || p.ParameterType == typeof(DateTime?))
                {
                    args[i] = null;
                    continue;
                }

                ok = false;
                break;
            }

            if (!ok)
                continue;

            var resObj = mi.Invoke(svc, args);

            if (resObj is Task<long> tLong)
                return await tLong;

            if (resObj is Task<int> tInt)
                return await tInt;

            if (resObj is Task task)
            {
                await task;
                throw new InvalidOperationException("TicketsService.CreateTicketAsync returned Task without ID.");
            }
        }

        throw new InvalidOperationException("No compatible overload for TicketsService.CreateTicketAsync was found.");
    }

    private static void TrySetProp(object target, string propName, object? value)
    {
        try
        {
            var t = target.GetType();
            var p = t.GetProperty(propName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (p is null || !p.CanWrite)
                return;

            var coerced = CoerceToParameterType(value, p.PropertyType);
            p.SetValue(target, coerced);
        }
        catch
        {
        }
    }

