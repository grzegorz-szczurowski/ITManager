            => perms != null && perms.Any(p => !string.IsNullOrWhiteSpace(p) && ctx.Has(p));

        var canViewAnyByViewPerms = HasAny(PermViewOwn, PermViewAssigned, PermViewTeam);
        var canViewAnyByEditPerms = HasAny(PermEditOwn, PermEditAssigned, PermEditAll);
        var canViewAnyByAssignPerms = HasAny(PermAssignTeam);

        _canViewModule = ctx.IsAuthenticated && ctx.IsActive == true && (canViewAnyByViewPerms || canViewAnyByEditPerms || canViewAnyByAssignPerms);

        _canCreateMode = ctx.IsAuthenticated && ctx.IsActive == true && (ctx.Has(PermCreateOwn) || canViewAnyByEditPerms);

        _canAssign = ctx.IsAuthenticated && ctx.IsActive == true && HasAny(PermAssignTeam, PermEditAll);

        _canEdit = ctx.IsAuthenticated && ctx.IsActive == true && canViewAnyByEditPerms;

        _canEditRequester = ctx.IsAuthenticated && ctx.IsActive == true && HasAny(PermEditAll);
        _canChangeOperator = ctx.IsAuthenticated && ctx.IsActive == true && HasAny(PermAssignTeam, PermEditAll);

        _canAddAction = _canEdit;

        _canSeePublicColumn = ctx.IsAuthenticated && ctx.IsActive == true && HasAny(
