        _busy = true;

        try
        {
            string? requesterToSend = null;

            if (_canEditRequester)
            {
                var trimmed = (_requesterName ?? string.Empty).Trim();
                if (!string.IsNullOrWhiteSpace(trimmed))
                    requesterToSend = trimmed;
            }

            var titleTrimmed = (_titleText ?? string.Empty).Trim();

            var pd = (_problemDescription ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(pd))
                pd = titleTrimmed;

            var newTicketId = await CreateTicketThroughAdapterAsync(
                title: titleTrimmed,
                problemDescription: pd,
                impactName: (_selectedImpact ?? string.Empty).Trim(),
                urgencyName: (_selectedUrgency ?? string.Empty).Trim(),
                categoryName: (_selectedCategory ?? string.Empty).Trim(),
                requesterName: requesterToSend
            );

            var created = await TicketsService.GetTicketByIdAsync((int)newTicketId);
            var createdCode = created is null ? string.Empty : GetTicketCodeFromTicket(created);

            Snackbar.Add(string.Format(L["TicketCreatedSuccess"], !string.IsNullOrWhiteSpace(createdCode) ? createdCode : newTicketId.ToString()), Severity.Success);

            await Task.Yield();

            var returnUrl = Uri.EscapeDataString(_returnUrl);

            if (!string.IsNullOrWhiteSpace(createdCode))
                NavigationManager.NavigateTo($"/tickets/{Uri.EscapeDataString(createdCode)}?returnUrl={returnUrl}", replace: true);
