    private static string GetStringProp(object obj, params string[] names)
    {
        if (obj is null || names is null || names.Length == 0)
            return string.Empty;

        var t = obj.GetType();

        foreach (var n in names)
        {
            if (string.IsNullOrWhiteSpace(n))
                continue;

            var p = t.GetProperty(n, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (p is null)
                continue;

            var val = p.GetValue(obj);
            if (val is null)
                continue;

            if (val is string s)
            {
                s = s.Trim();
                if (!string.IsNullOrWhiteSpace(s))
                    return s;

                continue;
            }

            var text = val.ToString()?.Trim() ?? string.Empty;
            if (!string.IsNullOrWhiteSpace(text))
                return text;
        }

        return string.Empty;
    }

