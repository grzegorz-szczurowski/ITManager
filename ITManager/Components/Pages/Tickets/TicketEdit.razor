    private static int ClampPriorityScore(int raw)
    {
        if (raw <= 0)
            return 0;

        return Math.Max(1, Math.Min(120, raw));
    }

    private static string NormalizePriorityTag(string? raw)
    {
        var s = (raw ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(s))
            return string.Empty;

        if (string.Equals(s, PriorityEmergency, StringComparison.OrdinalIgnoreCase))
            return PriorityCritical;

        return s;
    }

    private string GetPriorityLabelFromTag(string? rawTag)
    {
        var tag = NormalizePriorityTag(rawTag);

        return tag switch
        {
            PriorityCritical => L["Priority.Critical"],
            PriorityVeryHigh => L["Priority.VeryHigh"],
            PriorityHigh => L["Priority.High"],
            PriorityMedium => L["Priority.Medium"],
            PriorityLow => L["Priority.Low"],
            _ => string.IsNullOrWhiteSpace(tag) ? L["Priority.Unknown"] : tag
        };
    }

    private string GetPriorityTagFromScore(int clampedScore)
    {
        if (clampedScore <= 0) return string.Empty;
        if (clampedScore >= 80) return PriorityCritical;
        if (clampedScore >= 50) return PriorityVeryHigh;
        if (clampedScore >= 30) return PriorityHigh;
        if (clampedScore >= 15) return PriorityMedium;
        return PriorityLow;
    }

    private static int GetWeightPriorityFromTicketSafe(Ticket ticket)
    {
        try
        {
            var t = ticket.GetType();

            var p = t.GetProperty("WeightPriority", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("weight_priority", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("TicketPriorityValue", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("ticket_priority_value", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("PriorityValue", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                ?? t.GetProperty("Priority", BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (p is null)
                return 0;

            var raw = p.GetValue(ticket);
            if (raw is null)
                return 0;

            if (raw is int i) return i;
            if (raw is long l) return (int)Math.Max(int.MinValue, Math.Min(int.MaxValue, l));
            if (raw is short s) return s;
            if (raw is byte b) return b;
            if (raw is decimal dec) return (int)Math.Round(dec, MidpointRounding.AwayFromZero);
            if (raw is double dbl) return (int)Math.Round(dbl, MidpointRounding.AwayFromZero);
            if (raw is float fl) return (int)Math.Round(fl, MidpointRounding.AwayFromZero);

            var str = raw.ToString();
            if (!string.IsNullOrWhiteSpace(str) && int.TryParse(str, out var parsed))
                return parsed;

            return 0;
        }
        catch
        {
            return 0;
        }
    }

