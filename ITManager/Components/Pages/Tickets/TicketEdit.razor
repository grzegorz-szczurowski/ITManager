    private Task<List<string>> LoadAllowedStatusesSafeAsync()
    {
        try
        {
            if (_ticket is null)
                return Task.FromResult(new List<string>());

            var currentStatusName = (_ticket.TicketStatusesName ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(currentStatusName))
                return Task.FromResult(new List<string>());

            var currentStatus = TicketWorkflow.MapFromDbStatusName(currentStatusName);

            var ctx = CurrentUserContextService.CurrentUser;
            var permBag = new List<string>(8);

            if (ctx.Has(PermEditAll)) permBag.Add(PermEditAll);
            if (ctx.Has(PermEditAssigned)) permBag.Add(PermEditAssigned);
            if (ctx.Has(PermAssignTeam)) permBag.Add(PermAssignTeam);

            var role = TicketWorkflow.MapFromPermissions(permBag);

            var allowedTargets = TicketWorkflow.GetAllowedTargets(
                currentStatus: currentStatus,
                role: role,
                now: DateTime.UtcNow,
                closedOrResolvedAtUtcOrLocal: null
            );

            var allowedDbNames = allowedTargets
                .Select(TicketWorkflow.ToDbStatusName)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            return Task.FromResult(allowedDbNames);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[TicketEdit.LoadAllowedStatusesSafeAsync] ERROR: {ex}");
            return Task.FromResult(new List<string>());
        }
    }

