        width: 100%;
        max-width: none;
        height: calc(100vh - 110px);
        display: flex;
        flex-direction: column;
    }

    .ticketcreate-layout {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .ticketcreate-header {
        flex: 0 0 auto;
    }

    .ticketcreate-securitybox {
        width: 100%;
        border: 1px solid var(--mud-palette-divider);
        border-radius: 6px;
