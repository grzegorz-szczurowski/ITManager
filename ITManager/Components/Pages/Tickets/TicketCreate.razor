@page "/tickets/new"
@namespace ITManager.Components.Pages.Tickets

@* File: Components/Pages/Tickets/TicketCreate.razor
   Description: Create ticket page (end-user). Strict v2 create rules: FirstAction required, dictionary weights from DB.
   Version: 1.03
   Created: 2026-02-08
   Updated: 2026-02-08
   Change log:
   - 1.03 (2026-02-08) UX: full page sizing (width/height) + sticky footer + dark mode toggle text white.
   - 1.02 (2026-02-08) FIX: brak preselected toggle w Create (Value nie może być null) + filtr pustych wartości ze słowników.
   - 1.01 (2026-02-08) Urgency/Impact: użyj tego samego mechanizmu wyświetlania (CSS classes + NormalizeLevel + segmented toggle) co w TicketEdit.
   - 1.00 (2026-02-08) Initial version.
*@

@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading.Tasks
@using MudBlazor
@using ITManager.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Localization
@using ITManager.Services.Auth
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Policy = "Perm:Tickets.View")]

@inject TicketsService TicketsService
@inject CurrentUserContextService CurrentUserContextService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IStringLocalizer<TicketCreate> L
@inject TimeZoneService TimeZoneService

<MudPaper Class="pa-4 ticketcreate-page" Elevation="0">

    <MudStack Spacing="2" Class="ticketcreate-layout">

        <MudStack Spacing="0" Class="ticketcreate-header">
            <MudText Typo="Typo.h6">@GetDialogTitle()</MudText>
            <MudText Typo="Typo.body2" Style="opacity:0.75;">@GetDialogSubtitle()</MudText>
        </MudStack>

        <MudPaper Elevation="0" Class="pa-3 ticketcreate-securitybox">

            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                <MudText Typo="Typo.body2">
                    <b>@L["SecurityBoxTitle"]</b> @L["SecurityBoxText"]
                </MudText>
            </MudAlert>

        </MudPaper>

        @if (!_canCreate)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">
                @L["NoCreatePermission"]
            </MudAlert>

            <MudPaper Elevation="0" Class="ticketcreate-footer pa-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="Cancel">
                        @L["CloseButton"]
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
        else if (_loading)
        {
            <MudProgressCircular Size="Size.Large" Class="mx-auto" />
        }
        else
        {
            <div class="ticketcreate-content">

                <MudGrid GutterSize="4" AlignItems="AlignItems.Stretch">

                    <MudItem xs="12" md="7" Class="d-flex">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column ticketcreate-card"
                                  Style="width:100%; height:100%;">

                            <MudText Typo="Typo.subtitle1" Class="mb-3">@L["DetailsSectionTitle"]</MudText>

                            <MudTextField T="string"
                                          @ref="_titleField"
                                          Label="@L["TitleLabel"]"
                                          @bind-Value="_title"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Dense="true"
                                          MaxLength="160"
                                          Counter="160"
                                          Immediate="true"
                                          Class="mb-2"
                                          Disabled="@_saving"
                                          Error="@(_submitAttempted && !IsTitleValid())"
                                          ErrorText=" " />

                            <div style="min-height:18px;">
                                @if (_submitAttempted && !IsTitleValid())
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                        @GetTitleInvalidText()
                                    </MudText>
                                }
                            </div>

                            <MudTextField T="string"
                                          Label="@L["DescriptionLabel"]"
                                          @bind-Value="_firstActionText"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Lines="16"
                                          TextAlign="TextAlign.Left"
                                          Margin="Margin.Dense"
                                          MaxLength="2000"
                                          Counter="2000"
                                          Immediate="true"
                                          Class="mb-2 flex-grow-1 ticketcreate-desc-field"
                                          Disabled="@_saving"
                                          Error="@(_submitAttempted && !IsFirstActionValid())"
                                          ErrorText=" " />

                            <div style="min-height:18px;">
                                @if (_submitAttempted && !IsFirstActionValid())
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                        @GetDescriptionInvalidText()
                                    </MudText>
                                }
                            </div>

                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="5" Class="d-flex">
                        <MudStack Spacing="4" Class="d-flex" Style="width:100%;">

                            <MudPaper Elevation="0" Class="pa-4 d-flex flex-column ticketcreate-card"
                                      Style="@GetSectionBorderStyle(missing: _submitAttempted && string.IsNullOrWhiteSpace(_selectedUrgency), minHeightPx: 190)">

                                <MudText Typo="Typo.subtitle1">@L["UrgencyTitle"]</MudText>
                                <MudText Typo="Typo.caption" Class="mb-2">@L["UrgencyHelp"]</MudText>

                                <MudToggleGroup T="string"
                                                Exclusive="true"
                                                Value="@_selectedUrgency"
                                                ValueChanged="OnUrgencyChanged"
                                                Disabled="@_saving"
                                                Class="segmented-toggle"
                                                FullWidth="true">
                                    @foreach (var u in _urgencyOptionsSorted)
                                    {
                                        var level = NormalizeLevel(u?.Name);
                                        var isCritical = string.Equals(level, LevelCritical, StringComparison.OrdinalIgnoreCase);
                                        var isDisabled = isCritical && !_canSelectCritical;
                                        var css = GetSeverityToggleClass(level);

                                        <MudToggleItem T="string"
                                                       Value="@level"
                                                       Disabled="@isDisabled"
                                                       Class="@css">
                                            @if (isCritical)
                                            {
                                                <MudTooltip Text="@GetCriticalManagersOnlyTooltip()" Placement="Placement.Top" Delay="250">
                                                    <span style="display:inline-block;">
                                                        @LevelLabel(level)
                                                    </span>
                                                </MudTooltip>
                                            }
                                            else
                                            {
                                                <span>@LevelLabel(level)</span>
                                            }
                                        </MudToggleItem>
                                    }
                                </MudToggleGroup>

                                <MudText Typo="Typo.caption" Class="toggle-desc">
                                    @GetUrgencyDescriptionOrHint()
                                </MudText>

                                @if (_submitAttempted && string.IsNullOrWhiteSpace(_selectedUrgency))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">
                                        @L["UrgencyRequired"]
                                    </MudText>
                                }
                            </MudPaper>

                            <MudPaper Elevation="0" Class="pa-4 d-flex flex-column ticketcreate-card"
                                      Style="@GetSectionBorderStyle(missing: _submitAttempted && string.IsNullOrWhiteSpace(_selectedImpact), minHeightPx: 210)">

                                <MudText Typo="Typo.subtitle1">@L["ImpactTitle"]</MudText>
                                <MudText Typo="Typo.caption" Class="mb-2">@L["ImpactHelp"]</MudText>

                                <MudToggleGroup T="string"
                                                Exclusive="true"
                                                Value="@_selectedImpact"
                                                ValueChanged="OnImpactChanged"
                                                Disabled="@_saving"
                                                Class="segmented-toggle"
                                                FullWidth="true">
                                    @foreach (var i in _impactOptionsSorted)
                                    {
                                        var level = NormalizeLevel(i?.Name);
                                        var isCritical = string.Equals(level, LevelCritical, StringComparison.OrdinalIgnoreCase);
                                        var isDisabled = isCritical && !_canSelectCritical;
                                        var css = GetSeverityToggleClass(level);

                                        <MudToggleItem T="string"
                                                       Value="@level"
                                                       Disabled="@isDisabled"
                                                       Class="@css">
                                            @if (isCritical)
                                            {
                                                <MudTooltip Text="@GetCriticalManagersOnlyTooltip()" Placement="Placement.Top" Delay="250">
                                                    <span style="display:inline-block;">
                                                        @LevelLabel(level)
                                                    </span>
                                                </MudTooltip>
                                            }
                                            else
                                            {
                                                <span>@LevelLabel(level)</span>
                                            }
                                        </MudToggleItem>
                                    }
                                </MudToggleGroup>

                                <MudText Typo="Typo.caption" Class="toggle-desc">
                                    @GetImpactDescriptionOrHint()
                                </MudText>

                                @if (_submitAttempted && string.IsNullOrWhiteSpace(_selectedImpact))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">
                                        @L["ImpactRequired"]
                                    </MudText>
                                }
                            </MudPaper>

                            <MudPaper Elevation="0" Class="pa-4 d-flex flex-column ticketcreate-card"
                                      Style="width:100%;">

                                <MudText Typo="Typo.subtitle1">@L["PriorityTitle"]</MudText>
                                <MudText Typo="Typo.caption" Class="mb-2">@L["PriorityHelp"]</MudText>

                                <div style="@GetPriorityBoxStyleCentered()">
                                    @GetPriorityText()
                                </div>

                            </MudPaper>

                        </MudStack>
                    </MudItem>

                </MudGrid>

            </div>

            <MudPaper Elevation="0" Class="ticketcreate-footer pa-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Send"
                               Disabled="@(_saving || !_canCreate)"
                               OnClick="CreateAsync">
                        @L["SubmitButton"]
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Close"
                               Disabled="@_saving"
                               OnClick="Cancel">
                        @L["CancelButton"]
                    </MudButton>

                </MudStack>
            </MudPaper>
        }

    </MudStack>

</MudPaper>

<style>
