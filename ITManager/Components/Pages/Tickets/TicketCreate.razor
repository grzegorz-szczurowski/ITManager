@code
{
    [SupplyParameterFromQuery(Name = "returnUrl")]
    [Parameter] public string? ReturnUrl { get; set; }

    private const string PermTicketsCreateOwn = "Tickets.Create.Own";
    private const string PermTicketsEditAll = "Tickets.Edit.All";
    private const string PermTicketsLevelCritical = "Tickets.Level.Critical";

    private const string DefaultCategoryFallback = "User support";

    private const string LevelEmergency = "Emergency";
    private const string LevelCritical = "Critical";
    private const string LevelHigh = "High";
    private const string LevelMedium = "Medium";
    private const string LevelLow = "Low";
    private const string LevelInfo = "Info";

    private string _returnUrl = "/tickets/mine";

    private bool _loading = true;
    private bool _saving;
    private bool _submitAttempted;

    private bool _canCreate;
    private bool _canSelectCritical;

    private string _title = string.Empty;
    private string _firstActionText = string.Empty;

    // FIX: Value dla MudToggleGroup nie może być null, inaczej potrafi "zaznaczyć" pierwszy element w UI.
    private string _selectedUrgency = string.Empty;
    private string _selectedImpact = string.Empty;

    private int _weightPriority;

    private List<TicketsService.ImpactUrgencyItem> _urgencyOptions = new();
    private List<TicketsService.ImpactUrgencyItem> _impactOptions = new();

    private List<TicketsService.ImpactUrgencyItem> _urgencyOptionsSorted = new();
    private List<TicketsService.ImpactUrgencyItem> _impactOptionsSorted = new();

    private MudTextField<string>? _titleField;
    private bool _titleFocused;

    protected override async Task OnInitializedAsync()
    {
        _returnUrl = NormalizeReturnUrl(ReturnUrl);

        try
        {
            await CurrentUserContextService.EnsureInitializedAsync();
            var ctx = CurrentUserContextService.CurrentUser;

            var isOkUser = ctx.IsAuthenticated && ctx.IsActive == true;

            _canCreate = isOkUser && (ctx.Has(PermTicketsCreateOwn) || ctx.Has(PermTicketsEditAll));
            _canSelectCritical = isOkUser && ctx.Has(PermTicketsLevelCritical);
        }
        catch
        {
            _canCreate = false;
            _canSelectCritical = false;
        }

        try
        {
            var dict = await TicketsService.GetImpactAndUrgencyDictionaryAsync();
            _impactOptions = dict?.Impacts ?? new List<TicketsService.ImpactUrgencyItem>();
            _urgencyOptions = dict?.Urgencies ?? new List<TicketsService.ImpactUrgencyItem>();
        }
        catch
        {
            _impactOptions = new List<TicketsService.ImpactUrgencyItem>();
            _urgencyOptions = new List<TicketsService.ImpactUrgencyItem>();
        }

        // FIX: filtrujemy puste/whitespace nazwy, żeby nie wygenerować toggle o Value="",
        // bo to potrafi wyglądać jak "zaznaczone" przy pustej wartości.
        _urgencyOptionsSorted = SortLevelsForUi(_urgencyOptions, isImpact: false)
            .Where(x => !string.IsNullOrWhiteSpace(NormalizeLevel(x?.Name)))
            .ToList();

        _impactOptionsSorted = SortLevelsForUi(_impactOptions, isImpact: true)
            .Where(x => !string.IsNullOrWhiteSpace(NormalizeLevel(x?.Name)))
            .ToList();

        if (!_canSelectCritical)
        {
            if (string.Equals(NormalizeLevel(_selectedUrgency), LevelCritical, StringComparison.OrdinalIgnoreCase))
                _selectedUrgency = string.Empty;

            if (string.Equals(NormalizeLevel(_selectedImpact), LevelCritical, StringComparison.OrdinalIgnoreCase))
                _selectedImpact = string.Empty;
        }

        RecalculatePriority();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || !_canCreate)
            return;

        if (_titleFocused)
            return;

        _titleFocused = true;

        try
        {
            if (_titleField is not null)
                await _titleField.FocusAsync();
        }
        catch
        {
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(_returnUrl, forceLoad: false, replace: true);
    }

    private Task OnUrgencyChanged(string value)
    {
        _selectedUrgency = NormalizeLevel(value);
        RecalculatePriority();
        return Task.CompletedTask;
    }

    private Task OnImpactChanged(string value)
    {
        _selectedImpact = NormalizeLevel(value);
        RecalculatePriority();
        return Task.CompletedTask;
    }

    private async Task CreateAsync()
    {
        if (_saving)
            return;

        if (!_canCreate)
        {
            Snackbar.Add(L["NoCreatePermission"], Severity.Warning);
            return;
        }

        _submitAttempted = true;
        RecalculatePriority();

        if (!IsFormValid())
        {
            Snackbar.Add(L["FormInvalidWarning"], Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            var createdAtUtc = DateTime.UtcNow;

            var req = new TicketsService.CreateTicketRequest
            {
                Title = _title.Trim(),
                FirstActionText = _firstActionText.Trim(),
                CategoryName = GetDefaultCategoryName(),
                ImpactName = NormalizeLevel(_selectedImpact),
                UrgencyName = NormalizeLevel(_selectedUrgency),
                RequesterDisplayName = null
            };

            var newTicketId = await TicketsService.CreateTicketAsync(req);

            string displayCode;
            try
            {
                var ticket = await TicketsService.GetTicketByIdAsync((int)Math.Min(int.MaxValue, newTicketId));
                displayCode = string.IsNullOrWhiteSpace(ticket?.TicketCode) ? newTicketId.ToString() : ticket!.TicketCode.Trim();
            }
            catch
            {
                displayCode = newTicketId.ToString();
            }

            var createdAtLocal = await TimeZoneService.FromUtcAsync(createdAtUtc);

            var msg = string.Format(L["TicketCreatedSuccess"], displayCode);
            msg += $" ({createdAtLocal:yyyy-MM-dd HH:mm})";

            Snackbar.Add(msg, Severity.Success);
            NavigationManager.NavigateTo(_returnUrl, forceLoad: false, replace: true);
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add(L["NoCreatePermission"], Severity.Warning);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[TicketCreatePage.CreateAsync] ERROR: {ex}");
            Snackbar.Add(string.Format(L["SaveError"], ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private string GetDialogTitle()
    {
        var v = L["DialogTitle"].Value;
        if (!string.IsNullOrWhiteSpace(v) && !string.Equals(v, "DialogTitle", StringComparison.Ordinal))
            return v;

        return "Nowe zgłoszenie";
    }

    private string GetDialogSubtitle()
    {
        var v = L["DialogSubtitle"].Value;
        if (!string.IsNullOrWhiteSpace(v) && !string.Equals(v, "DialogSubtitle", StringComparison.Ordinal))
            return v;

        return "Opisz problem i wybierz Pilność oraz Wpływ. Priorytet zostanie wyliczony automatycznie.";
    }

    private string GetCriticalManagersOnlyTooltip()
    {
        var loc = L["CriticalManagersOnlyTooltip"].Value;
        if (!string.IsNullOrWhiteSpace(loc) && !string.Equals(loc, "CriticalManagersOnlyTooltip", StringComparison.Ordinal))
            return loc;

        return "Poziom Krytyczne jest dostępny wyłącznie dla menedżerów. Użyj go tylko w sytuacjach wymagających eskalacji.";
    }

    private string LevelLabel(string code)
    {
        var c = NormalizeLevel(code);
        var key = $"Level_{c}";
        var text = L[key];
        return string.IsNullOrWhiteSpace(text) ? c : text;
    }

    private string GetTitleInvalidText()
    {
        var v = L["TitleTooShort"].Value;
        if (!string.IsNullOrWhiteSpace(v) && !string.Equals(v, "TitleTooShort", StringComparison.Ordinal))
            return v;

        return "Tytuł jest zbyt krótki.";
    }

    private string GetDescriptionInvalidText()
    {
        var v = L["DescriptionTooShort"].Value;
        if (!string.IsNullOrWhiteSpace(v) && !string.Equals(v, "DescriptionTooShort", StringComparison.Ordinal))
            return v;

        return "Opis jest zbyt krótki.";
    }

    private string NormalizeReturnUrl(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return "/tickets/mine";

        raw = raw.Trim();

        if (Uri.TryCreate(raw, UriKind.Absolute, out var abs))
        {
            var appBase = new Uri(NavigationManager.BaseUri);
            if (!string.Equals(abs.Host, appBase.Host, StringComparison.OrdinalIgnoreCase))
                return "/tickets/mine";

            return abs.PathAndQuery.StartsWith("/", StringComparison.Ordinal) ? abs.PathAndQuery : "/tickets/mine";
        }

        if (!raw.StartsWith("/", StringComparison.Ordinal))
            return "/tickets/mine";

        if (raw.StartsWith("//", StringComparison.Ordinal))
            return "/tickets/mine";

        if (raw.Contains("\r") || raw.Contains("\n"))
            return "/tickets/mine";

        return raw;
    }

    private void RecalculatePriority()
    {
        var impactWeight = GetImpactWeight(_selectedImpact);
        var urgencyWeight = GetUrgencyWeight(_selectedUrgency);
        _weightPriority = impactWeight * urgencyWeight;
    }

    private bool IsTitleValid()
    {
        var t = (_title ?? string.Empty).Trim();
        return t.Length >= 3 && t.Length <= 160;
    }

    private bool IsFirstActionValid()
    {
        var d = (_firstActionText ?? string.Empty).Trim();
        return d.Length >= 3 && d.Length <= 2000;
    }

    private bool IsFormValid()
    {
        if (string.IsNullOrWhiteSpace(_selectedUrgency))
            return false;

        if (string.IsNullOrWhiteSpace(_selectedImpact))
            return false;

        if (!IsTitleValid())
            return false;

        if (!IsFirstActionValid())
            return false;

        if (!_canSelectCritical)
        {
            if (string.Equals(NormalizeLevel(_selectedUrgency), LevelCritical, StringComparison.OrdinalIgnoreCase))
                return false;

            if (string.Equals(NormalizeLevel(_selectedImpact), LevelCritical, StringComparison.OrdinalIgnoreCase))
                return false;
        }

        return true;
    }

    private string GetUrgencyDescriptionOrHint()
    {
        if (string.IsNullOrWhiteSpace(_selectedUrgency))
            return L["SelectUrgencyHint"];

        var key = GetUrgencyDescriptionKey(_selectedUrgency);
        return string.IsNullOrWhiteSpace(key) ? string.Empty : L[key];
    }

    private string GetImpactDescriptionOrHint()
    {
        if (string.IsNullOrWhiteSpace(_selectedImpact))
            return L["SelectImpactHint"];

        var key = GetImpactDescriptionKey(_selectedImpact);
        return string.IsNullOrWhiteSpace(key) ? string.Empty : L[key];
    }

    private int GetImpactWeight(string impact)
    {
        var n = NormalizeLevel(impact);
        if (string.IsNullOrWhiteSpace(n))
            return 0;

        var item = _impactOptions.FirstOrDefault(x => string.Equals(NormalizeLevel(x?.Name), n, StringComparison.OrdinalIgnoreCase));
        return item?.Weight ?? 0;
    }

    private int GetUrgencyWeight(string urgency)
    {
        var n = NormalizeLevel(urgency);
        if (string.IsNullOrWhiteSpace(n))
            return 0;

        var item = _urgencyOptions.FirstOrDefault(x => string.Equals(NormalizeLevel(x?.Name), n, StringComparison.OrdinalIgnoreCase));
        return item?.Weight ?? 0;
    }

    private string GetPriorityText()
    {
        if (_weightPriority <= 0)
            return L["PriorityNone"];

        var code = GetPriorityCode(_weightPriority);
        return GetPriorityLabel(code);
    }

    private string GetPriorityLabel(string code) => code switch
    {
        "P1" => L["PriorityP1"],
        "P2" => L["PriorityP2"],
        "P3" => L["PriorityP3"],
        "P4" => L["PriorityP4"],
        "P5" => L["PriorityP5"],
        _ => L["PriorityNone"]
    };

    private static string GetPriorityCode(int score)
    {
        if (score >= 80) return "P1";
        if (score >= 50) return "P2";
        if (score >= 30) return "P3";
        if (score >= 15) return "P4";
        if (score >= 1) return "P5";
        return "NONE";
    }

    private static string GetUrgencyDescriptionKey(string? name) => NormalizeLevel(name) switch
    {
        LevelCritical => "UrgencyDescCritical",
        LevelHigh => "UrgencyDescHigh",
        LevelMedium => "UrgencyDescMedium",
        LevelLow => "UrgencyDescLow",
        _ => string.Empty
    };

    private static string GetImpactDescriptionKey(string? name) => NormalizeLevel(name) switch
    {
        LevelCritical => "ImpactDescCritical",
        LevelHigh => "ImpactDescHigh",
        LevelMedium => "ImpactDescMedium",
        LevelLow => "ImpactDescLow",
        LevelInfo => "ImpactDescInfo",
        _ => string.Empty
    };

    private string GetSeverityToggleClass(string level)
    {
        var l = NormalizeLevel(level);

        return l switch
        {
            LevelCritical => "sev-critical",
            LevelHigh => "sev-high",
            LevelMedium => "sev-medium",
            LevelLow => "sev-low",
            LevelInfo => "sev-info",
            _ => "sev-info"
        };
    }

    private static string NormalizeLevel(string? raw)
    {
        var s = (raw ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(s))
            return string.Empty;

        if (string.Equals(s, LevelEmergency, StringComparison.OrdinalIgnoreCase))
            return LevelCritical;

        if (string.Equals(s, LevelCritical, StringComparison.OrdinalIgnoreCase)) return LevelCritical;
        if (string.Equals(s, LevelHigh, StringComparison.OrdinalIgnoreCase)) return LevelHigh;
        if (string.Equals(s, LevelMedium, StringComparison.OrdinalIgnoreCase)) return LevelMedium;
        if (string.Equals(s, LevelLow, StringComparison.OrdinalIgnoreCase)) return LevelLow;
        if (string.Equals(s, LevelInfo, StringComparison.OrdinalIgnoreCase)) return LevelInfo;

        return s;
    }

    private static string GetSectionBorderStyle(bool missing, int minHeightPx)
    {
        var border = missing ? "1px solid var(--mud-palette-error)" : "1px solid var(--mud-palette-divider)";
        return $"width:100%; min-height:{minHeightPx}px; border:{border}; border-radius:6px; background-color: var(--mud-palette-background-paper);";
    }

    private string GetPriorityBoxStyleCentered()
    {
        var code = GetPriorityCode(_weightPriority);

        var fill = code switch
        {
            "P1" => "#D32F2F",
            "P2" => "#D32F2F",
            "P3" => "#F57C00",
            "P4" => "#0288D1",
            "P5" => "#2E7D32",
            _ => "#607D8B"
        };

        const string borderColor = "#0288D1";

        return "margin-top:14px; padding:16px 16px; border-radius:6px; " +
               $"background-color:{fill}; color:#FFFFFF; border:1px solid {borderColor}; " +
               "display:flex; align-items:center; justify-content:center; font-weight:600;";
    }

    private string GetDefaultCategoryName()
    {
        var v = L["DefaultCategoryName"].Value;
        if (!string.IsNullOrWhiteSpace(v) && !string.Equals(v, "DefaultCategoryName", StringComparison.Ordinal))
            return v.Trim();

        return DefaultCategoryFallback;
    }

    private static List<TicketsService.ImpactUrgencyItem> SortLevelsForUi(List<TicketsService.ImpactUrgencyItem> items, bool isImpact)
    {
        if (items is null || items.Count == 0)
            return new List<TicketsService.ImpactUrgencyItem>();

        return items
            .OrderBy(x => GetUiOrder(NormalizeLevel(x?.Name), isImpact))
            .ThenBy(x => NormalizeLevel(x?.Name), StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static int GetUiOrder(string name, bool isImpact)
    {
        name = NormalizeLevel(name);

        if (isImpact)
        {
            return name switch
            {
                LevelInfo => 0,
                LevelLow => 10,
                LevelMedium => 20,
                LevelHigh => 30,
                LevelCritical => 40,
                _ => 999
            };
        }

        return name switch
        {
            LevelLow => 10,
            LevelMedium => 20,
            LevelHigh => 30,
            LevelCritical => 40,
            _ => 999
        };
    }
}
