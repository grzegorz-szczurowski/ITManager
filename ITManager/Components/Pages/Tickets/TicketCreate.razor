        border: 1px solid #0288D1 !important;
    }

    .segmented-toggle .mud-toggle-item.sev-high.mud-selected,
    .segmented-toggle .mud-toggle-item.sev-high.mud-toggle-item-selected {
        background-color: #F57C00 !important;
        color: #FFFFFF !important;
        border: 1px solid #0288D1 !important;
    }

    .segmented-toggle .mud-toggle-item.sev-medium.mud-selected,
    .segmented-toggle .mud-toggle-item.sev-medium.mud-toggle-item-selected {
