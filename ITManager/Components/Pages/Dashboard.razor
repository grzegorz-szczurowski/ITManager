    private static int ParsePriorityWeight(object? raw)
    {
        if (raw == null || raw == DBNull.Value)
            return 0;

        try
        {
            int w;

            if (raw is int i) w = i;
            else if (raw is long l) w = (int)l;
            else if (raw is short s) w = s;
            else if (raw is byte b) w = b;
            else if (raw is decimal d) w = (int)d;
            else if (raw is double db) w = (int)db;
            else
            {
                var txt = raw.ToString();
                if (string.IsNullOrWhiteSpace(txt)) return 0;
                if (!int.TryParse(txt, out w)) return 0;
            }

            if (w <= 0) return 0;
            return Math.Max(1, Math.Min(120, w));
        }
        catch
        {
            return 0;
        }
    }

    private static string GetPriorityTag(int weightPriority)
    {
        var s = weightPriority;

        if (s >= 80) return "Emergency";
        if (s >= 50) return "Very High";
        if (s >= 30) return "High";
        if (s >= 15) return "Medium";
        if (s >= 1) return "Low";
        return "None";
    }

    private static string BuildPriorityText(int weightPriority)
    {
        if (weightPriority <= 0) return "-";
        var clamped = Math.Max(1, Math.Min(120, weightPriority));
        var tag = GetPriorityTag(clamped);
        return $"{tag} ({clamped})";
    }

    private static Color GetPriorityColorByTag(string? priorityTag)
    {
        var tag = (priorityTag ?? string.Empty).Trim();

        return tag switch
        {
            "Emergency" => Color.Error,
            "Very High" => Color.Error,
            "High" => Color.Warning,
            "Medium" => Color.Info,
            "Low" => Color.Success,
            _ => Color.Default
        };
    }

    private RenderFragment PriorityChip(TicketListRow row) => builder =>
    {
        var color = GetPriorityColorByTag(row?.PriorityTag);

        builder.OpenComponent<MudChip<string>>(0);
        builder.AddAttribute(1, "Size", Size.Small);
        builder.AddAttribute(2, "Color", color);
        builder.AddAttribute(3, "Variant", Variant.Filled);
        builder.AddAttribute(4, "Label", true);
        builder.AddAttribute(5, "Style", "min-width:110px; justify-content:center;");
        builder.AddAttribute(6, "ChildContent", (RenderFragment)(b =>
        {
            b.AddContent(0, row?.PriorityText ?? "-");
        }));
        builder.CloseComponent();
    };

