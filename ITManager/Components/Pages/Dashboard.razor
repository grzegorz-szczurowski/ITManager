    private async Task<List<TicketListRow>> ReadTicketListAsync(SqlCommand cmd)
    {
        using var reader = await cmd.ExecuteReaderAsync();
        var listOut = new List<TicketListRow>();

        while (await reader.ReadAsync())
        {
            var id = reader.IsDBNull(0) ? 0 : Convert.ToInt32(reader.GetValue(0));
            var title = reader.IsDBNull(1) ? string.Empty : (reader.GetString(1) ?? string.Empty);
            if (string.IsNullOrWhiteSpace(title)) title = L["NoTitle"];

            var status = reader.IsDBNull(2) ? string.Empty : (reader.GetString(2) ?? string.Empty);

            var priorityRaw = reader.IsDBNull(3) ? null : reader.GetValue(3);
            var weight = ParsePriorityWeight(priorityRaw);
            var tag = GetPriorityTag(weight);
            var text = BuildPriorityText(weight);

            var ageDays = reader.IsDBNull(4) ? 0 : Convert.ToInt32(reader.GetValue(4));
            var lastActionAge = reader.IsDBNull(5) ? 0 : Convert.ToInt32(reader.GetValue(5));

            listOut.Add(new TicketListRow
            {
                Id = id,
                Title = title,
                Status = status,

                WeightPriority = weight,
                PriorityTag = tag,
                PriorityText = text,

                AgeDays = ageDays,
                LastActionAgeDays = lastActionAge
            });
        }

        return listOut;
    }

