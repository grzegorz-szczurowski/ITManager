    private async Task LoadAssetsAsync(SqlConnection conn)
    {
        try
        {
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM dbo.devices;", conn))
            {
                cmd.CommandTimeout = 10;
                var result = await cmd.ExecuteScalarAsync();
                _devicesTotal = (result == null || result == DBNull.Value) ? 0 : Convert.ToInt32(result);
            }

            var hasDeviceKindsTable = await ExistsTableAsync(conn, "dbo", "device_kinds");
            var hasDeviceKindId = await ExistsColumnAsync(conn, "dbo", "devices", "device_kind_id");

            string sql;

            if (hasDeviceKindsTable && hasDeviceKindId)
            {
                sql =
                    "SELECT " +
                    "ISNULL(dk.name,'Unknown') AS type_name, " +
                    "COUNT(*) AS cnt " +
                    "FROM dbo.devices d " +
                    "LEFT JOIN dbo.device_kinds dk ON dk.id = d.device_kind_id " +
                    "GROUP BY ISNULL(dk.name,'Unknown') " +
                    "ORDER BY COUNT(*) DESC, ISNULL(dk.name,'Unknown') ASC;";
            }
            else
            {
                sql =
                    "SELECT 'All devices' AS type_name, COUNT(*) AS cnt " +
                    "FROM dbo.devices;";
            }

            var rows = new List<(string TypeName, int Count)>();

            using (var cmd = new SqlCommand(sql, conn))
            {
                cmd.CommandTimeout = 10;

                using var r = await cmd.ExecuteReaderAsync();
                while (await r.ReadAsync())
                {
                    var typeName = r.IsDBNull(0) ? "Unknown" : (r.GetString(0) ?? "Unknown");
                    var cnt = r.IsDBNull(1) ? 0 : Convert.ToInt32(r.GetValue(1));
                    rows.Add((typeName, cnt));
                }
            }

            _assetTypeBreakdown.Clear();

            var total = _devicesTotal.GetValueOrDefault(0);
            if (total <= 0)
            {
                _assetTypeChartLabels = Array.Empty<string>();
                _assetTypeChartData = Array.Empty<double>();
                return;
            }

            var ordered = rows
                .Where(x => x.Count > 0)
                .OrderByDescending(x => x.Count)
                .ToList();

            var maxSlices = 8;
            var main = ordered.Take(maxSlices).ToList();
            var rest = ordered.Skip(maxSlices).ToList();
            var restSum = rest.Sum(x => x.Count);

            var final = new List<(string TypeName, int Count)>();
            final.AddRange(main);

            if (restSum > 0)
                final.Add(("Other", restSum));

            foreach (var it in final)
            {
                var percent = total > 0 ? ((decimal)it.Count / total * 100m) : 0m;

                _assetTypeBreakdown.Add(new AssetTypeRow
                {
                    TypeName = it.TypeName,
                    Count = it.Count,
                    Percent = percent,
                    PercentText = percent.ToString("N1") + "%"
                });
            }

            _assetTypeChartLabels = _assetTypeBreakdown.Select(x => x.TypeName).ToArray();
            _assetTypeChartData = _assetTypeBreakdown.Select(x => (double)x.Count).ToArray();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine("[Dashboard] Assets query failed: " + ex);

            _devicesTotal = null;
            _assetTypeBreakdown.Clear();
            _assetTypeChartLabels = Array.Empty<string>();
            _assetTypeChartData = Array.Empty<double>();
        }
    }

