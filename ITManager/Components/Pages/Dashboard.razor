    private async Task LoadPrintersAsync(SqlConnection conn, int requestVersion)
    {
        long currPages = 0;
        long currColor = 0;
        long currMono = 0;

        decimal? currTotalCost = null;
        decimal? currColorCost = null;
        decimal? currMonoCost = null;

        long prevPages = 0;
        long prevColor = 0;
        long prevMono = 0;

        decimal? prevTotalCost = null;

        var topPrintersLocal = new List<PrinterRow>();

        var now = DateTime.Now;
        var currFrom = now.AddDays(-_printerDays);
        var currTo = now;

        var prevFrom = now.AddDays(-2 * _printerDays);
        var prevTo = now.AddDays(-_printerDays);

        var sqlAgg =
            "SELECT " +
            "CAST(ISNULL(SUM(CAST(cp.counter_total_difference as bigint)),0) as bigint) AS Pages, " +
            "CAST(ISNULL(SUM(CAST(ISNULL(cp.color_prints_difference,0) + ISNULL(cp.color_copies_difference,0) as bigint)),0) as bigint) AS ColorPages, " +
            "CAST(ISNULL(SUM(CAST(ISNULL(cp.mono_prints_difference,0) + ISNULL(cp.mono_copies_difference,0) as bigint)),0) as bigint) AS MonoPages, " +
            "CAST(ISNULL(SUM(CAST( " +
            "ISNULL(CASE WHEN d.PrintCostColorPage IS NULL THEN 0 ELSE (ISNULL(cp.color_prints_difference,0) + ISNULL(cp.color_copies_difference,0)) * d.PrintCostColorPage END, 0) + " +
            "ISNULL(CASE WHEN d.PrintCostMonoPage  IS NULL THEN 0 ELSE (ISNULL(cp.mono_prints_difference,0)  + ISNULL(cp.mono_copies_difference,0))  * d.PrintCostMonoPage  END, 0) " +
            "as decimal(18,2))),0) as decimal(18,2)) AS TotalCost, " +
            "CAST(ISNULL(SUM(CAST( " +
            "ISNULL(CASE WHEN d.PrintCostColorPage IS NULL THEN 0 ELSE (ISNULL(cp.color_prints_difference,0) + ISNULL(cp.color_copies_difference,0)) * d.PrintCostColorPage END, 0) " +
            "as decimal(18,2))),0) as decimal(18,2)) AS ColorCost, " +
            "CAST(ISNULL(SUM(CAST( " +
            "ISNULL(CASE WHEN d.PrintCostMonoPage IS NULL THEN 0 ELSE (ISNULL(cp.mono_prints_difference,0) + ISNULL(cp.mono_copies_difference,0)) * d.PrintCostMonoPage END, 0) " +
            "as decimal(18,2))),0) as decimal(18,2)) AS MonoCost, " +
            "CAST(MAX(CASE WHEN d.PrintCostColorPage IS NOT NULL OR d.PrintCostMonoPage IS NOT NULL THEN 1 ELSE 0 END) as bit) AS HasAnyCost " +
            "FROM dbo.counter_printers cp " +
            "INNER JOIN dbo.devices d ON d.id = cp.device_id " +
            "WHERE cp.read_time >= @from AND cp.read_time < @to;";

        using (var cmd = new SqlCommand(sqlAgg, conn))
        {
            cmd.CommandTimeout = 10;
            cmd.Parameters.AddWithValue("@from", currFrom);
            cmd.Parameters.AddWithValue("@to", currTo);

            using var r = await cmd.ExecuteReaderAsync();
            if (await r.ReadAsync())
            {
                currPages = r.IsDBNull(0) ? 0 : Convert.ToInt64(r.GetValue(0));
                currColor = r.IsDBNull(1) ? 0 : Convert.ToInt64(r.GetValue(1));
                currMono = r.IsDBNull(2) ? 0 : Convert.ToInt64(r.GetValue(2));

                var totalCost = r.IsDBNull(3) ? 0m : Convert.ToDecimal(r.GetValue(3));
                var colorCost = r.IsDBNull(4) ? 0m : Convert.ToDecimal(r.GetValue(4));
                var monoCost = r.IsDBNull(5) ? 0m : Convert.ToDecimal(r.GetValue(5));
                var hasAnyCost = !r.IsDBNull(6) && Convert.ToBoolean(r.GetValue(6));

                currTotalCost = hasAnyCost ? totalCost : null;
                currColorCost = hasAnyCost ? colorCost : null;
                currMonoCost = hasAnyCost ? monoCost : null;
            }
        }

        using (var cmd = new SqlCommand(sqlAgg, conn))
        {
            cmd.CommandTimeout = 10;
            cmd.Parameters.AddWithValue("@from", prevFrom);
            cmd.Parameters.AddWithValue("@to", prevTo);

            using var r = await cmd.ExecuteReaderAsync();
            if (await r.ReadAsync())
            {
                prevPages = r.IsDBNull(0) ? 0 : Convert.ToInt64(r.GetValue(0));
                prevColor = r.IsDBNull(1) ? 0 : Convert.ToInt64(r.GetValue(1));
                prevMono = r.IsDBNull(2) ? 0 : Convert.ToInt64(r.GetValue(2));

                var totalCost = r.IsDBNull(3) ? 0m : Convert.ToDecimal(r.GetValue(3));
                var hasAnyCost = !r.IsDBNull(6) && Convert.ToBoolean(r.GetValue(6));
                prevTotalCost = hasAnyCost ? totalCost : null;
            }
        }

        var sqlTop =
            "SELECT TOP 10 " +
            "d.id AS device_id, " +
            "d.hostname, " +
            "m.name AS model, " +
            "l.name AS location_name, " +
            "CAST(ISNULL(SUM(CAST(cp.counter_total_difference as bigint)),0) as bigint) AS pages, " +
            "CAST(ISNULL(SUM(CAST(ISNULL(cp.color_prints_difference,0) + ISNULL(cp.color_copies_difference,0) as bigint)),0) as bigint) AS color_pages, " +
            "CAST(ISNULL(SUM(CAST(ISNULL(cp.mono_prints_difference,0) + ISNULL(cp.mono_copies_difference,0) as bigint)),0) as bigint) AS mono_pages, " +
            "CAST(ISNULL(SUM(CAST( " +
            "ISNULL(CASE WHEN d.PrintCostColorPage IS NULL THEN 0 ELSE (ISNULL(cp.color_prints_difference,0) + ISNULL(cp.color_copies_difference,0)) * d.PrintCostColorPage END, 0) + " +
            "ISNULL(CASE WHEN d.PrintCostMonoPage  IS NULL THEN 0 ELSE (ISNULL(cp.mono_prints_difference,0)  + ISNULL(cp.mono_copies_difference,0))  * d.PrintCostMonoPage  END, 0) " +
            "as decimal(18,2))),0) as decimal(18,2)) AS total_cost, " +
            "CAST(MAX(CASE WHEN d.PrintCostColorPage IS NOT NULL OR d.PrintCostMonoPage IS NOT NULL THEN 1 ELSE 0 END) as bit) AS has_cost " +
            "FROM dbo.counter_printers cp " +
            "INNER JOIN dbo.devices d ON d.id = cp.device_id " +
            "LEFT JOIN dbo.models m ON m.id = d.model_id " +
            "LEFT JOIN dbo.locations l ON l.id = d.location_id " +
            "WHERE cp.read_time >= @from AND cp.read_time < @to " +
            "GROUP BY d.id, d.hostname, m.name, l.name " +
            "ORDER BY CAST(ISNULL(SUM(CAST( " +
            "ISNULL(CASE WHEN d.PrintCostColorPage IS NULL THEN 0 ELSE (ISNULL(cp.color_prints_difference,0) + ISNULL(cp.color_copies_difference,0)) * d.PrintCostColorPage END, 0) + " +
            "ISNULL(CASE WHEN d.PrintCostMonoPage  IS NULL THEN 0 ELSE (ISNULL(cp.mono_prints_difference,0)  + ISNULL(cp.mono_copies_difference,0))  * d.PrintCostMonoPage  END, 0) " +
            "as decimal(18,2))),0) as decimal(18,2)) DESC;";

        using (var cmd = new SqlCommand(sqlTop, conn))
        {
            cmd.CommandTimeout = 10;
            cmd.Parameters.AddWithValue("@from", currFrom);
            cmd.Parameters.AddWithValue("@to", currTo);

            using var r = await cmd.ExecuteReaderAsync();
            while (await r.ReadAsync())
            {
                var pages = r.IsDBNull(4) ? 0 : Convert.ToInt64(r.GetValue(4));
                var colorPages = r.IsDBNull(5) ? 0 : Convert.ToInt64(r.GetValue(5));
                var monoPages = r.IsDBNull(6) ? 0 : Convert.ToInt64(r.GetValue(6));

                var hasCost = !r.IsDBNull(8) && Convert.ToBoolean(r.GetValue(8));
                var cost = hasCost ? (r.IsDBNull(7) ? (decimal?)null : Convert.ToDecimal(r.GetValue(7))) : null;

                topPrintersLocal.Add(new PrinterRow
                {
                    DeviceId = r.IsDBNull(0) ? 0 : Convert.ToInt32(r.GetValue(0)),
                    Hostname = r.IsDBNull(1) ? string.Empty : (r.GetString(1) ?? string.Empty),
                    Model = r.IsDBNull(2) ? string.Empty : (r.GetString(2) ?? string.Empty),
                    Location = r.IsDBNull(3) ? string.Empty : (r.GetString(3) ?? string.Empty),

                    Pages = pages,
                    ColorPages = colorPages,
                    MonoPages = monoPages,

                    PagesText = pages.ToString("N0"),
                    ColorPagesText = colorPages.ToString("N0"),
                    MonoPagesText = monoPages.ToString("N0"),

                    Cost = cost,
                    CostText = cost.HasValue ? (cost.Value.ToString("N2") + " " + L["CurrencyPLN"]) : L["NA"]
                });
            }
        }

        if (requestVersion != _printersRequestVersion)
            return;

        _printerPagesInRange = currPages;
        _printerColorPagesInRange = currColor;
        _printerMonoPagesInRange = currMono;

        _printerTotalCostInRange = currTotalCost;
        _printerColorCostInRange = currColorCost;
        _printerMonoCostInRange = currMonoCost;

        _printerPagesChangePct = CalcChangePct(currPages, prevPages);
        _printerColorPagesChangePct = CalcChangePct(currColor, prevColor);
        _printerMonoPagesChangePct = CalcChangePct(currMono, prevMono);

        _printerCostChangePct = (currTotalCost.HasValue && prevTotalCost.HasValue)
            ? CalcChangePct(currTotalCost.Value, prevTotalCost.Value)
            : null;

        _topPrinters.Clear();
        _topPrinters.AddRange(topPrintersLocal);
    }

