@code {
    private const int TicketTrendDays = 30;

    private bool _isLoading = true;
    private string? _errorMessage;

    private bool _ticketsSchemaReady;
    private string? _ticketsSchemaDiagnostic;

    private int? _ticketsOpened30;
    private int? _ticketsClosed30;
    private int? _ticketsQueue;
    private int? _ticketsInProgress;
    private int? _ticketsWaiting;

    private decimal? _ticketsOpened30ChangePct;
    private decimal? _ticketsClosed30ChangePct;
    private decimal? _ticketsQueueChangePct;
    private decimal? _ticketsInProgressChangePct;
    private decimal? _ticketsWaitingChangePct;

    private readonly List<TicketListRow> _topOldestActiveTickets = new();
    private readonly List<TicketListRow> _topStaleActiveTickets = new();
    private readonly List<TicketListRow> _topOldestWaitingTickets = new();
    private readonly List<TicketListRow> _topStaleWaitingTickets = new();

    private readonly List<LicenseRow> _topExpiringLicenses = new();
    private readonly List<LicenseRow> _topUnusedLicenses = new();

    private int _printerDays = 30;

    private long? _printerPagesInRange;
    private long? _printerColorPagesInRange;
    private long? _printerMonoPagesInRange;

    private decimal? _printerTotalCostInRange;
    private decimal? _printerColorCostInRange;
    private decimal? _printerMonoCostInRange;

    private decimal? _printerPagesChangePct;
    private decimal? _printerColorPagesChangePct;
    private decimal? _printerMonoPagesChangePct;
    private decimal? _printerCostChangePct;

    private readonly List<PrinterRow> _topPrinters = new();
    private int _printersRequestVersion;

    private int? _devicesTotal;
    private readonly List<AssetTypeRow> _assetTypeBreakdown = new();
    private string[] _assetTypeChartLabels = Array.Empty<string>();
    private double[] _assetTypeChartData = Array.Empty<double>();

    private int? _backupOk;
    private int? _backupWarning;
    private int? _backupFailed;
    private int? _backupDisabled;
    private readonly List<BackupHealthRow> _backupIssues = new();

    // Helper do markupu @T("Key","Fallback")
    private string T(string key, string fallback)
    {
        try
        {
            var s = L[key];
            if (s.ResourceNotFound) return fallback;

            var v = s.Value;
            return string.IsNullOrWhiteSpace(v) ? fallback : v;
        }
        catch
        {
            return fallback;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAllAsync();
        StateHasChanged();
    }

    private async Task OnPrinterDaysChanged(int value)
    {
        _printerDays = value;

        var version = Interlocked.Increment(ref _printersRequestVersion);
        await LoadPrintersAsync(version);

        StateHasChanged();
    }

    private async Task LoadAllAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _ticketsSchemaReady = false;
        _ticketsSchemaDiagnostic = null;

        _ticketsOpened30 = null;
        _ticketsClosed30 = null;
        _ticketsQueue = null;
        _ticketsInProgress = null;
        _ticketsWaiting = null;

        _ticketsOpened30ChangePct = null;
        _ticketsClosed30ChangePct = null;
        _ticketsQueueChangePct = null;
        _ticketsInProgressChangePct = null;
        _ticketsWaitingChangePct = null;

        _topOldestActiveTickets.Clear();
        _topStaleActiveTickets.Clear();
        _topOldestWaitingTickets.Clear();
        _topStaleWaitingTickets.Clear();

        _topExpiringLicenses.Clear();
        _topUnusedLicenses.Clear();

        _printerPagesInRange = null;
        _printerColorPagesInRange = null;
        _printerMonoPagesInRange = null;

        _printerTotalCostInRange = null;
        _printerColorCostInRange = null;
        _printerMonoCostInRange = null;

        _printerPagesChangePct = null;
        _printerColorPagesChangePct = null;
        _printerMonoPagesChangePct = null;
        _printerCostChangePct = null;

        _topPrinters.Clear();

        _devicesTotal = null;
        _assetTypeBreakdown.Clear();
        _assetTypeChartLabels = Array.Empty<string>();
        _assetTypeChartData = Array.Empty<double>();

        _backupOk = null;
        _backupWarning = null;
        _backupFailed = null;
        _backupDisabled = null;
        _backupIssues.Clear();

        try
        {
            var cs = Configuration.GetConnectionString("ITManagerConnection");
            if (string.IsNullOrWhiteSpace(cs))
            {
                _errorMessage = L["MissingConnectionString"];
                return;
            }

            using var conn = new SqlConnection(cs);
            await conn.OpenAsync();

            var (schema, diag) = await ResolveTicketSchemaAsync(conn);
            _ticketsSchemaReady = schema != null;
            _ticketsSchemaDiagnostic = diag;

            if (_ticketsSchemaReady && schema != null)
                await LoadTicketsAsync(conn, schema);

            await LoadLicensesAsync(conn);
            await LoadAssetsAsync(conn);
            await LoadBackupsAsync(conn);

            var version = Interlocked.Increment(ref _printersRequestVersion);
            await LoadPrintersAsync(conn, version);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine("[Dashboard] Error: " + ex);
            _errorMessage = L["DbLoadFailed"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    // =========================================================
    // Tickets schema
    // =========================================================

    private async Task<(TicketSchema? Schema, string? Diagnostic)> ResolveTicketSchemaAsync(SqlConnection conn)
    {
        var hasTickets = await ExistsTableAsync(conn, "dbo", "tickets");
        var hasActions = await ExistsTableAsync(conn, "dbo", "ticket_actions");
        var hasStatuses = await ExistsTableAsync(conn, "dbo", "ticket_statuses");

        if (!hasTickets || !hasActions || !hasStatuses)
        {
            var missing = new List<string>();
            if (!hasTickets) missing.Add("dbo.tickets");
            if (!hasActions) missing.Add("dbo.ticket_actions");
            if (!hasStatuses) missing.Add("dbo.ticket_statuses");

            return (null, "Tickets: Missing required table(s): " + string.Join(", ", missing));
        }

        var required = new List<(string Schema, string Table, string Column)>
        {
            ("dbo", "tickets", "id"),
            ("dbo", "tickets", "ticket_title"),
            ("dbo", "tickets", "ticket_request_date"),
            ("dbo", "tickets", "ticket_priority_value"),
            ("dbo", "tickets", "ticket_status_id"),

            ("dbo", "ticket_actions", "id"),
            ("dbo", "ticket_actions", "ticket_id"),
            ("dbo", "ticket_actions", "created_at"),
            ("dbo", "ticket_actions", "status_to_id"),

            ("dbo", "ticket_statuses", "id"),
            ("dbo", "ticket_statuses", "name")
        };

        var missingCols = new List<string>();
        foreach (var (schema, table, col) in required)
        {
            if (!await ExistsColumnAsync(conn, schema, table, col))
                missingCols.Add($"{schema}.{table}.{col}");
        }

        if (missingCols.Count > 0)
            return (null, "Tickets: Missing column " + string.Join(", ", missingCols));

        var s = new TicketSchema
        {
            TicketTable = "dbo.tickets",
            ActionsTable = "dbo.ticket_actions",
            StatusesTable = "dbo.ticket_statuses",

            TicketIdCol = "id",
            TicketTitleCol = "ticket_title",
            TicketCreatedCol = "ticket_request_date",
            TicketPriorityCol = "ticket_priority_value",
            TicketStatusIdCol = "ticket_status_id",

            ActionIdCol = "id",
            ActionTicketIdCol = "ticket_id",
            ActionDateCol = "created_at",
            ActionStatusToIdCol = "status_to_id",

            StatusIdCol = "id",
            StatusNameCol = "name"
        };

        return (s, null);
    }

    // =========================================================
    // Tickets load + KPI
    // =========================================================

    private async Task LoadTicketsAsync(SqlConnection conn, TicketSchema s)
    {
        var now = DateTime.Now;
        var currFrom = now.AddDays(-TicketTrendDays);
        var currTo = now;

        var prevFrom = now.AddDays(-2 * TicketTrendDays);
        var prevTo = now.AddDays(-TicketTrendDays);

        _ticketsOpened30 = await CountTicketsOpenedAsync(conn, s, currFrom, currTo);
        var prevOpened = await CountTicketsOpenedAsync(conn, s, prevFrom, prevTo);
        _ticketsOpened30ChangePct = CalcChangePct(_ticketsOpened30.GetValueOrDefault(0), prevOpened);

        _ticketsClosed30 = await CountTicketsClosedByLastActionAsync(conn, s, currFrom, currTo);
        var prevClosed = await CountTicketsClosedByLastActionAsync(conn, s, prevFrom, prevTo);
        _ticketsClosed30ChangePct = CalcChangePct(_ticketsClosed30.GetValueOrDefault(0), prevClosed);

        _ticketsQueue = await CountTicketsByCurrentStatusAsync(conn, s, TicketStatusGroups.QueueNames);
        _ticketsInProgress = await CountTicketsByCurrentStatusAsync(conn, s, TicketStatusGroups.InProgressNames);
        _ticketsWaiting = await CountTicketsByCurrentStatusAsync(conn, s, TicketStatusGroups.WaitingNames);

        var currQueueMoves = await CountTicketsMovedToStatusAsync(conn, s, TicketStatusGroups.QueueNames, currFrom, currTo);
        var prevQueueMoves = await CountTicketsMovedToStatusAsync(conn, s, TicketStatusGroups.QueueNames, prevFrom, prevTo);
        _ticketsQueueChangePct = CalcChangePct(currQueueMoves, prevQueueMoves);

        var currInProgMoves = await CountTicketsMovedToStatusAsync(conn, s, TicketStatusGroups.InProgressNames, currFrom, currTo);
        var prevInProgMoves = await CountTicketsMovedToStatusAsync(conn, s, TicketStatusGroups.InProgressNames, prevFrom, prevTo);
        _ticketsInProgressChangePct = CalcChangePct(currInProgMoves, prevInProgMoves);

        var currWaitMoves = await CountTicketsMovedToStatusAsync(conn, s, TicketStatusGroups.WaitingNames, currFrom, currTo);
        var prevWaitMoves = await CountTicketsMovedToStatusAsync(conn, s, TicketStatusGroups.WaitingNames, prevFrom, prevTo);
        _ticketsWaitingChangePct = CalcChangePct(currWaitMoves, prevWaitMoves);

        _topOldestActiveTickets.Clear();
        _topStaleActiveTickets.Clear();
        _topOldestWaitingTickets.Clear();
        _topStaleWaitingTickets.Clear();

        _topOldestActiveTickets.AddRange(await LoadTopOldestByStatusAsync(conn, s, TicketStatusGroups.ActiveNames, 5));
        _topStaleActiveTickets.AddRange(await LoadTopStaleByStatusAsync(conn, s, TicketStatusGroups.ActiveNames, 5));

        _topOldestWaitingTickets.AddRange(await LoadTopOldestByStatusAsync(conn, s, TicketStatusGroups.WaitingNames, 5));
        _topStaleWaitingTickets.AddRange(await LoadTopStaleByStatusAsync(conn, s, TicketStatusGroups.WaitingNames, 5));
    }

    private string BuildLastActionApply(TicketSchema s)
    {
        var orderTail = $"ORDER BY ta.[{s.ActionDateCol}] DESC, ta.[{s.ActionIdCol}] DESC";

        return
            "OUTER APPLY ( " +
            "SELECT TOP 1 " +
            $"ta.[{s.ActionDateCol}] AS last_action_date, " +
            $"ta.[{s.ActionStatusToIdCol}] AS last_status_id " +
            $"FROM {s.ActionsTable} ta " +
            $"WHERE ta.[{s.ActionTicketIdCol}] = t.[{s.TicketIdCol}] " +
            orderTail +
            ") la " +
            $"LEFT JOIN {s.StatusesTable} st ON st.[{s.StatusIdCol}] = la.last_status_id ";
    }

