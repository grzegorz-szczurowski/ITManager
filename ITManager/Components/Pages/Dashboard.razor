@page "/dashboard"

@* File: Components/Pages/Dashboard.razor
   Description: Dashboard: tickety (dbo.tickets + dbo.ticket_actions + dbo.ticket_statuses) + drukarki (dbo.counter_printers) + backup health + assets.
                Localized via IStringLocalizer<Dashboard> (PL/EN resx).
   Version: 1.61
   Notes:
   - Tickets:
     - dbo.tickets: źródło listy ticketów + data utworzenia + aktualny status (ticket_status_id)
     - dbo.ticket_actions: tylko do last_action_date (Top stale)
     - dbo.ticket_statuses: mapowanie id -> name
   - UI: 5 ticket KPI w jednym rzędzie (desktop) + Top 4 po 2 na rząd
   - FIX (1.61): status nie jest wymagany w dbo.ticket_actions (u Ciebie status jest w dbo.tickets)
*@

@using System
@using System.Data
@using System.Data.SqlClient
@using System.Threading
@using System.Threading.Tasks
@using System.Collections.Generic
@using System.Linq
@using MudBlazor
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Authorization

@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Dashboard> L

<style>
    .printer-kpi-card {
        height: 132px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .printer-kpi-subline {
        margin-top: 2px;
        opacity: 0.9;
        min-height: 18px;
    }

    .ticket-kpi-card {
        height: 132px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ticket-kpi-subline {
        margin-top: 2px;
        opacity: 0.9;
        min-height: 18px;
    }

    .ticket-top-card {
        display: flex;
        flex-direction: column;
    }

    .ticket-top-card-body {
        display: flex;
        flex-direction: column;
    }

    .ticket-top-table-wrap {
        overflow: visible;
    }

    .clickable-row {
        cursor: pointer;
    }

    .asset-kpi-card {
        height: 132px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .asset-chart-wrap {
        height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .dashboard-loading-overlay {
        position: relative;
        min-height: 520px;
    }

    .dashboard-loading-content {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }

    /* Tickets KPI: 5 w rzędzie na desktopie */
    .tickets-kpi-grid {
        display: grid;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        gap: 8px;
    }

    @@media (min-width: 600px) {
        .tickets-kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (min-width: 960px) {
        .tickets-kpi-grid {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }
    }
</style>

<MudPaper Class="pa-4" Elevation="0">
    <MudStack Spacing="3">

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="0">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h5">@T("DashboardTitle", "Dashboard")</MudText>

                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Color="Color.Primary"
                                   Disabled="_isLoading"
                                   OnClick="ReloadAsync"
                                   Title="@T("Refresh", "Refresh")"
                                   AriaLabel="@T("Refresh", "Refresh")" />
                </MudStack>

                <MudText Typo="Typo.subtitle2">@T("DashboardSubtitle", "Overview")</MudText>
            </MudStack>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
        }

        <div class="dashboard-loading-overlay">

            <MudOverlay Visible="_isLoading"
                        DarkBackground="true"
                        AutoClose="false"
                        Absolute="true">
                <div class="dashboard-loading-content">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle2">@T("LoadingData", "Loading data")</MudText>
                </div>
            </MudOverlay>

            @if (!_isLoading)
            {
                <MudGrid GutterSize="GutterSize.Small">

                    <MudItem xs="12">
                        <MudText Typo="Typo.h6">@T("Tickets", "Tickets")</MudText>
                    </MudItem>

                    @if (!_ticketsSchemaReady)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                @(!string.IsNullOrWhiteSpace(_ticketsSchemaDiagnostic)
                                                        ? _ticketsSchemaDiagnostic
                                                        : T("TicketsSchemaMissing", "Tickets: missing required tables/columns (dbo.tickets + dbo.ticket_actions + dbo.ticket_statuses)."))
                    </MudAlert>
                </MudItem>
                                }
                    else
                    {
                        <MudItem xs="12">
                            <div class="tickets-kpi-grid">

                                <MudCard Class="pa-4 ticket-kpi-card">
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@T("TicketsOpened30", "Opened (30d)")</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.h3">@Fmt(_ticketsOpened30)</MudText>
                                            @TrendChip(_ticketsOpened30ChangePct, T("TrendTicketsOpened30Tooltip", "Compared to previous 30d"))
                                        </MudStack>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="ticket-kpi-subline">
                                        @T("TicketsOpened30Hint", "Created based on ticket creation date")
                                    </MudText>
                                </MudCard>

                                <MudCard Class="pa-4 ticket-kpi-card">
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@T("TicketsClosed30", "Closed (30d)")</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.h3">@Fmt(_ticketsClosed30)</MudText>
                                            @TrendChip(_ticketsClosed30ChangePct, T("TrendTicketsClosed30Tooltip", "Compared to previous 30d"))
                                        </MudStack>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="ticket-kpi-subline">
                                        @T("TicketsClosed30Hint", "Counted using ticket closing date and current status")
                                    </MudText>
                                </MudCard>

                                <MudCard Class="pa-4 ticket-kpi-card">
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@T("TicketsQueue", "Queue")</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.h3">@Fmt(_ticketsQueue)</MudText>
                                            @TrendChip(_ticketsQueueChangePct, T("TrendTicketsQueueTooltip", "Tickets moved to Queue in last 30d vs previous 30d"))
                                        </MudStack>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="ticket-kpi-subline">
                                        @T("TicketsQueueHint", "New and Assigned")
                                    </MudText>
                                </MudCard>

                                <MudCard Class="pa-4 ticket-kpi-card">
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@T("TicketsInProgress", "In progress")</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.h3">@Fmt(_ticketsInProgress)</MudText>
                                            @TrendChip(_ticketsInProgressChangePct, T("TrendTicketsInProgressTooltip", "Tickets moved to In progress in last 30d vs previous 30d"))
                                        </MudStack>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="ticket-kpi-subline">
                                        @T("TicketsInProgressHint", "Currently being handled")
                                    </MudText>
                                </MudCard>

                                <MudCard Class="pa-4 ticket-kpi-card">
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@T("TicketsWaiting", "Waiting")</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.h3">@Fmt(_ticketsWaiting)</MudText>
                                            @TrendChip(_ticketsWaitingChangePct, T("TrendTicketsWaitingTooltip", "Tickets moved to Waiting in last 30d vs previous 30d"))
                                        </MudStack>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="ticket-kpi-subline">
                                        @T("TicketsWaitingHint", "On hold / waiting")
                                    </MudText>
                                </MudCard>

                            </div>
                        </MudItem>

                        <MudItem xs="12">
                            <MudGrid GutterSize="GutterSize.Small">

                                <MudItem xs="12" md="6">
                                    <MudCard Class="pa-4 ticket-top-card">
                                        <MudText Typo="Typo.subtitle2">@T("TopOldestActiveTicketsTitle", "Top oldest active tickets")</MudText>

                                        <div class="ticket-top-card-body">
                                            @if (_topOldestActiveTickets.Count == 0)
                                            {
                                                <MudText Typo="Typo.caption" Class="mt-2">@T("NoData", "No data")</MudText>
                                            }
                                            else
                                            {
                                                <div class="ticket-top-table-wrap">
                                                    <MudTable Items="_topOldestActiveTickets"
                                                              Dense="true"
                                                              Hover="true"
                                                              Elevation="0"
                                                              Class="mt-2"
                                                              RowClassFunc="@(new Func<TicketListRow, int, string>((row, index) => "clickable-row"))"
                                                              RowClick="OnTicketRowClick">
                                                        <HeaderContent>
                                                            <MudTh>@T("TableId", "ID")</MudTh>
                                                            <MudTh>@T("TableTitle", "Title")</MudTh>
                                                            <MudTh>@T("TableStatus", "Status")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TablePriority", "Priority")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TableAge", "Age")</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd DataLabel="@T("TableId", "ID")">@context.Id</MudTd>
                                                            <MudTd DataLabel="@T("TableTitle", "Title")">@context.Title</MudTd>
                                                            <MudTd DataLabel="@T("TableStatus", "Status")">@context.Status</MudTd>
                                                            <MudTd DataLabel="@T("TablePriority", "Priority")" Style="text-align:right;">
                                                                @PriorityChip(context)
                                                            </MudTd>
                                                            <MudTd DataLabel="@T("TableAge", "Age")" Style="text-align:right;">@context.AgeDays</MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </div>

                                                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               OnClick="@(() => NavigationManager.NavigateTo("/tickets"))">
                                                        @T("ShowMore", "Show more")
                                                    </MudButton>
                                                </MudStack>
                                            }
                                        </div>
                                    </MudCard>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudCard Class="pa-4 ticket-top-card">
                                        <MudText Typo="Typo.subtitle2">@T("TopStaleActiveTicketsTitle", "Top stale active tickets")</MudText>

                                        <div class="ticket-top-card-body">
                                            @if (_topStaleActiveTickets.Count == 0)
                                            {
                                                <MudText Typo="Typo.caption" Class="mt-2">@T("NoData", "No data")</MudText>
                                            }
                                            else
                                            {
                                                <div class="ticket-top-table-wrap">
                                                    <MudTable Items="_topStaleActiveTickets"
                                                              Dense="true"
                                                              Hover="true"
                                                              Elevation="0"
                                                              Class="mt-2"
                                                              RowClassFunc="@(new Func<TicketListRow, int, string>((row, index) => "clickable-row"))"
                                                              RowClick="OnTicketRowClick">
                                                        <HeaderContent>
                                                            <MudTh>@T("TableId", "ID")</MudTh>
                                                            <MudTh>@T("TableTitle", "Title")</MudTh>
                                                            <MudTh>@T("TableStatus", "Status")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TablePriority", "Priority")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TableLastActionAge", "Last action age")</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd DataLabel="@T("TableId", "ID")">@context.Id</MudTd>
                                                            <MudTd DataLabel="@T("TableTitle", "Title")">@context.Title</MudTd>
                                                            <MudTd DataLabel="@T("TableStatus", "Status")">@context.Status</MudTd>
                                                            <MudTd DataLabel="@T("TablePriority", "Priority")" Style="text-align:right;">
                                                                @PriorityChip(context)
                                                            </MudTd>
                                                            <MudTd DataLabel="@T("TableLastActionAge", "Last action age")" Style="text-align:right;">@context.LastActionAgeDays</MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </div>

                                                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               OnClick="@(() => NavigationManager.NavigateTo("/tickets"))">
                                                        @T("ShowMore", "Show more")
                                                    </MudButton>
                                                </MudStack>
                                            }
                                        </div>
                                    </MudCard>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudCard Class="pa-4 ticket-top-card">
                                        <MudText Typo="Typo.subtitle2">@T("TopOldestWaitingTicketsTitle", "Top oldest waiting tickets")</MudText>

                                        <div class="ticket-top-card-body">
                                            @if (_topOldestWaitingTickets.Count == 0)
                                            {
                                                <MudText Typo="Typo.caption" Class="mt-2">@T("NoData", "No data")</MudText>
                                            }
                                            else
                                            {
                                                <div class="ticket-top-table-wrap">
                                                    <MudTable Items="_topOldestWaitingTickets"
                                                              Dense="true"
                                                              Hover="true"
                                                              Elevation="0"
                                                              Class="mt-2"
                                                              RowClassFunc="@(new Func<TicketListRow, int, string>((row, index) => "clickable-row"))"
                                                              RowClick="OnTicketRowClick">
                                                        <HeaderContent>
                                                            <MudTh>@T("TableId", "ID")</MudTh>
                                                            <MudTh>@T("TableTitle", "Title")</MudTh>
                                                            <MudTh>@T("TableStatus", "Status")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TablePriority", "Priority")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TableAge", "Age")</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd DataLabel="@T("TableId", "ID")">@context.Id</MudTd>
                                                            <MudTd DataLabel="@T("TableTitle", "Title")">@context.Title</MudTd>
                                                            <MudTd DataLabel="@T("TableStatus", "Status")">@context.Status</MudTd>
                                                            <MudTd DataLabel="@T("TablePriority", "Priority")" Style="text-align:right;">
                                                                @PriorityChip(context)
                                                            </MudTd>
                                                            <MudTd DataLabel="@T("TableAge", "Age")" Style="text-align:right;">@context.AgeDays</MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </div>

                                                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               OnClick="@(() => NavigationManager.NavigateTo("/tickets"))">
                                                        @T("ShowMore", "Show more")
                                                    </MudButton>
                                                </MudStack>
                                            }
                                        </div>
                                    </MudCard>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudCard Class="pa-4 ticket-top-card">
                                        <MudText Typo="Typo.subtitle2">@T("TopStaleWaitingTicketsTitle", "Top stale waiting tickets")</MudText>

                                        <div class="ticket-top-card-body">
                                            @if (_topStaleWaitingTickets.Count == 0)
                                            {
                                                <MudText Typo="Typo.caption" Class="mt-2">@T("NoData", "No data")</MudText>
                                            }
                                            else
                                            {
                                                <div class="ticket-top-table-wrap">
                                                    <MudTable Items="_topStaleWaitingTickets"
                                                              Dense="true"
                                                              Hover="true"
                                                              Elevation="0"
                                                              Class="mt-2"
                                                              RowClassFunc="@(new Func<TicketListRow, int, string>((row, index) => "clickable-row"))"
                                                              RowClick="OnTicketRowClick">
                                                        <HeaderContent>
                                                            <MudTh>@T("TableId", "ID")</MudTh>
                                                            <MudTh>@T("TableTitle", "Title")</MudTh>
                                                            <MudTh>@T("TableStatus", "Status")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TablePriority", "Priority")</MudTh>
                                                            <MudTh Style="text-align:right;">@T("TableLastActionAge", "Last action age")</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd DataLabel="@T("TableId", "ID")">@context.Id</MudTd>
                                                            <MudTd DataLabel="@T("TableTitle", "Title")">@context.Title</MudTd>
                                                            <MudTd DataLabel="@T("TableStatus", "Status")">@context.Status</MudTd>
                                                            <MudTd DataLabel="@T("TablePriority", "Priority")" Style="text-align:right;">
                                                                @PriorityChip(context)
                                                            </MudTd>
                                                            <MudTd DataLabel="@T("TableLastActionAge", "Last action age")" Style="text-align:right;">@context.LastActionAgeDays</MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </div>

                                                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               OnClick="@(() => NavigationManager.NavigateTo("/tickets"))">
                                                        @T("ShowMore", "Show more")
                                                    </MudButton>
                                                </MudStack>
                                            }
                                        </div>
                                    </MudCard>
                                </MudItem>

                            </MudGrid>
                        </MudItem>
                    }

                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudText Typo="Typo.h6">@T("Licenses", "Licenses")</MudText>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudCard Class="pa-4 ticket-top-card">
                            <MudText Typo="Typo.subtitle2">@T("TopExpiringLicensesTitle", "Top expiring licenses")</MudText>

                            <div class="ticket-top-card-body">
                                @if (_topExpiringLicenses.Count == 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-2">@T("NoData", "No data")</MudText>
                                }
                                else
                                {
                                    <div class="ticket-top-table-wrap">
                                        <MudTable Items="_topExpiringLicenses"
                                                  Dense="true"
                                                  Hover="true"
                                                  Elevation="0"
                                                  Class="mt-2">
                                            <HeaderContent>
                                                <MudTh>@T("TableLicense", "License")</MudTh>
                                                <MudTh>@T("TableType", "Type")</MudTh>
                                                <MudTh>@T("TableProducer", "Producer")</MudTh>
                                                <MudTh>@T("TableUser", "User")</MudTh>
                                                <MudTh Style="text-align:right;">@T("TableDaysLeft", "Days left")</MudTh>
                                                <MudTh>@T("TableStatus", "Status")</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd DataLabel="@T("TableLicense", "License")">@context.LicenseName</MudTd>
                                                <MudTd DataLabel="@T("TableType", "Type")">@context.TypeName</MudTd>
                                                <MudTd DataLabel="@T("TableProducer", "Producer")">@context.ProducerName</MudTd>
                                                <MudTd DataLabel="@T("TableUser", "User")">@context.UserDisplayName</MudTd>
                                                <MudTd DataLabel="@T("TableDaysLeft", "Days left")" Style="text-align:right;">@context.DaysLeftText</MudTd>
                                                <MudTd DataLabel="@T("TableStatus", "Status")">@context.StatusName</MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </div>

                                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => NavigationManager.NavigateTo("/assets/licenses"))">
                                            @T("ShowMore", "Show more")
                                        </MudButton>
                                    </MudStack>
                                }
                            </div>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudCard Class="pa-4 ticket-top-card">
                            <MudText Typo="Typo.subtitle2">@T("TopUnusedLicensesTitle", "Top unused licenses")</MudText>

                            <div class="ticket-top-card-body">
                                @if (_topUnusedLicenses.Count == 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-2">@T("NoData", "No data")</MudText>
                                }
                                else
                                {
                                    <div class="ticket-top-table-wrap">
                                        <MudTable Items="_topUnusedLicenses"
                                                  Dense="true"
                                                  Hover="true"
                                                  Elevation="0"
                                                  Class="mt-2">
                                            <HeaderContent>
                                                <MudTh>@T("TableLicense", "License")</MudTh>
                                                <MudTh>@T("TableType", "Type")</MudTh>
                                                <MudTh>@T("TableProducer", "Producer")</MudTh>
                                                <MudTh>@T("TableInventoryNo", "Inventory no")</MudTh>
                                                <MudTh>@T("TableStatus", "Status")</MudTh>
                                                <MudTh Style="text-align:right;">@T("TableSubscription", "Subscription")</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd DataLabel="@T("TableLicense", "License")">@context.LicenseName</MudTd>
                                                <MudTd DataLabel="@T("TableType", "Type")">@context.TypeName</MudTd>
                                                <MudTd DataLabel="@T("TableProducer", "Producer")">@context.ProducerName</MudTd>
                                                <MudTd DataLabel="@T("TableInventoryNo", "Inventory no")">@context.InventoryNo</MudTd>
                                                <MudTd DataLabel="@T("TableStatus", "Status")">@context.StatusName</MudTd>
                                                <MudTd DataLabel="@T("TableSubscription", "Subscription")" Style="text-align:right;">@context.SubscriptionText</MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </div>

                                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => NavigationManager.NavigateTo("/assets/licenses"))">
                                            @T("ShowMore", "Show more")
                                        </MudButton>
                                    </MudStack>
                                }
                            </div>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudText Typo="Typo.h6">@T("Assets", "Assets")</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="pa-4 asset-kpi-card">
                            <div>
                                <MudText Typo="Typo.subtitle2">@T("Devices", "Devices")</MudText>
