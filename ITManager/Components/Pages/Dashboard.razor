    private async Task LoadBackupsAsync(SqlConnection conn)
    {
        try
        {
            using (var cmd = new SqlCommand(
                "SELECT health_state, COUNT(*) " +
                "FROM dbo.vw_backup_health " +
                "GROUP BY health_state;", conn))
            {
                cmd.CommandTimeout = 10;

                using var r = await cmd.ExecuteReaderAsync();
                var counts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

                while (await r.ReadAsync())
                {
                    var state = r.IsDBNull(0) ? string.Empty : (r.GetString(0) ?? string.Empty);
                    var cnt = r.IsDBNull(1) ? 0 : Convert.ToInt32(r.GetValue(1));
                    if (!string.IsNullOrWhiteSpace(state))
                        counts[state] = cnt;
                }

                _backupOk = counts.TryGetValue("OK", out var ok) ? ok : 0;
                _backupWarning = counts.TryGetValue("Warning", out var warn) ? warn : 0;
                _backupFailed = counts.TryGetValue("Failed", out var failed) ? failed : 0;
                _backupDisabled = counts.TryGetValue("Disabled", out var dis) ? dis : 0;
            }

            _backupIssues.Clear();

            using (var cmd = new SqlCommand(
                "SELECT TOP 10 " +
                "system_id, system_name, backup_frequency_name, last_backup_status_name, last_backup_date, age_minutes, health_state " +
                "FROM dbo.vw_backup_health " +
                "WHERE health_state IN ('Failed','Warning') " +
                "ORDER BY CASE health_state WHEN 'Failed' THEN 0 ELSE 1 END, ISNULL(age_minutes, 999999999) DESC;", conn))
            {
                cmd.CommandTimeout = 10;

                using var r = await cmd.ExecuteReaderAsync();
                while (await r.ReadAsync())
                {
                    var lastBackupDate = r.IsDBNull(4) ? (DateTime?)null : Convert.ToDateTime(r.GetValue(4));
                    var ageMinutes = r.IsDBNull(5) ? (int?)null : Convert.ToInt32(r.GetValue(5));

                    _backupIssues.Add(new BackupHealthRow
                    {
                        SystemId = r.IsDBNull(0) ? 0 : Convert.ToInt32(r.GetValue(0)),
                        SystemName = r.IsDBNull(1) ? string.Empty : (r.GetString(1) ?? string.Empty),
                        FrequencyName = r.IsDBNull(2) ? string.Empty : (r.GetString(2) ?? string.Empty),
                        LastStatusName = r.IsDBNull(3) ? string.Empty : (r.GetString(3) ?? string.Empty),
                        LastBackupDateText = lastBackupDate.HasValue ? lastBackupDate.Value.ToString("yyyy-MM-dd HH:mm") : L["NA"],
                        AgeText = BuildAgeText(ageMinutes),
                        HealthState = r.IsDBNull(6) ? string.Empty : (r.GetString(6) ?? string.Empty)
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine("[Dashboard] Backups query failed: " + ex);

            _backupOk = null;
            _backupWarning = null;
            _backupFailed = null;
            _backupDisabled = null;
            _backupIssues.Clear();
        }
    }

