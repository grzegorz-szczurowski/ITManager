    private RenderFragment BackupStateChip(string? healthState) => builder =>
    {
        var state = healthState ?? string.Empty;
        var (color, label) = GetBackupStateChipView(state);

        builder.OpenComponent<MudChip<string>>(0);
        builder.AddAttribute(1, "Size", Size.Small);
        builder.AddAttribute(2, "Color", color);
        builder.AddAttribute(3, "Variant", Variant.Filled);
        builder.AddAttribute(4, "Label", true);
        builder.AddAttribute(5, "Style", "min-width:84px; justify-content:center;");
        builder.AddAttribute(6, "ChildContent", (RenderFragment)(b => { b.AddContent(0, label); }));
        builder.CloseComponent();
    };

    private (Color color, string label) GetBackupStateChipView(string healthState)
    {
        if (string.Equals(healthState, "OK", StringComparison.OrdinalIgnoreCase))
            return (Color.Success, L["BackupOK"]);

        if (string.Equals(healthState, "Warning", StringComparison.OrdinalIgnoreCase))
            return (Color.Warning, L["BackupWarning"]);

        if (string.Equals(healthState, "Failed", StringComparison.OrdinalIgnoreCase))
            return (Color.Error, L["BackupFailed"]);

        if (string.Equals(healthState, "Disabled", StringComparison.OrdinalIgnoreCase))
            return (Color.Default, L["BackupDisabled"]);

        return (Color.Default, string.IsNullOrWhiteSpace(healthState) ? L["NA"] : healthState);
    }

    private RenderFragment TrendChip(decimal? pct, string label) => builder =>
    {
        var (icon, cssColor, text) = GetTrendView(pct);

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "trend-chip");
        builder.AddAttribute(2, "title", label);

        builder.OpenComponent<MudIcon>(3);
        builder.AddAttribute(4, "Icon", icon);
        builder.AddAttribute(5, "Style", $"font-size:18px; vertical-align:middle; color:{cssColor};");
        builder.CloseComponent();

        builder.OpenComponent<MudText>(6);
        builder.AddAttribute(7, "Typo", Typo.caption);
        builder.AddAttribute(8, "Style", $"display:inline-block; margin-left:4px; color:{cssColor}; font-weight:600;");
        builder.AddContent(9, text);
        builder.CloseComponent();

        builder.CloseElement();
    };

    private (string icon, string cssColor, string text) GetTrendView(decimal? pct)
    {
        if (!pct.HasValue)
            return (Icons.Material.Filled.Remove, "rgba(0,0,0,0.38)", L["NA"]);

        var v = pct.Value;

        if (v > 0.0001m)
            return (Icons.Material.Filled.ArrowOutward, "#f44336", string.Format(L["PercentFormat"], v));

        if (v < -0.0001m)
            return (Icons.Material.Filled.SouthEast, "#4caf50", string.Format(L["PercentFormat"], Math.Abs(v)));

        return (Icons.Material.Filled.Remove, "rgba(0,0,0,0.38)", L["ZeroPercent"]);
    }

