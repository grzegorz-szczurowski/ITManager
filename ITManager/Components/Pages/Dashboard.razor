    private static decimal? CalcChangePct(long current, long previous)
    {
        if (previous == 0)
        {
            if (current == 0) return 0m;
            return null;
        }

        return ((decimal)current - previous) / previous * 100m;
    }

    private static decimal? CalcChangePct(decimal current, decimal previous)
    {
        if (previous == 0m)
        {
            if (current == 0m) return 0m;
            return null;
        }

        return (current - previous) / previous * 100m;
    }

    private static decimal? CalcChangePct(int current, int previous)
    {
        if (previous == 0)
        {
            if (current == 0) return 0m;
            return null;
        }

        return ((decimal)current - previous) / previous * 100m;
    }

    private static void AddStringListParams(SqlCommand cmd, string prefix, IEnumerable<string> values)
    {
        var i = 0;
        foreach (var v in values)
        {
            cmd.Parameters.AddWithValue(prefix + i.ToString(), v);
            i++;
        }
    }

    private static string BuildParamList(string prefix, int count)
    {
        var parts = new List<string>();
        for (var i = 0; i < count; i++)
            parts.Add(prefix + i.ToString());
        return string.Join(", ", parts);
    }

    private static async Task<bool> ExistsTableAsync(SqlConnection conn, string schemaName, string tableName)
    {
        using var cmd = new SqlCommand(
            "SELECT CASE WHEN OBJECT_ID(@fullName, 'U') IS NULL THEN 0 ELSE 1 END;",
            conn);

        cmd.CommandTimeout = 10;
        cmd.Parameters.AddWithValue("@fullName", schemaName + "." + tableName);

        var result = await cmd.ExecuteScalarAsync();
        if (result == null || result == DBNull.Value) return false;
        return Convert.ToInt32(result) == 1;
    }

    private static async Task<bool> ExistsColumnAsync(SqlConnection conn, string schemaName, string tableName, string columnName)
    {
        using var cmd = new SqlCommand(
            "SELECT CASE WHEN EXISTS ( " +
            "SELECT 1 " +
            "FROM sys.columns c " +
            "INNER JOIN sys.objects o ON o.object_id = c.object_id " +
            "INNER JOIN sys.schemas s ON s.schema_id = o.schema_id " +
            "WHERE s.name = @schema AND o.name = @table AND c.name = @column " +
            ") THEN 1 ELSE 0 END;",
            conn);

        cmd.CommandTimeout = 10;
        cmd.Parameters.AddWithValue("@schema", schemaName);
        cmd.Parameters.AddWithValue("@table", tableName);
        cmd.Parameters.AddWithValue("@column", columnName);

        var result = await cmd.ExecuteScalarAsync();
        if (result == null || result == DBNull.Value) return false;
        return Convert.ToInt32(result) == 1;
    }

    private static string BuildAgeText(int? minutes)
    {
        if (!minutes.HasValue) return string.Empty;

        var m = minutes.Value;
        if (m < 60) return m + " min";

        var h = m / 60;
        if (h < 48) return h + " h";

        var d = h / 24;
        return d + " d";
    }

    private string BuildDaysLeftText(DateTime? end)
    {
        if (!end.HasValue) return L["NA"];

        var days = (end.Value.Date - DateTime.Now.Date).Days;

        if (days < 0) return L["Expired"];
        if (days == 0) return L["EndsToday"];
        return string.Format(L["DaysLeftFormat"], days);
    }

    private string BuildSubscriptionText(DateTime? start, DateTime? end)
    {
        if (!start.HasValue && !end.HasValue) return L["NA"];

        var s = start.HasValue ? start.Value.ToString("yyyy-MM-dd") : L["NA"];
        var e = end.HasValue ? end.Value.ToString("yyyy-MM-dd") : L["NA"];

        return s + " - " + e;
    }

