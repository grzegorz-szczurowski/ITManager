@code {
    [Parameter] public int Id { get; set; }

    private const string PermProjectsCreate = "Projects.Create";
    private const string PermProjectsEdit = "Projects.Edit";
    private const string PermTicketsCreate = "Tickets.Create";

    private bool _loading;
    private bool _saving;

    private bool _loadAttempted;

    private bool _isCreateMode;
    private bool _isEditMode;

    private bool _canCreate;
    private bool _canEdit;
    private bool _canCreateTicket;

    private string _loadError = string.Empty;

    private ProjectDetailsDto? _project;
    private ProjectUpsertRequest _model = new();

    private ProjectFormLookupsDto? _lookups;

    private string _ticketsSearch = string.Empty;

    private ProjectBusinessStage _stage = ProjectBusinessStage.Draft;
    private string _stageDisplay = "Draft";
    private bool _requiresLastUpdateNote;

    private bool HasStatuses => _lookups?.Statuses?.Any() == true;
    private bool HasOwners => _lookups?.Owners?.Any() == true;

    private bool HasImpacts => _lookups?.Impacts?.Any() == true;
    private bool HasUrgencies => _lookups?.Urgencies?.Any() == true;
    private bool HasScopes => _lookups?.Scopes?.Any() == true;
    private bool HasDelayCosts => _lookups?.DelayCosts?.Any() == true;
    private bool HasEfforts => _lookups?.Efforts?.Any() == true;

    private IEnumerable<ProjectTicketListItemDto> FilteredTickets
        => (_project?.Tickets ?? Enumerable.Empty<ProjectTicketListItemDto>())
            .Where(x => TicketMatchesSearch(x, _ticketsSearch))
            .ToList();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _loadAttempted = false;
        _loadError = string.Empty;

        try
        {
            await CurrentUserContextService.EnsureInitializedAsync();

            _isCreateMode = Id == 0;

            _canCreate = CurrentUserContextService.Can(PermProjectsCreate);
            _canEdit = CurrentUserContextService.Can(PermProjectsEdit);
            _canCreateTicket = CurrentUserContextService.Can(PermTicketsCreate);

            _isEditMode = false;
            _project = null;
            _ticketsSearch = string.Empty;

            await LoadLookupsAsync();

            if (_isCreateMode)
            {
                _model = CreateDefaultModel();
                RefreshStageState();
                _loadAttempted = true;
                return;
            }

            await LoadAsync();
            RefreshStageState();
            _loadAttempted = true;
        }
        catch (Exception ex)
        {
            _project = null;
            _loadError = ex.Message;
            _loadAttempted = true;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool CanManageProjectTickets()
    {
        if (_saving || _loading)
            return false;

        if (_isCreateMode)
            return false;

        if (_project == null)
            return false;

        return _canEdit;
    }

    private async Task AddNewTicketAsync()
    {
        if (!CanManageProjectTickets())
            return;

        if (!_canCreateTicket)
        {
            Snackbar.Add(L["NoPermissions"], Severity.Error);
            return;
        }

        Snackbar.Add(L["AddTicketNotReadyInfo"], Severity.Info);
        Navigation.NavigateTo($"/tickets/0?projectId={Id}");
        await Task.CompletedTask;
    }

    private async Task OpenLinkTicketsDialogAsync()
    {
        if (!CanManageProjectTickets())
            return;

        var parameters = new DialogParameters
        {
            { nameof(ProjectTicketLinkDialog.ProjectId), Id }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            BackdropClick = false,
            CloseOnEscapeKey = false
        };

        var dialog = DialogService.Show<ProjectTicketLinkDialog>(L["LinkTicketsDialogTitle"], parameters, options);
        var result = await dialog.Result;

        if (result.Canceled)
            return;

        await ReloadProjectAfterTicketsChangeAsync();
    }

    private async Task ReloadProjectAfterTicketsChangeAsync()
    {
        if (_isCreateMode)
            return;

        _loading = true;
        _loadAttempted = false;

        try
        {
            await LoadAsync();
            RefreshStageState();
            _loadAttempted = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            _lookups = await ProjectsService.GetProjectFormLookupsAsync();
            EnsureScoringFallbacksIfMissing(_lookups);
        }
        catch (Exception ex)
        {
            _lookups = BuildFallbackLookups();
            Snackbar.Add(string.Format(L["LookupLoadFailedWarning"], ex.Message), Severity.Warning);
        }
    }

    private async Task LoadAsync()
    {
        try
        {
            _loadError = string.Empty;

            _project = await ProjectsService.GetProjectDetailsAsync(Id);

            if (_project != null)
                _model = MapToUpsertModel(_project);
        }
        catch (Exception ex)
        {
            _project = null;
            _loadError = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private string GetHeaderTitle()
    {
        if (_isCreateMode)
            return L["HeaderNewProject"];

        if (_project == null)
            return L["HeaderProject"];

        var n = (_project.Name ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(n) ? L["HeaderProject"] : n;
    }

    private void GoBack() => Navigation.NavigateTo("/projects");

    private void EnterEditMode()
    {
        if (!_canEdit)
        {
            Snackbar.Add(L["NoPermissions"], Severity.Error);
            return;
        }

        if (_project == null)
            return;

        _model = MapToUpsertModel(_project);
        _isEditMode = true;
        RefreshStageState();
    }

    private void Cancel()
    {
        if (_saving || _loading)
            return;

        GoBack();
    }

    private bool CanSave()
    {
        if (_saving || _loading)
            return false;

        if (_isCreateMode)
            return _canCreate && ValidateClientRules();

        if (_isEditMode)
            return _canEdit && ValidateClientRules();

        return false;
    }

    private bool ValidateClientRules()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
            return false;

        if (_requiresLastUpdateNote && string.IsNullOrWhiteSpace(_model.LastUpdateNote))
            return false;

        return true;
    }

    private async Task SaveAsync()
    {
        if (_saving || _loading)
            return;

        if (!CanSave())
            return;

        try
        {
            _saving = true;

            NormalizeModel(_model);

            if (_isCreateMode)
            {
                var _ = await ProjectsService.CreateProjectAsync(_model);
                Snackbar.Add(L["ProjectCreatedSuccess"], Severity.Success);
                GoBack();
                return;
            }

            _model.Id = Id;
            await ProjectsService.UpdateProjectAsync(_model);

            Snackbar.Add(L["ProjectUpdatedSuccess"], Severity.Success);
            GoBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(L["SaveFailedError"], ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void OnProjectStatusChangedAfter()
        => RefreshStageState();

    private void RefreshStageState()
    {
        var statusName = TryGetStatusNameById(_model.ProjectStatusId);
        _stage = ProjectBusinessStageResolver.Resolve(statusName);
        _stageDisplay = GetStageDisplayName(_stage);

        _requiresLastUpdateNote = _stage == ProjectBusinessStage.Validation || _stage == ProjectBusinessStage.OnHold;

        if (!_requiresLastUpdateNote)
            _model.LastUpdateNote = null;
    }

    private string GetStageDisplayName(ProjectBusinessStage stage) => stage switch
    {
        ProjectBusinessStage.Draft => L["Stage_Draft"],
        ProjectBusinessStage.Planning => L["Stage_Planning"],
        ProjectBusinessStage.Execution => L["Stage_Execution"],
        ProjectBusinessStage.Validation => L["Stage_Validation"],
        ProjectBusinessStage.OnHold => L["Stage_OnHold"],
        ProjectBusinessStage.Done => L["Stage_Done"],
        _ => L["Stage_Unknown"]
    };

    private string? TryGetStatusNameById(int id)
    {
        if (_lookups?.Statuses == null || _lookups.Statuses.Count == 0)
            return _project?.ProjectStatusName;

        var it = _lookups.Statuses.FirstOrDefault(x => x.Id == id);
        return it?.Name ?? _project?.ProjectStatusName;
    }

    private static bool TicketMatchesSearch(ProjectTicketListItemDto t, string search)
    {
        if (t == null)
            return false;

        var s = (search ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(s))
            return true;

        bool has(string? v) => !string.IsNullOrWhiteSpace(v) && v.Contains(s, StringComparison.OrdinalIgnoreCase);

        if (t.TicketId.ToString().Contains(s, StringComparison.OrdinalIgnoreCase))
            return true;

        return has(t.Title)
            || has(t.StatusName)
            || has(t.PriorityName)
            || has(t.AssignedToDisplayName);
    }

    private Task OnTicketsSearchChanged(string value)
    {
        _ticketsSearch = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private string TicketRowClass(ProjectTicketListItemDto row, int index) => "tickets-row-clickable";

    private void OnTicketRowClick(DataGridRowClickEventArgs<ProjectTicketListItemDto> args)
    {
        if (args?.Item == null)
            return;

        var id = args.Item.TicketId;
        if (id <= 0)
            return;

        Navigation.NavigateTo($"/tickets/{id}");
    }

    private static ProjectUpsertRequest CreateDefaultModel()
    {
        return new ProjectUpsertRequest
        {
            Id = null,
            Name = string.Empty,
            Description = null,
            ProjectStatusId = 1,
            ProjectPriorityId = 1,
            OwnerUserId = 0,
            PlannedStartDate = null,
            DeadlineDate = null,
            IsActive = true,

            Impact = 3,
            Urgency = 3,
            Scope = 2,
            CostOfDelay = 2,
            Effort = 2
        };
    }

    private static ProjectUpsertRequest MapToUpsertModel(ProjectDetailsDto dto)
    {
        return new ProjectUpsertRequest
        {
            Id = dto.Id,
            Name = dto.Name ?? string.Empty,
            Description = dto.Description,
            ProjectStatusId = dto.ProjectStatusId,
            ProjectPriorityId = dto.ProjectPriorityId,
            OwnerUserId = dto.OwnerUserId,
            PlannedStartDate = dto.PlannedStartDate,
            DeadlineDate = dto.DeadlineDate,
            IsActive = dto.IsActive,

            Impact = dto.Impact,
            Urgency = dto.Urgency,
            Scope = dto.Scope,
            CostOfDelay = dto.CostOfDelay,
            Effort = dto.Effort,

            LastUpdateNote = dto.LastUpdateNote
        };
    }

    private static void NormalizeModel(ProjectUpsertRequest model)
    {
        model.Name = (model.Name ?? string.Empty).Trim();

        if (model.Description != null)
        {
            model.Description = model.Description.Trim();
            if (model.Description.Length == 0)
                model.Description = null;
        }

        if (model.LastUpdateNote != null)
        {
            model.LastUpdateNote = model.LastUpdateNote.Trim();
            if (model.LastUpdateNote.Length == 0)
                model.LastUpdateNote = null;
        }

        model.Impact = Clamp(model.Impact, 1, 5, 3);
        model.Urgency = Clamp(model.Urgency, 1, 5, 3);
        model.Scope = Clamp(model.Scope, 1, 3, 2);
        model.CostOfDelay = Clamp(model.CostOfDelay, 1, 3, 2);
        model.Effort = Clamp(model.Effort, 1, 3, 2);
    }

    private static int Clamp(int value, int min, int max, int fallback)
    {
        if (value < min) return fallback;
        if (value > max) return fallback;
        return value;
    }

    private string GetScorePreview()
    {
        var score = CalculateScore(_model.Impact, _model.Urgency, _model.Scope, _model.CostOfDelay, _model.Effort);
        return score.ToString();
    }

    private static int CalculateScore(int impact, int urgency, int scope, int costOfDelay, int effort)
    {
        var i = ClampOrFallback(impact, 1, 5, 3);
        var u = ClampOrFallback(urgency, 1, 5, 3);
        var s = ClampOrFallback(scope, 1, 3, 2);
        var d = ClampOrFallback(costOfDelay, 1, 3, 2);
        var e = ClampOrFallback(effort, 1, 3, 2);

        checked
        {
            return (i * u) + s + d - e;
        }
    }

    private static int ClampOrFallback(int value, int min, int max, int fallback)
    {
        if (value < min) return fallback;
        if (value > max) return fallback;
        return value;
    }

    private static string GetScoreToggleClass(LookupItemDto it, string kind)
    {
        var name = (it?.Name ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(name))
            return string.Empty;

        var n = name.ToLowerInvariant();

        if (!string.Equals(kind, "Impact", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(kind, "Urgency", StringComparison.OrdinalIgnoreCase))
            return string.Empty;

        if (n.Contains("critical") || n.Contains("immediate"))
            return "tg-critical";

        if (n.Contains("very high") || n.Contains("asap"))
            return "tg-high";

        if (n.Contains("high"))
            return "tg-high";

        if (n.Contains("medium") || n.Contains("normal"))
            return "tg-medium";

        if (n.Contains("low"))
            return "tg-low";

        return string.Empty;
    }

    private static ProjectFormLookupsDto BuildFallbackLookups()
    {
        var dto = new ProjectFormLookupsDto();
        EnsureScoringFallbacksIfMissing(dto);
        return dto;
    }

    private static void EnsureScoringFallbacksIfMissing(ProjectFormLookupsDto dto)
    {
        if (dto.Impacts == null) dto.Impacts = new();
        if (dto.Urgencies == null) dto.Urgencies = new();
        if (dto.Scopes == null) dto.Scopes = new();
        if (dto.DelayCosts == null) dto.DelayCosts = new();
        if (dto.Efforts == null) dto.Efforts = new();

        if (!dto.Impacts.Any())
        {
            dto.Impacts.AddRange(new[]
            {
                new LookupItemDto { Id = 1, Name = "Low" },
                new LookupItemDto { Id = 2, Name = "Medium" },
                new LookupItemDto { Id = 3, Name = "High" },
                new LookupItemDto { Id = 4, Name = "Very high" },
                new LookupItemDto { Id = 5, Name = "Critical" }
            });
        }

        if (!dto.Urgencies.Any())
        {
            dto.Urgencies.AddRange(new[]
            {
                new LookupItemDto { Id = 1, Name = "Low" },
                new LookupItemDto { Id = 2, Name = "Normal" },
                new LookupItemDto { Id = 3, Name = "High" },
                new LookupItemDto { Id = 4, Name = "ASAP" },
                new LookupItemDto { Id = 5, Name = "Immediate" }
            });
        }

        if (!dto.Scopes.Any())
        {
            dto.Scopes.AddRange(new[]
            {
                new LookupItemDto { Id = 1, Name = "Small" },
                new LookupItemDto { Id = 2, Name = "Medium" },
                new LookupItemDto { Id = 3, Name = "Large" }
            });
        }

        if (!dto.DelayCosts.Any())
        {
            dto.DelayCosts.AddRange(new[]
            {
                new LookupItemDto { Id = 1, Name = "Low" },
                new LookupItemDto { Id = 2, Name = "Medium" },
                new LookupItemDto { Id = 3, Name = "High" }
            });
        }

        if (!dto.Efforts.Any())
        {
            dto.Efforts.AddRange(new[]
            {
                new LookupItemDto { Id = 1, Name = "Small" },
                new LookupItemDto { Id = 2, Name = "Medium" },
                new LookupItemDto { Id = 3, Name = "Large" }
            });
        }
    }

