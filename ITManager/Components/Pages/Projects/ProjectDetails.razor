@page "/projects/{Id:int}"
@rendermode InteractiveServer

@* File: Components/Pages/Projects/ProjectDetails.razor
   Description: Project details + tickets. Create/Edit w tym samym ekranie. UI w stylu TicketEdit.
   Version: 1.45
   Created: 2026-01-25
   Updated:
   - 2026-01-28 - Tickets: dodane przyciski "Dodaj" i "Powiąż" nad listą + modal powiązania ticketów.
   - 2026-01-28 - CHANGE: usunięto wyświetlanie priorytetu projektu; scoring to prosty wynik (classic: (I*U)+S+D-E) pokazany jako liczba.
   - 2026-01-28 - UX: po zapisie wraca do ProjectsIndex; usunięto przycisk Back.
   - 2026-01-28 - FIX: Cancel zawsze wraca do ProjectsIndex.
   - 2026-01-28 - UX: dodano krótkie pytania + przykłady przy polach scoringu i kluczowych toggle, aby ujednolicić wybór.
   - 2026-01-29 - i18n: literals moved to resx (PL/EN) via IStringLocalizer<ProjectDetails>.
   - 2026-01-29 - FIX: Scope toggle read-only: poprawione domknięcia MudTooltip/MudToggleItem (Razor parse errors).
   - 2026-01-29 - FIX: opisy scoringu zawsze odświeżają się po zmianie toggle (ValueChanged + StateHasChanged + @key).
   Notes:
   - Backend: wymagane metody ProjectsService do pobrania ticketów kandydujących i zapisania powiązań.
*@

@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading.Tasks
@using MudBlazor
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Localization
@using ITManager.Models.Projects
@using ITManager.Services.Projects
@using ITManager.Services.Auth

@inject ProjectsService ProjectsService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject CurrentUserContextService CurrentUserContextService
@inject IDialogService DialogService
@inject IStringLocalizer<ProjectDetails> L

<MudPaper Class="pa-4" Elevation="0">

    @if (_isCreateMode && !_canCreate)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            @L["NoCreatePermission"]
        </MudAlert>
    }
    else if (!_isCreateMode && _loadAttempted && _project == null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            @L["ProjectNotFoundOrNoAccess"]
        </MudAlert>
    }
    else
    {
        <div class="project-content-container">

            <MudStack Spacing="2">

                @* HEADER *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">

                    <MudStack Spacing="0" AlignItems="AlignItems.Start">
                        <MudText Typo="Typo.h5">
                            @GetHeaderTitle()
                        </MudText>

                        @if (_isCreateMode)
                        {
                            <MudText Typo="Typo.subtitle2" Style="opacity:0.75;">
                                @L["CreateMode"]
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @L["ProjectsLabel"]
                            </MudText>
                        }
                    </MudStack>

                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">

                        @if (!_isCreateMode && _project != null && _canEdit && !_isEditMode)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       Disabled="@(_saving || _loading)"
                                       OnClick="EnterEditMode">
                                @L["EditButton"]
                            </MudButton>
                        }

                        @if (!_isCreateMode && _project != null)
                        {
                            <MudText Typo="Typo.subtitle1" Style="opacity:0.85; font-weight:600;">
                                #@Id
                            </MudText>
                        }

                    </MudStack>

                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_loadError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                        @_loadError
                    </MudAlert>
                }

                @if (!_isCreateMode && _project == null)
                {
                    <MudText Typo="Typo.body2" Style="opacity:0.75;">
                        @L["Loading"]
                    </MudText>
                }
                else
                {
                    <MudGrid GutterSize="3">

                        @* LEFT *@
                        <MudItem xs="12" md="4">
                            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                                <MudStack Spacing="2">

                                    @* STATUS *@
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@L["StatusTitle"]</MudText>

                                        <MudText Typo="Typo.caption" Class="helper-question">
                                            @L["StatusQuestion"]
                                        </MudText>

                                        <MudText Typo="Typo.caption" Class="helper-example">
                                            @GetStatusExampleLine()
                                        </MudText>

                                        @if (HasStatuses)
                                        {
                                            @if (_isEditMode || _isCreateMode)
                                            {
                                                <MudToggleGroup T="int"
                                                                Exclusive="true"
                                                                @bind-Value="_model.ProjectStatusId"
                                                                @bind-Value:after="OnProjectStatusChangedAfter"
                                                                Disabled="@(_saving || _loading)"
                                                                Class="segmented-toggle segmented-toggle-sm"
                                                                FullWidth="true">
                                                    @foreach (var it in _lookups!.Statuses)
                                                    {
                                                        <MudToggleItem Value="@it.Id">
                                                            <MudTooltip Text="@it.Name">
                                                                <span>@it.Name</span>
                                                            </MudTooltip>
                                                        </MudToggleItem>
                                                    }
                                                </MudToggleGroup>
                                            }
                                            else
                                            {
                                                <MudToggleGroup T="int"
                                                                Exclusive="true"
                                                                Value="@_project!.ProjectStatusId"
                                                                Disabled="true"
                                                                Class="segmented-toggle segmented-toggle-sm"
                                                                FullWidth="true">
                                                    @foreach (var it in _lookups!.Statuses)
                                                    {
                                                        <MudToggleItem Value="@it.Id">
                                                            <MudTooltip Text="@it.Name">
                                                                <span>@it.Name</span>
                                                            </MudTooltip>
                                                        </MudToggleItem>
                                                    }
                                                </MudToggleGroup>
                                            }
                                        }
                                        else
                                        {
                                            @if (_isEditMode || _isCreateMode)
                                            {
                                                <MudNumericField T="int"
                                                                 @bind-Value="_model.ProjectStatusId"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Disabled="@(_saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                            else
                                            {
                                                <MudChip T="string" Label="true" Variant="Variant.Outlined">
                                                    @_project!.ProjectStatusName
                                                </MudChip>
                                            }
                                        }

                                        <MudText Typo="Typo.caption" Style="opacity:0.75;">
                                            @string.Format(L["StageFormat"], _stageDisplay)
                                        </MudText>
                                    </MudStack>

                                    <MudDivider />

                                    @* SCORING *@
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@L["ScoringTitle"]</MudText>

                                        <MudText Typo="Typo.caption" Style="opacity:0.80;">
                                            @L["ScoringGoal"]
                                        </MudText>

                                        <MudChip T="string" Label="true" Variant="Variant.Outlined">
                                            @string.Format(L["ScoreFormat"], GetScorePreview())
                                        </MudChip>

                                        @* Impact *@
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.caption" Style="opacity:0.8;">@L["ImpactTitle"]</MudText>

                                            <MudText Typo="Typo.caption" Class="helper-question">
                                                @L["ImpactQuestion"]
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="helper-example" @key="_model.Impact">
                                                @GetImpactExample()
                                            </MudText>

                                            @if (HasImpacts)
                                            {
                                                @if (_isEditMode || _isCreateMode)
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_model.Impact"
                                                                    ValueChanged="OnImpactChanged"
                                                                    Disabled="@(_saving || _loading)"
                                                                    Class="segmented-toggle"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Impacts)
                                                        {
                                                            var css = GetScoreToggleClass(it, "Impact");
                                                            <MudToggleItem Value="@it.Id" Class="@css">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                                else
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_project!.Impact"
                                                                    Disabled="true"
                                                                    Class="segmented-toggle"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Impacts)
                                                        {
                                                            var css = GetScoreToggleClass(it, "Impact");
                                                            <MudToggleItem Value="@it.Id" Class="@css">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                            }
                                            else
                                            {
                                                <MudNumericField T="int"
                                                                 Label="@L["ImpactNumericLabel"]"
                                                                 @bind-Value="_model.Impact"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Max="5"
                                                                 Disabled="@(!(_isEditMode || _isCreateMode) || _saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                        </MudStack>

                                        @* Urgency *@
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.caption" Style="opacity:0.8;">@L["UrgencyTitle"]</MudText>

                                            <MudText Typo="Typo.caption" Class="helper-question">
                                                @L["UrgencyQuestion"]
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="helper-example" @key="_model.Urgency">
                                                @GetUrgencyExample()
                                            </MudText>

                                            @if (HasUrgencies)
                                            {
                                                @if (_isEditMode || _isCreateMode)
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_model.Urgency"
                                                                    ValueChanged="OnUrgencyChanged"
                                                                    Disabled="@(_saving || _loading)"
                                                                    Class="segmented-toggle"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Urgencies)
                                                        {
                                                            var css = GetScoreToggleClass(it, "Urgency");
                                                            <MudToggleItem Value="@it.Id" Class="@css">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                                else
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_project!.Urgency"
                                                                    Disabled="true"
                                                                    Class="segmented-toggle"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Urgencies)
                                                        {
                                                            var css = GetScoreToggleClass(it, "Urgency");
                                                            <MudToggleItem Value="@it.Id" Class="@css">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                            }
                                            else
                                            {
                                                <MudNumericField T="int"
                                                                 Label="@L["UrgencyNumericLabel"]"
                                                                 @bind-Value="_model.Urgency"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Max="5"
                                                                 Disabled="@(!(_isEditMode || _isCreateMode) || _saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                        </MudStack>

                                        @* Scope *@
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.caption" Style="opacity:0.8;">@L["ScopeTitle"]</MudText>

                                            <MudText Typo="Typo.caption" Class="helper-question">
                                                @L["ScopeQuestion"]
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="helper-example" @key="_model.Scope">
                                                @GetScopeExample()
                                            </MudText>

                                            @if (HasScopes)
                                            {
                                                @if (_isEditMode || _isCreateMode)
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_model.Scope"
                                                                    ValueChanged="OnScopeChanged"
                                                                    Disabled="@(_saving || _loading)"
                                                                    Class="segmented-toggle segmented-toggle-sm"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Scopes)
                                                        {
                                                            <MudToggleItem Value="@it.Id">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                                else
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_project!.Scope"
                                                                    Disabled="true"
                                                                    Class="segmented-toggle segmented-toggle-sm"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Scopes)
                                                        {
                                                            <MudToggleItem Value="@it.Id">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                            }
                                            else
                                            {
                                                <MudNumericField T="int"
                                                                 Label="@L["ScopeNumericLabel"]"
                                                                 @bind-Value="_model.Scope"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Max="3"
                                                                 Disabled="@(!(_isEditMode || _isCreateMode) || _saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                        </MudStack>

                                        @* Delay *@
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.caption" Style="opacity:0.8;">@L["DelayTitle"]</MudText>

                                            <MudText Typo="Typo.caption" Class="helper-question">
                                                @L["DelayQuestion"]
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="helper-example" @key="_model.CostOfDelay">
                                                @GetDelayExample()
                                            </MudText>

                                            @if (HasDelayCosts)
                                            {
                                                @if (_isEditMode || _isCreateMode)
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_model.CostOfDelay"
                                                                    ValueChanged="OnDelayChanged"
                                                                    Disabled="@(_saving || _loading)"
                                                                    Class="segmented-toggle segmented-toggle-sm"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.DelayCosts)
                                                        {
                                                            <MudToggleItem Value="@it.Id">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                                else
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_project!.CostOfDelay"
                                                                    Disabled="true"
                                                                    Class="segmented-toggle segmented-toggle-sm"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.DelayCosts)
                                                        {
                                                            <MudToggleItem Value="@it.Id">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                            }
                                            else
                                            {
                                                <MudNumericField T="int"
                                                                 Label="@L["DelayNumericLabel"]"
                                                                 @bind-Value="_model.CostOfDelay"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Max="3"
                                                                 Disabled="@(!(_isEditMode || _isCreateMode) || _saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                        </MudStack>

                                        @* Effort *@
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.caption" Style="opacity:0.8;">@L["EffortTitle"]</MudText>

                                            <MudText Typo="Typo.caption" Class="helper-question">
                                                @L["EffortQuestion"]
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="helper-example" @key="_model.Effort">
                                                @GetEffortExample()
                                            </MudText>

                                            @if (HasEfforts)
                                            {
                                                @if (_isEditMode || _isCreateMode)
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_model.Effort"
                                                                    ValueChanged="OnEffortChanged"
                                                                    Disabled="@(_saving || _loading)"
                                                                    Class="segmented-toggle segmented-toggle-sm"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Efforts)
                                                        {
                                                            <MudToggleItem Value="@it.Id">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                                else
                                                {
                                                    <MudToggleGroup T="int"
                                                                    Exclusive="true"
                                                                    Value="@_project!.Effort"
                                                                    Disabled="true"
                                                                    Class="segmented-toggle segmented-toggle-sm"
                                                                    FullWidth="true">
                                                        @foreach (var it in _lookups!.Efforts)
                                                        {
                                                            <MudToggleItem Value="@it.Id">
                                                                <MudTooltip Text="@it.Name">
                                                                    <span>@it.Name</span>
                                                                </MudTooltip>
                                                            </MudToggleItem>
                                                        }
                                                    </MudToggleGroup>
                                                }
                                            }
                                            else
                                            {
                                                <MudNumericField T="int"
                                                                 Label="@L["EffortNumericLabel"]"
                                                                 @bind-Value="_model.Effort"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Max="3"
                                                                 Disabled="@(!(_isEditMode || _isCreateMode) || _saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                        </MudStack>
                                    </MudStack>

                                    <MudDivider />

                                    @* OWNER *@
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@L["BusinessOwnerTitle"]</MudText>

                                        <MudText Typo="Typo.caption" Class="helper-question">
                                            @L["OwnerQuestion"]
                                        </MudText>

                                        <MudText Typo="Typo.caption" Class="helper-example">
                                            @L["OwnerExample"]
                                        </MudText>

                                        @if (_isEditMode || _isCreateMode)
                                        {
                                            @if (HasOwners)
                                            {
                                                <MudSelect T="int"
                                                           Label="@L["OwnerLabel"]"
                                                           @bind-Value="_model.OwnerUserId"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           Disabled="@(_saving || _loading)"
                                                           FullWidth="true">
                                                    @foreach (var it in _lookups!.Owners)
                                                    {
                                                        <MudSelectItem T="int" Value="@it.Id">@it.Name</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                                <MudNumericField T="int"
                                                                 @bind-Value="_model.OwnerUserId"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="1"
                                                                 Disabled="@(_saving || _loading)"
                                                                 FullWidth="true" />
                                            }
                                        }
                                        else
                                        {
                                            <MudChip T="string" Label="true" Variant="Variant.Outlined">
                                                @_project!.OwnerDisplayName
                                            </MudChip>
                                        }
                                    </MudStack>

                                    <MudDivider />

                                    @* Dates *@
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@L["DatesTitle"]</MudText>

                                        <MudText Typo="Typo.caption" Class="helper-question">
                                            @L["DatesQuestion"]
                                        </MudText>

                                        <MudText Typo="Typo.caption" Class="helper-example">
                                            @L["DatesExample"]
                                        </MudText>

                                        @if (_isEditMode || _isCreateMode)
                                        {
                                            <MudDatePicker @bind-Date="_model.PlannedStartDate"
                                                           Label="@L["PlannedStartLabel"]"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Disabled="@(_saving || _loading)" />

                                            <MudDatePicker @bind-Date="_model.DeadlineDate"
                                                           Label="@L["DeadlineLabel"]"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Disabled="@(_saving || _loading)" />
                                        }
                                        else
                                        {
                                            <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap;">
                                                @if (_project!.PlannedStartDate.HasValue)
                                                {
                                                    <MudChip T="string" Label="true" Variant="Variant.Outlined">
                                                        @string.Format(L["StartDateFormat"], _project.PlannedStartDate.Value.ToString("yyyy-MM-dd"))
                                                    </MudChip>
                                                }
                                                @if (_project.DeadlineDate.HasValue)
                                                {
                                                    <MudChip T="string" Label="true" Variant="Variant.Outlined">
                                                        @string.Format(L["DeadlineDateFormat"], _project.DeadlineDate.Value.ToString("yyyy-MM-dd"))
                                                    </MudChip>
                                                }
                                            </MudStack>
                                        }
                                    </MudStack>

                                </MudStack>
                            </MudPaper>
                        </MudItem>

                        @* RIGHT *@
                        <MudItem xs="12" md="8">
                            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                                <MudStack Spacing="2">

                                    <MudTextField T="string"
                                                  Label="@L["NameLabel"]"
                                                  @bind-Value="_model.Name"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true"
                                                  Dense="true"
                                                  Disabled="@(!(_isCreateMode || _isEditMode) || _saving || _loading)"
                                                  Required="true" />

                                    <MudTextField T="string"
                                                  Label="@L["DescriptionLabel"]"
                                                  @bind-Value="_model.Description"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true"
                                                  Dense="true"
                                                  Lines="5"
                                                  Disabled="@(!(_isCreateMode || _isEditMode) || _saving || _loading)" />

                                    @* LastUpdateNote *@
                                    @if ((_isCreateMode || _isEditMode) && _requiresLastUpdateNote)
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["LastUpdateNoteLabel"]"
                                                      @bind-Value="_model.LastUpdateNote"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true"
                                                      Dense="true"
                                                      Lines="3"
                                                      Required="true"
                                                      Disabled="@(_saving || _loading)" />

                                        <MudText Typo="Typo.caption" Style="opacity:0.75;">
                                            @L["LastUpdateNoteRequiredHint"]
                                        </MudText>
                                    }

                                    <MudDivider />

                                    @* Tickets *@
                                    <MudStack Spacing="2">

                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.subtitle2">@L["TicketsTitle"]</MudText>

                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                <MudButton Variant="Variant.Filled"
                                                           Color="Color.Primary"
                                                           StartIcon="@Icons.Material.Filled.Add"
                                                           Disabled="@(!CanManageProjectTickets())"
                                                           OnClick="AddNewTicketAsync">
                                                    @L["AddButton"]
                                                </MudButton>

                                                <MudButton Variant="Variant.Outlined"
                                                           Color="Color.Primary"
                                                           StartIcon="@Icons.Material.Filled.Link"
                                                           Disabled="@(!CanManageProjectTickets())"
                                                           OnClick="OpenLinkTicketsDialogAsync">
                                                    @L["LinkButton"]
                                                </MudButton>

                                                <MudTextField T="string"
                                                              Value="@_ticketsSearch"
                                                              ValueChanged="OnTicketsSearchChanged"
                                                              ValueChangedDebounceInterval="300"
                                                              Adornment="Adornment.Start"
                                                              AdornmentIcon="@Icons.Material.Filled.Search"
                                                              Placeholder="@L["SearchTicketsPlaceholder"]"
                                                              Immediate="true"
                                                              Dense="true"
                                                              Disabled="@(_saving || _loading)"
                                                              Class="tickets-search" />
                                            </MudStack>
                                        </MudStack>

                                        <MudDataGrid T="ProjectTicketListItemDto"
                                                     Items="@FilteredTickets"
                                                     Dense="true"
                                                     Hover="true"
                                                     Elevation="0"
                                                     Outlined="true"
                                                     Bordered="true"
                                                     Filterable="false"
                                                     SortMode="SortMode.Multiple"
                                                     RowClick="OnTicketRowClick"
                                                     RowClassFunc="TicketRowClass"
                                                     Height="calc(100vh - 520px)">

                                            <Columns>
                                                <PropertyColumn Property="x => x.TicketId"
                                                                Title="@L["TicketsColId"]"
                                                                Sortable="true"
                                                                CellClass="tickets-col-id" />

                                                <PropertyColumn Property="x => x.Title"
                                                                Title="@L["TicketsColTitle"]"
                                                                Sortable="true"
                                                                CellClass="tickets-col-title" />

                                                <PropertyColumn Property="x => x.StatusName"
                                                                Title="@L["TicketsColStatus"]"
                                                                Sortable="true"
                                                                CellClass="tickets-col-status" />

                                                <PropertyColumn Property="x => x.PriorityName"
                                                                Title="@L["TicketsColPriority"]"
                                                                Sortable="true"
                                                                CellClass="tickets-col-priority" />

                                                <PropertyColumn Property="x => x.AssignedToDisplayName"
                                                                Title="@L["TicketsColAssigned"]"
                                                                Sortable="true"
                                                                CellClass="tickets-col-assigned" />

                                                <PropertyColumn Property="x => x.UpdatedAtUtc"
                                                                Title="@L["TicketsColUpdated"]"
                                                                Sortable="true"
                                                                CellClass="tickets-col-updated" />
                                            </Columns>

                                            <PagerContent>
                                                <MudDataGridPager T="ProjectTicketListItemDto" />
                                            </PagerContent>

                                            <NoRecordsContent>
                                                <MudText Typo="Typo.body2" Class="px-2 py-2">
                                                    @L["NoTickets"]
                                                </MudText>
                                            </NoRecordsContent>

                                        </MudDataGrid>

                                    </MudStack>

                                </MudStack>
                            </MudPaper>
                        </MudItem>

                    </MudGrid>

                    @* FOOTER ACTIONS *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-2">

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Class="ml-2"
                                   Disabled="@(!CanSave())"
                                   OnClick="SaveAsync">
                            @L["SaveButton"]
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   Disabled="@(_saving || _loading)"
                                   OnClick="Cancel">
                            @L["CancelButton"]
                        </MudButton>

                    </MudStack>
                }

            </MudStack>

            <MudOverlay Visible="@(_loading || _saving)"
                        DarkBackground="true"
                        AutoClose="false"
                        Absolute="true"
                        Class="project-overlay">
                <MudPaper Class="pa-6 project-overlay-card">
                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">
                            @(_saving? L["Saving"] : L["Loading"])
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudOverlay>

        </div>
    }

</MudPaper>

