    private static string GetLookupName(List<LookupItemDto>? items, int id)
    {
        if (items == null || items.Count == 0)
            return string.Empty;

        var it = items.FirstOrDefault(x => x.Id == id);
        return (it?.Name ?? string.Empty).Trim();
    }
