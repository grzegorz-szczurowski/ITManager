    private string GetStatusExampleLine()
    {
        return _stage switch
        {
            ProjectBusinessStage.Draft => L["StatusExample_Draft"],
            ProjectBusinessStage.Planning => L["StatusExample_Planning"],
            ProjectBusinessStage.Execution => L["StatusExample_Execution"],
            ProjectBusinessStage.Validation => L["StatusExample_Validation"],
            ProjectBusinessStage.OnHold => L["StatusExample_OnHold"],
            ProjectBusinessStage.Done => L["StatusExample_Done"],
            _ => L["StatusExample_Default"]
        };
    }

    private string GetImpactExample()
    {
        var name = GetLookupName(_lookups?.Impacts, _model.Impact);
        if (string.IsNullOrWhiteSpace(name))
            return L["ImpactExample_Default"];

        var n = name.ToLowerInvariant();

        if (n.Contains("critical"))
            return L["ImpactExample_Critical"];

        if (n.Contains("very") && n.Contains("high"))
            return L["ImpactExample_VeryHigh"];

        if (n.Contains("high"))
            return L["ImpactExample_High"];

        if (n.Contains("medium") || n.Contains("normal"))
            return L["ImpactExample_Medium"];

        if (n.Contains("low"))
            return L["ImpactExample_Low"];

        return L["ImpactExample_Fallback"];
    }

    private string GetUrgencyExample()
    {
        var name = GetLookupName(_lookups?.Urgencies, _model.Urgency);
        if (string.IsNullOrWhiteSpace(name))
            return L["UrgencyExample_Default"];

        var n = name.ToLowerInvariant();

        if (n.Contains("immediate") || n.Contains("critical"))
            return L["UrgencyExample_Immediate"];

        if (n.Contains("asap"))
            return L["UrgencyExample_ASAP"];

        if (n.Contains("high"))
            return L["UrgencyExample_High"];

        if (n.Contains("normal") || n.Contains("medium"))
            return L["UrgencyExample_Normal"];

        if (n.Contains("low"))
            return L["UrgencyExample_Low"];

        return L["UrgencyExample_Fallback"];
    }

