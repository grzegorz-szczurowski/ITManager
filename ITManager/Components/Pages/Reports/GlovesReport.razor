@namespace ITManager.Components.Pages.Reports
@page "/reports/gloves"
@rendermode InteractiveServer

@attribute [Authorize(Policy = "Perm:Reports.View")]

@* File: Components/Pages/Reports/GlovesReport.razor
   Description: Raport pobrań rękawic (TEMREX) - widok managerski.
                Cele:
                - Kto i ile zużywa (osoba, dział)
                - Jaki typ rękawic (bez rozmiarów)
                - Konfigurowalne filtry, ale czytelne
                - Porównanie okresów: pokazuj "co się zmieniło" wprost
                - Drill-down: klik w Department ustawia filtr bez przeładowania strony
   Version: 1.10
   Created: 2026-02-11
   Updated: 2026-02-12
   Change log:
     - 1.03 (2026-02-12) Trend chart na pełną szerokość.
     - 1.10 (2026-02-12) MANAGER VIEW: ranking działów + ByItemType bez rozmiarów + filtry panel + compare deltas + drill-down Department.
*@

@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading
@using System.Threading.Tasks
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Logging
@using ITManager.Models.Reports
@using ITManager.Services.Auth
@using ITManager.Services.Reports

@implements IAsyncDisposable

@inject GlovesReportService GlovesReportService
@inject ISnackbar Snackbar
@inject CurrentUserContextService CurrentUserContextService
@inject IStringLocalizer<GlovesReport> L
@inject TimeZoneService TimeZoneService
@inject ILogger<GlovesReport> Logger

<MudPaper Class="pa-4" Elevation="0">
    <MudStack Spacing="2">

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5">@L["Title"]</MudText>
                <MudText Typo="Typo.body2" Color="Color.Primary">@L["Subtitle"]</MudText>
            </MudStack>

            <MudTooltip Text="@L["Refresh"]">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               Size="Size.Medium"
                               Variant="Variant.Text"
                               Class="ml-1"
                               OnClick="ReloadAsync"
                               Disabled="@(_loading || !_canView)" />
            </MudTooltip>
        </MudStack>

        @if (!_ready)
        {
            <MudProgressCircular Size="Size.Large" Class="mx-auto" />
        }
        else if (!_canView)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                @L["NoAccess", "Reports.View"] <b>Reports.View</b>
            </MudAlert>
        }
        else
        {
            <div class="gloves-content-container">

                @* Filtry: czytelne, zwijane, z presetami *@
                <MudExpansionPanels Class="mt-1" Elevation="0" MultiExpansion="false">
                    <MudExpansionPanel Text="@L["FiltersPanelTitle"]" Expanded="false">
                        <MudPaper Class="pa-3" Outlined="true">
                            <MudStack Spacing="2">
                                <MudGrid Spacing="2">

                                    <MudItem xs="12" md="12">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["FiltersSummary", GetDateRangeLabel(), GetDepartmentLabel(), GetItemsLabel(), GetMachinesLabel()]</MudText>
                                        </MudStack>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudDatePicker Label="@L["From"]"
                                                       Date="_dateFrom"
                                                       DateChanged="OnDateFromChanged"
                                                       DateFormat="yyyy-MM-dd"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Disabled="@_loading" />

                                        <MudSlider T="double"
                                                   Min="0"
                                                   Max="@_sliderMaxDays"
                                                   Step="1"
                                                   Value="_sliderFromDays"
                                                   ValueChanged="OnSliderFromChanged"
                                                   Immediate="true"
                                                   Disabled="@_loading" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudDatePicker Label="@L["To"]"
                                                       Date="_dateTo"
                                                       DateChanged="OnDateToChanged"
                                                       DateFormat="yyyy-MM-dd"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Disabled="@_loading" />

                                        <MudSlider T="double"
                                                   Min="0"
                                                   Max="@_sliderMaxDays"
                                                   Step="1"
                                                   Value="_sliderToDays"
                                                   ValueChanged="OnSliderToChanged"
                                                   Immediate="true"
                                                   Disabled="@_loading" />
                                    </MudItem>

                                    <MudItem xs="12" md="12">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Presets"]</MudText>

                                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@_loading" OnClick="@(async () => await ApplyPresetDaysAsync(30))">@L["Preset_30d"]</MudButton>
                                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@_loading" OnClick="@(async () => await ApplyPresetDaysAsync(90))">@L["Preset_90d"]</MudButton>
                                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@_loading" OnClick="@(async () => await ApplyPresetDaysAsync(180))">@L["Preset_180d"]</MudButton>
                                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@_loading" OnClick="@(async () => await ApplyPresetDaysAsync(365))">@L["Preset_365d"]</MudButton>

                                            <MudSpacer />

                                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Disabled="@_loading" OnClick="ResetFiltersAsync">
                                                <MudIcon Icon="@Icons.Material.Filled.RestartAlt" Class="me-1" />
                                                @L["ResetFilters"]
                                            </MudButton>
                                        </MudStack>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete T="GlovesDepartmentOption"
                                                         Label="@L["Department"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Dense="true"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         SearchFunc="SearchDepartmentsAsync"
                                                         ToStringFunc="@(x => x is null ? "" : x.Department)"
                                                         Value="null"
                                                         ValueChanged="OnDepartmentPicked"
                                                         Disabled="@(_loading || _departments.Count == 0)"
                                                         Clearable="true" />

                                        <MudStack Spacing="1" Class="mt-1">
                                            @if (string.IsNullOrWhiteSpace(_selectedDepartment))
                                            {
                                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                                    @L["AllDepartments"]
                                                </MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string"
                                                         Variant="Variant.Outlined"
                                                         Color="Color.Primary"
                                                         Size="Size.Small"
                                                         Closeable="true"
                                                         OnClose="ClearDepartmentAsync">
                                                    @L["ActiveDepartment", _selectedDepartment]
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudSelect T="GlovesTrendGranularity"
                                                   Label="@L["TrendGranularity"]"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Value="_trendGranularity"
                                                   ValueChanged="OnTrendGranularityChanged"
                                                   Disabled="@_loading">
                                            <MudSelectItem Value="GlovesTrendGranularity.Week">@L["Trend_Week"]</MudSelectItem>
                                            <MudSelectItem Value="GlovesTrendGranularity.Month">@L["Trend_Month"]</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudCheckBox T="bool"
                                                     Value="_compare"
                                                     ValueChanged="OnCompareValueChanged"
                                                     Label="@L["CompareLabel"]"
                                                     Disabled="@_loading" />

                                        @if (_compare)
                                        {
                                            var p = GetComparePeriods();
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @L["ComparePeriods", p.CurrentFrom.ToString("yyyy-MM-dd"), p.CurrentTo.ToString("yyyy-MM-dd"), p.PrevFrom.ToString("yyyy-MM-dd"), p.PrevTo.ToString("yyyy-MM-dd")]
                                            </MudText>
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete T="GlovesItemOption"
                                                         Label="@L["GlovesTypes"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Dense="true"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         SearchFunc="SearchItemsAsync"
                                                         ToStringFunc="@(x => x is null ? "" : $"{x.ItemNumber}  {x.ItemDescr}")"
                                                         Value="null"
                                                         ValueChanged="OnItemPicked"
                                                         Disabled="@(_loading || _items.Count == 0)"
                                                         Clearable="true" />

                                        <MudStack Spacing="1" Class="mt-1">
                                            @if (_selectedItemNumbers.Count == 0)
                                            {
                                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                                    @L["AllItems"]
                                                </MudChip>
                                            }
                                            else
                                            {
                                                foreach (var it in _selectedItemNumbers.OrderBy(x => x, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <MudChip T="string"
                                                             Variant="Variant.Outlined"
                                                             Color="Color.Primary"
                                                             Size="Size.Small"
                                                             OnClose="@(async () => await RemoveItemAsync(it))"
                                                             Closeable="true">
                                                        @it
                                                    </MudChip>
                                                }
                                            }
                                        </MudStack>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete T="GlovesVmOption"
                                                         Label="@L["VendingMachines"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Dense="true"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         SearchFunc="SearchVmsAsync"
                                                         ToStringFunc="@(x => x is null ? "" : $"{x.VmId}  {x.VmDescr}")"
                                                         Value="null"
                                                         ValueChanged="OnVmPicked"
                                                         Disabled="@(_loading || _vms.Count == 0)"
                                                         Clearable="true" />

                                        <MudStack Spacing="1" Class="mt-1">
                                            @if (_selectedVmIds.Count == 0)
                                            {
                                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                                    @L["AllMachines"]
                                                </MudChip>
                                            }
                                            else
                                            {
                                                foreach (var id in _selectedVmIds.OrderBy(x => x))
                                                {
                                                    <MudChip T="string"
                                                             Variant="Variant.Outlined"
                                                             Color="Color.Primary"
                                                             Size="Size.Small"
                                                             OnClose="@(async () => await RemoveVmAsync(id))"
                                                             Closeable="true">
                                                        @id
                                                    </MudChip>
                                                }
                                            }
                                        </MudStack>
                                    </MudItem>

                                </MudGrid>
                            </MudStack>
                        </MudPaper>
                    </MudExpansionPanel>
                </MudExpansionPanels>

                @if (_loading && _result is null)
                {
                    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="pa-4">
                        <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Loading"]</MudText>
                    </MudStack>
                }
                else if (_result is null)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                        @L["NoDataForFilters"]
                    </MudAlert>
                }
                else
                {
                    var k = _result.Kpis;

                    @* Sekcja 1: KPI *@
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" md="3">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Direction="Row" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                    <MudText Typo="Typo.subtitle2">@L["Kpi_TotalQty"]</MudText>
                                    @if (_compare)
                                    {
                                        var ch = GetChangeChip(k.TotalQty, k.PrevTotalQty);
                                        <MudChip T="string" Variant="Variant.Outlined" Color="@ch.Color" Size="Size.Small">
                                            <MudIcon Icon="@ch.Icon" Size="Size.Small" Class="me-1" />
                                            @ch.Label
                                        </MudChip>
                                    }
                                </MudStack>
                                <MudText Typo="Typo.h4">@k.TotalQty</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Kpi_AvgPerDay", k.AvgQtyPerDay]</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Direction="Row" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                    <MudText Typo="Typo.subtitle2">@L["Kpi_Transactions"]</MudText>
                                    @if (_compare)
                                    {
                                        var ch = GetChangeChip(k.TransactionsCount, k.PrevTransactionsCount);
                                        <MudChip T="string" Variant="Variant.Outlined" Color="@ch.Color" Size="Size.Small">
                                            <MudIcon Icon="@ch.Icon" Size="Size.Small" Class="me-1" />
                                            @ch.Label
                                        </MudChip>
                                    }
                                </MudStack>
                                <MudText Typo="Typo.h4">@k.TransactionsCount</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Direction="Row" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                    <MudText Typo="Typo.subtitle2">@L["Kpi_UniqueUsers"]</MudText>
                                    @if (_compare)
                                    {
                                        var ch = GetChangeChip(k.UniqueUsersCount, k.PrevUniqueUsersCount);
                                        <MudChip T="string" Variant="Variant.Outlined" Color="@ch.Color" Size="Size.Small">
                                            <MudIcon Icon="@ch.Icon" Size="Size.Small" Class="me-1" />
                                            @ch.Label
                                        </MudChip>
                                    }
                                </MudStack>
                                <MudText Typo="Typo.h4">@k.UniqueUsersCount</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">@L["Kpi_TopDepartment"]</MudText>
                                <MudText Typo="Typo.h6">@GetTopDepartmentLabel()</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@GetTopDepartmentDetails()</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @* Porównanie: "co się zmieniło" wprost *@
                    @if (_compare)
                    {
                        <MudPaper Class="pa-3 mt-2" Outlined="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">@L["CompareChangesTitle"]</MudText>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="3">
                                        <MudText Typo="Typo.body2">@L["Compare_TotalQty"]</MudText>
                                        <MudText Typo="Typo.h6">@GetChangeText(k.TotalQty, k.PrevTotalQty)</MudText>
                                    </MudItem>

                                    <MudItem xs="12" md="3">
                                        <MudText Typo="Typo.body2">@L["Compare_AvgPerDay"]</MudText>
                                        <MudText Typo="Typo.h6">@GetChangeText(k.AvgQtyPerDay, k.PrevAvgQtyPerDay)</MudText>
                                    </MudItem>

                                    <MudItem xs="12" md="3">
                                        <MudText Typo="Typo.body2">@L["Compare_Transactions"]</MudText>
                                        <MudText Typo="Typo.h6">@GetChangeText(k.TransactionsCount, k.PrevTransactionsCount)</MudText>
                                    </MudItem>

                                    <MudItem xs="12" md="3">
                                        <MudText Typo="Typo.body2">@L["Compare_UniqueUsers"]</MudText>
                                        <MudText Typo="Typo.h6">@GetChangeText(k.UniqueUsersCount, k.PrevUniqueUsersCount)</MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudStack>
                        </MudPaper>
                    }

                    @* Sekcja 2: Trend full width *@
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" md="12">
                            <MudPaper Class="pa-3 gloves-trend" Outlined="true">
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.subtitle2">@L["TrendTitle"]</MudText>
                                        @if (!string.IsNullOrWhiteSpace(_selectedDepartment))
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["DrillDownHint", _selectedDepartment]</MudText>
                                        }
                                    </MudStack>

                                    @if (_result.Trend.Count == 0)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@L["NoTrend"]</MudAlert>
                                    }
                                    else
                                    {
                                        <MudChart ChartType="ChartType.Line"
                                                  XAxisLabels="TrendLabels"
                                                  ChartSeries="TrendSeries"
                                                  Width="100%"
                                                  Height="240px"
                                                  Class="w-100" />
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @* Sekcja 3: dwa bloki obok siebie (manager view) *@
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2">@L["TopDepartmentsTitle"]</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["TopDepartmentsHint"]</MudText>

                                    <MudTable T="GlovesByDepartmentRow"
                                              Items="_result.ByDepartment"
                                              Dense="true"
                                              Hover="true"
                                              Bordered="true"
                                              Striped="true"
                                              Class="gloves-table gloves-clickable"
                                              OnRowClick="@(async (TableRowClickEventArgs<GlovesByDepartmentRow> args) => await OnDepartmentRowClickedAsync(args))">
                                        <HeaderContent>
                                            <MudTh>@L["Col_Department"]</MudTh>
                                            <MudTh class="text-right">@L["Col_Qty"]</MudTh>
                                            <MudTh class="text-right">@L["Col_Transactions"]</MudTh>
                                            <MudTh class="text-right">@L["Col_UniqueUsers"]</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>
                                                <MudText Typo="Typo.body2" Style="font-weight:700;">@context.Department</MudText>
                                            </MudTd>
                                            <MudTd class="text-right">@context.Qty</MudTd>
                                            <MudTd class="text-right">@context.Transactions</MudTd>
                                            <MudTd class="text-right">@context.UniqueUsers</MudTd>
                                        </RowTemplate>
                                    </MudTable>

                                </MudStack>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">@L["TopUsersTitle"]</MudText>

                                <MudTable Items="_result.ByUser"
                                          Dense="true"
                                          Hover="true"
                                          Bordered="true"
                                          Striped="true"
                                          Class="gloves-table">
                                    <HeaderContent>
                                        <MudTh>@L["Col_UserName"]</MudTh>
                                        <MudTh>@L["Col_Department"]</MudTh>
                                        <MudTh class="text-right">@L["Col_Qty"]</MudTh>
                                        <MudTh class="text-right">@L["Col_AvgPerDay"]</MudTh>
                                        <MudTh class="text-right">@L["Col_Transactions"]</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>
                                            <MudText Typo="Typo.body2" Style="font-weight:700;">@context.UserName</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.CardNumber</MudText>
                                        </MudTd>
                                        <MudTd>@context.Department</MudTd>
                                        <MudTd class="text-right">@context.Qty</MudTd>
                                        <MudTd class="text-right">@GetAvgPerDay(context.Qty)</MudTd>
                                        <MudTd class="text-right">@context.Transactions</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @* Reszta: typy bez rozmiarów + maszyny *@
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">@L["TopGloveTypesTitle"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["TopGloveTypesHint"]</MudText>

                                <MudTable Items="_result.ByItemType"
                                          Dense="true"
                                          Hover="true"
                                          Bordered="true"
                                          Striped="true"
                                          Class="gloves-table">
                                    <HeaderContent>
                                        <MudTh>@L["Col_GloveType"]</MudTh>
                                        <MudTh class="text-right">@L["Col_Qty"]</MudTh>
                                        <MudTh class="text-right">@L["Col_Transactions"]</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>
                                            <MudText Typo="Typo.body2" Style="font-weight:700;">@context.GloveType</MudText>
                                        </MudTd>
                                        <MudTd class="text-right">@context.Qty</MudTd>
                                        <MudTd class="text-right">@context.Transactions</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">@L["TopVmsTitle"]</MudText>

                                <MudTable Items="_result.ByVm"
                                          Dense="true"
                                          Hover="true"
                                          Bordered="true"
                                          Striped="true"
                                          Class="gloves-table">
                                    <HeaderContent>
                                        <MudTh>@L["Col_Vm"]</MudTh>
                                        <MudTh class="text-right">@L["Col_Qty"]</MudTh>
                                        <MudTh class="text-right">@L["Col_Transactions"]</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>
                                            <MudText Typo="Typo.body2" Style="font-weight:700;">@context.VmId</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.VmDescr</MudText>
                                        </MudTd>
                                        <MudTd class="text-right">@context.Qty</MudTd>
                                        <MudTd class="text-right">@context.Transactions</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                }

                <MudOverlay Visible="@_loading"
                            DarkBackground="true"
                            AutoClose="false"
                            Absolute="true"
                            Class="gloves-overlay">
                    <MudPaper Class="pa-6 gloves-overlay-card" Elevation="0">
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1">@L["Loading"]</MudText>
                        </MudStack>
                    </MudPaper>
                </MudOverlay>

            </div>
        }
    </MudStack>
</MudPaper>

<style>
    .gloves-content-container {
        position: relative;
        min-height: 320px;
    }

    .gloves-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

