@code
{
    private bool _ready;
    private bool _canView;
    private bool _loading;

    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private DateTime _sliderBaseStart;
    private double _sliderMaxDays;
    private double _sliderFromDays;
    private double _sliderToDays;

    private bool _compare;

    private GlovesTrendGranularity _trendGranularity = GlovesTrendGranularity.Week;

    private TimeZoneInfo _userTz = TimeZoneInfo.Local;

    private List<GlovesItemOption> _items = new();
    private List<GlovesVmOption> _vms = new();
    private List<GlovesDepartmentOption> _departments = new();

    private HashSet<string> _selectedItemNumbers = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<int> _selectedVmIds = new();

    private string? _selectedDepartment;

    private GlovesReportResult? _result;

    private CancellationTokenSource? _reloadDebounceCts;
    private bool _reloadRequestedWhileLoading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            await CurrentUserContextService.EnsureInitializedAsync();
            var ctx = CurrentUserContextService.CurrentUser;

            _canView = ctx.IsAuthenticated && ctx.IsActive == true && ctx.Has("Reports.View");
            _ready = true;

            if (!_canView)
                return;

            try
            {
                _userTz = await TimeZoneService.GetUserTimeZoneAsync();
            }
            catch
            {
                _userTz = TimeZoneInfo.Local;
            }

            var todayLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _userTz).Date;

            _sliderBaseStart = todayLocal.AddMonths(-12);
            _sliderMaxDays = Math.Max(1, (todayLocal - _sliderBaseStart).TotalDays);

            _dateFrom = todayLocal.AddDays(-30);
            _dateTo = todayLocal;

            SyncSlidersFromDates();

            _items = await GlovesReportService.GetAvailableItemsAsync();
            _vms = await GlovesReportService.GetAvailableVendingMachinesAsync();
            _departments = await GlovesReportService.GetAvailableDepartmentsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[Reports.Gloves] Init error.");
            Snackbar.Add(L["ErrorReport"], Severity.Error);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }

        if (_canView)
            await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        if (!_canView)
            return;

        if (_loading)
        {
            _reloadRequestedWhileLoading = true;
            return;
        }

        try
        {
            _loading = true;

            var from = (_dateFrom?.Date ?? TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _userTz).Date.AddDays(-30));
            var to = (_dateTo?.Date ?? TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _userTz).Date);

            if (to < from)
                (from, to) = (to, from);

            var req = new GlovesReportRequest
            {
                DateFrom = from,
                DateTo = to,
                CompareWithPreviousPeriod = _compare,
                TrendGranularity = _trendGranularity,
                Department = string.IsNullOrWhiteSpace(_selectedDepartment) ? null : _selectedDepartment,
                ItemNumbers = _selectedItemNumbers.Count == 0 ? new List<string>() : _selectedItemNumbers.ToList(),
                VmIds = _selectedVmIds.Count == 0 ? new List<int>() : _selectedVmIds.ToList()
            };

            _result = await GlovesReportService.GetReportAsync(req);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "[Reports.Gloves] Reload error. From={From} To={To} Dept={Dept} ItemsCount={ItemsCount} VmCount={VmCount} Compare={Compare} Granularity={Granularity}",
                _dateFrom, _dateTo, _selectedDepartment, _selectedItemNumbers.Count, _selectedVmIds.Count, _compare, _trendGranularity);

            Snackbar.Add(L["ErrorReport"], Severity.Error);
        }
        finally
        {
            _loading = false;

            if (_reloadRequestedWhileLoading)
            {
                _reloadRequestedWhileLoading = false;
                await ReloadAsync();
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ScheduleReloadAsync(int delayMs = 450)
    {
        _reloadDebounceCts?.Cancel();
        _reloadDebounceCts?.Dispose();

        _reloadDebounceCts = new CancellationTokenSource();
        var token = _reloadDebounceCts.Token;

        try
        {
            await Task.Delay(delayMs, token);
            if (!token.IsCancellationRequested)
                await InvokeAsync(ReloadAsync);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task ApplyPresetDaysAsync(int days)
    {
        NormalizeDates();

        var todayLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _userTz).Date;
        _dateTo = todayLocal;
        _dateFrom = todayLocal.AddDays(-Math.Max(1, days));

        SyncSlidersFromDates();
        await ReloadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        var todayLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _userTz).Date;

        _dateFrom = todayLocal.AddDays(-30);
        _dateTo = todayLocal;

        _trendGranularity = GlovesTrendGranularity.Week;
        _compare = false;

        _selectedDepartment = null;
        _selectedItemNumbers.Clear();
        _selectedVmIds.Clear();

        SyncSlidersFromDates();
        await ReloadAsync();
    }

    private async Task OnDateFromChanged(DateTime? value)
    {
        _dateFrom = value;
        NormalizeDates();
        SyncSlidersFromDates();
        await ScheduleReloadAsync();
    }

    private async Task OnDateToChanged(DateTime? value)
    {
        _dateTo = value;
        NormalizeDates();
        SyncSlidersFromDates();
        await ScheduleReloadAsync();
    }

    private async Task OnSliderFromChanged(double value)
    {
        _sliderFromDays = value;

        if (_sliderFromDays > _sliderToDays)
            _sliderToDays = _sliderFromDays;

        _dateFrom = _sliderBaseStart.AddDays(_sliderFromDays).Date;
        _dateTo = _sliderBaseStart.AddDays(_sliderToDays).Date;

        NormalizeDates();
        await ScheduleReloadAsync();
    }

    private async Task OnSliderToChanged(double value)
    {
        _sliderToDays = value;

        if (_sliderToDays < _sliderFromDays)
            _sliderFromDays = _sliderToDays;

        _dateFrom = _sliderBaseStart.AddDays(_sliderFromDays).Date;
        _dateTo = _sliderBaseStart.AddDays(_sliderToDays).Date;

        NormalizeDates();
        await ScheduleReloadAsync();
    }

    private async Task OnCompareValueChanged(bool value)
    {
        if (_compare == value)
            return;

        _compare = value;
        await ReloadAsync();
    }

    private async Task OnTrendGranularityChanged(GlovesTrendGranularity value)
    {
        if (_trendGranularity == value)
            return;

        _trendGranularity = value;
        await ReloadAsync();
    }

    private void NormalizeDates()
    {
        var todayLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _userTz).Date;

        var from = (_dateFrom?.Date ?? todayLocal.AddDays(-30));
        var to = (_dateTo?.Date ?? todayLocal);

        if (to < from)
            (from, to) = (to, from);

        _dateFrom = from;
        _dateTo = to;
    }

    private void SyncSlidersFromDates()
    {
        NormalizeDates();

        var from = _dateFrom!.Value.Date;
        var to = _dateTo!.Value.Date;

        var start = (from - _sliderBaseStart).TotalDays;
        var end = (to - _sliderBaseStart).TotalDays;

        start = Math.Max(0, Math.Min(_sliderMaxDays, start));
        end = Math.Max(0, Math.Min(_sliderMaxDays, end));

        _sliderFromDays = start;
        _sliderToDays = end;
    }

    private async Task<IEnumerable<GlovesDepartmentOption>> SearchDepartmentsAsync(string value, CancellationToken token)
    {
        await Task.CompletedTask;

        if (_departments.Count == 0)
            return Enumerable.Empty<GlovesDepartmentOption>();

        if (string.IsNullOrWhiteSpace(value))
            return _departments.Take(50);

        value = value.Trim();

        return _departments
            .Where(x => (x.Department?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(50);
    }

    private async Task OnDepartmentPicked(GlovesDepartmentOption? dept)
    {
        if (dept is null || string.IsNullOrWhiteSpace(dept.Department))
            return;

        _selectedDepartment = dept.Department.Trim();
        await ReloadAsync();
    }

    private async Task ClearDepartmentAsync()
    {
        _selectedDepartment = null;
        await ReloadAsync();
    }

    private async Task<IEnumerable<GlovesItemOption>> SearchItemsAsync(string value, CancellationToken token)
    {
        await Task.CompletedTask;

        if (_items.Count == 0)
            return Enumerable.Empty<GlovesItemOption>();

        if (string.IsNullOrWhiteSpace(value))
            return _items.Take(50);

        value = value.Trim();

        return _items
            .Where(x => (x.ItemNumber?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
                     || (x.ItemDescr?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(50);
    }

    private async Task<IEnumerable<GlovesVmOption>> SearchVmsAsync(string value, CancellationToken token)
    {
        await Task.CompletedTask;

        if (_vms.Count == 0)
            return Enumerable.Empty<GlovesVmOption>();

        if (string.IsNullOrWhiteSpace(value))
            return _vms.Take(50);

        value = value.Trim();

        return _vms
            .Where(x => x.VmId.ToString().Contains(value, StringComparison.OrdinalIgnoreCase)
                     || (x.VmDescr?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(50);
    }

    private async Task OnItemPicked(GlovesItemOption? item)
    {
        if (item is null || string.IsNullOrWhiteSpace(item.ItemNumber))
            return;

        _selectedItemNumbers.Add(item.ItemNumber);
        await ScheduleReloadAsync(250);
    }

    private async Task RemoveItemAsync(string itemNumber)
    {
        if (string.IsNullOrWhiteSpace(itemNumber))
            return;

        _selectedItemNumbers.Remove(itemNumber);
        await ScheduleReloadAsync(250);
    }

    private async Task OnVmPicked(GlovesVmOption? vm)
    {
        if (vm is null || vm.VmId <= 0)
            return;

        _selectedVmIds.Add(vm.VmId);
        await ScheduleReloadAsync(250);
    }

    private async Task RemoveVmAsync(int vmId)
    {
        if (vmId <= 0)
            return;

        _selectedVmIds.Remove(vmId);
        await ScheduleReloadAsync(250);
    }

    private async Task OnDepartmentRowClickedAsync(TableRowClickEventArgs<GlovesByDepartmentRow> args)
    {
        if (args.Item is null)
            return;

        var dept = args.Item.Department ?? "";
        if (string.IsNullOrWhiteSpace(dept))
            return;

        _selectedDepartment = dept.Trim();

        await ReloadAsync();
    }


    private string[] TrendLabels
        => _result?.Trend?.OrderBy(x => x.SortKey).Select(x => x.Label).ToArray() ?? Array.Empty<string>();

    private List<ChartSeries> TrendSeries
    {
        get
        {
            if (_result?.Trend is null || _result.Trend.Count == 0)
                return new List<ChartSeries>();

            var points = _result.Trend.OrderBy(x => x.SortKey).Select(x => (double)x.Qty).ToArray();

            return new List<ChartSeries>
            {
                new ChartSeries { Name = L["Series_Qty"], Data = points }
            };
        }
    }

    private decimal GetAvgPerDay(int qty)
    {
        NormalizeDates();
        var days = Math.Max(1, (_dateTo!.Value.Date - _dateFrom!.Value.Date).Days + 1);
        return Math.Round((decimal)qty / days, 2);
    }

    private string GetTopDepartmentLabel()
    {
        var top = _result?.ByDepartment?.FirstOrDefault();
        if (top is null)
            return L["NA"];

        return top.Department;
    }

    private string GetTopDepartmentDetails()
    {
        var top = _result?.ByDepartment?.FirstOrDefault();
        if (top is null)
            return "";

        return L["TopDepartmentDetails", top.Qty, top.UniqueUsers];
    }

    private ChangeChip GetChangeChip(int current, int prev)
    {
        if (prev == 0 && current == 0)
            return new ChangeChip(Icons.Material.Filled.Remove, Color.Primary, "0");

        if (prev == 0 && current > 0)
            return new ChangeChip(Icons.Material.Filled.ArrowUpward, Color.Error, L["ChangeFromZero"]);

        var diff = current - prev;
        if (diff == 0)
            return new ChangeChip(Icons.Material.Filled.Remove, Color.Primary, L["ChangeNo"]);

        var pct = (double)diff / prev * 100.0;
        var label = $"{diff:+#;-#;0} ({pct:+0.#;-0.#;0.#}%)";

        if (diff > 0)
            return new ChangeChip(Icons.Material.Filled.ArrowUpward, Color.Error, label);

        return new ChangeChip(Icons.Material.Filled.ArrowDownward, Color.Success, label);
    }

    private string GetChangeText(int current, int prev)
    {
        if (prev == 0 && current == 0)
            return "0";

        if (prev == 0 && current > 0)
            return $"{current} ( {L["ChangeFromZero"]} )";

        var diff = current - prev;
        if (diff == 0)
            return L["ChangeNo"];

        var pct = (double)diff / prev * 100.0;
        return $"{diff:+#;-#;0} ({pct:+0.#;-0.#;0.#}%)";
    }

    private string GetChangeText(decimal current, decimal prev)
    {
        if (prev == 0 && current == 0)
            return "0";

        if (prev == 0 && current > 0)
            return $"{current:0.##} ( {L["ChangeFromZero"]} )";

        var diff = current - prev;
        if (diff == 0)
            return L["ChangeNo"];

        var pct = (double)(diff / prev) * 100.0;
        return $"{diff:+0.##;-0.##;0.##} ({pct:+0.#;-0.#;0.#}%)";
    }

    private ComparePeriods GetComparePeriods()
    {
        NormalizeDates();

        var currentFrom = _dateFrom!.Value.Date;
        var currentTo = _dateTo!.Value.Date;

        var days = (currentTo - currentFrom).Days + 1;

        var prevTo = currentFrom.AddDays(-1);
        var prevFrom = prevTo.AddDays(-(days - 1));

        return new ComparePeriods(currentFrom, currentTo, prevFrom, prevTo);
    }

    private string GetDateRangeLabel()
    {
        NormalizeDates();
        return $"{_dateFrom!.Value:yyyy-MM-dd} - {_dateTo!.Value:yyyy-MM-dd}";
    }

    private string GetDepartmentLabel()
        => string.IsNullOrWhiteSpace(_selectedDepartment) ? L["AllDepartmentsShort"] : _selectedDepartment!;

    private string GetItemsLabel()
        => _selectedItemNumbers.Count == 0 ? L["AllItemsShort"] : L["SelectedCount", _selectedItemNumbers.Count];

    private string GetMachinesLabel()
        => _selectedVmIds.Count == 0 ? L["AllMachinesShort"] : L["SelectedCount", _selectedVmIds.Count];

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_reloadDebounceCts is not null)
            {
                _reloadDebounceCts.Cancel();
                _reloadDebounceCts.Dispose();
            }
        }
        catch
        {
        }

        await Task.CompletedTask;
    }

    private sealed record ComparePeriods(DateTime CurrentFrom, DateTime CurrentTo, DateTime PrevFrom, DateTime PrevTo);
    private sealed record ChangeChip(string Icon, Color Color, string Label);
}
