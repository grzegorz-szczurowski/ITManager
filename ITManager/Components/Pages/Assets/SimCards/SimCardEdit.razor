@code
{
    [Parameter] public int Id { get; set; }

    private bool _isLoading = true;
    private bool _isSaving;

    private bool _isNew;
    private bool _isEditEnabled;

    private bool _isDirty;
    private string _originalEditJson = string.Empty;

    private bool _canViewSim;
    private bool _canEditSim;

    private string _errorMessage = string.Empty;

    private MudForm? _form;

    private ITManager.Models.SimCardEditModel _edit = new();

    private List<string> _typeOptions = new();
    private List<string> _operatorOptions = new();
    private List<string> _planOptions = new();
    private List<string> _statusOptions = new();
    private List<string> _userOptions = new();

    private bool IsUiLocked => _isSaving || !_canEditSim;

    private Adornment LockAdornment => !_isEditEnabled ? Adornment.End : Adornment.None;
    private string? LockIcon => !_isEditEnabled ? Icons.Material.Filled.Lock : null;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            await CurrentUserContextService.EnsureInitializedAsync();
            var ctx = CurrentUserContextService.CurrentUser;

            if (ctx == null || !ctx.IsAuthenticated || ctx.IsActive != true || !ctx.Has("Assets.Sim.View"))
            {
                _canViewSim = false;
                _canEditSim = false;
                return;
            }

            _canViewSim = true;

            _isNew = Id <= 0;
            var canCreate = ctx.Has("Assets.Sim.Create");
            var canEdit = ctx.Has("Assets.Sim.Edit");

            _canEditSim = _isNew ? canCreate : canEdit;

            await LoadLookupsAsync();
            await LoadAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleEditMode()
    {
        if (_isLoading || _isSaving || !_canEditSim)
            return;

        _isEditEnabled = !_isEditEnabled;

        if (!_isEditEnabled)
            _isDirty = false;
    }

    private string BuildSimTitle()
    {
        var sim = GetSafe(_edit.SimCardNumber);
        if (!string.IsNullOrWhiteSpace(sim))
            return $"{L["Title.SimPrefix"]} {sim}";

        var mobile = GetSafe(_edit.MobileNumber);
        if (!string.IsNullOrWhiteSpace(mobile))
            return $"{L["Title.SimPrefix"]} {mobile}";

        return L["Title.SimCard"];
    }

    private string BuildSimSubtitle()
    {
        var op = GetSafe(_edit.Operator, L["Common.Dash"]);
        var plan = GetSafe(_edit.Plan, L["Common.Dash"]);
        return string.Format(L["Subtitle.OperatorPlan"], op, plan);
    }

    private Color GetStatusChipColor(string? status)
    {
        var s = (status ?? string.Empty).Trim();
        if (s.Equals("Active", StringComparison.OrdinalIgnoreCase))
            return Color.Success;

        return Color.Default;
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var result = await SimCardsService.GetSimCardsFilterLookupsAsync();
            if (!result.Ok)
            {
                ClearOptions();
                _errorMessage = result.ErrorMessage ?? L["Error.LoadLookups"];
                return;
            }

            var l = result.Lookups ?? new SimCardsFilterLookups();

            _typeOptions = NormalizeOptions(l.Types);
            _operatorOptions = NormalizeOptions(l.Operators);
            _planOptions = NormalizeOptions(l.Plans);
            _statusOptions = NormalizeOptions(l.Statuses);
            _userOptions = NormalizeOptions(l.Users);
        }
        catch
        {
            ClearOptions();
            _errorMessage = L["Error.LoadLookups"];
        }
    }

    private void ClearOptions()
    {
        _typeOptions = new();
        _operatorOptions = new();
        _planOptions = new();
        _statusOptions = new();
        _userOptions = new();
    }

    private static List<string> NormalizeOptions(IEnumerable<string>? source)
    {
        return (source ?? Enumerable.Empty<string>())
            .Select(x => (x ?? string.Empty).Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task LoadAsync()
    {
        _errorMessage = string.Empty;
        _isDirty = false;

        try
        {
            _isNew = Id <= 0;

            if (_isNew)
            {
                _edit = new ITManager.Models.SimCardEditModel { Id = 0 };
                SnapshotOriginal();
                _isEditEnabled = _canEditSim;
                return;
            }

            var get = await SimCardsService.GetSimCardByIdAsync(Id);
            if (!get.Ok)
            {
                _errorMessage = get.ErrorMessage ?? L["Error.LoadSimCard"];
                _edit = new ITManager.Models.SimCardEditModel();
                SnapshotOriginal();
                _isEditEnabled = false;
                return;
            }

            if (get.Row == null)
            {
                _errorMessage = string.Format(L["Error.NotFoundById"], Id);
                _edit = new ITManager.Models.SimCardEditModel();
                SnapshotOriginal();
                _isEditEnabled = false;
                return;
            }

            _edit = new ITManager.Models.SimCardEditModel
            {
                Id = get.Row.Id,
                Type = get.Row.Type ?? string.Empty,
                Operator = get.Row.Operator ?? string.Empty,
                Plan = get.Row.Plan ?? string.Empty,
                Status = get.Row.Status ?? string.Empty,
                User = get.Row.User ?? string.Empty,
                MobileNumber = get.Row.MobileNumber ?? string.Empty,
                SimCardNumber = get.Row.SimCardNumber ?? string.Empty,
                Note = get.Row.Note ?? string.Empty
            };

            SnapshotOriginal();
            _isEditEnabled = false;
        }
        catch
        {
            _errorMessage = L["Error.LoadSimCardTryLater"];
            _edit = new ITManager.Models.SimCardEditModel();
            SnapshotOriginal();
            _isEditEnabled = false;
        }
    }

    private void SnapshotOriginal()
    {
        _originalEditJson = SerializeEdit(_edit);
        _isDirty = false;
    }

    private void MarkDirty()
    {
        if (string.IsNullOrWhiteSpace(_originalEditJson))
        {
            _isDirty = true;
            return;
        }

        var current = SerializeEdit(_edit);
        _isDirty = !string.Equals(_originalEditJson, current, StringComparison.Ordinal);
    }

    private static string SerializeEdit(ITManager.Models.SimCardEditModel model)
    {
        var options = new JsonSerializerOptions
        {
            WriteIndented = false,
            PropertyNamingPolicy = null
        };

        return JsonSerializer.Serialize(model ?? new ITManager.Models.SimCardEditModel(), options);
    }

    private void SetEditString(Action<string> setter, string? value)
    {
        var v = value ?? string.Empty;
        setter(v);
        MarkDirty();
    }

    private async Task SaveAsync()
    {
        if (!_canViewSim || !_canEditSim)
        {
            Snackbar.Add(L["NoAccess.Edit"], Severity.Warning);
            NavigateBack();
            return;
        }

        if (!_isEditEnabled || _isLoading || _isSaving || !_isDirty)
            return;

        _isSaving = true;

        try
        {
            if (_form != null)
                await _form.Validate();

            var payload = new ITManager.Models.SimCardEditModel
            {
                Id = _isNew ? 0 : _edit.Id,
                Type = (_edit.Type ?? string.Empty).Trim(),
                Operator = (_edit.Operator ?? string.Empty).Trim(),
                Plan = (_edit.Plan ?? string.Empty).Trim(),
                Status = (_edit.Status ?? string.Empty).Trim(),
                User = (_edit.User ?? string.Empty).Trim(),
                MobileNumber = (_edit.MobileNumber ?? string.Empty).Trim(),
                SimCardNumber = (_edit.SimCardNumber ?? string.Empty).Trim(),
                Note = _edit.Note ?? string.Empty
            };

            if (_isNew || payload.Id <= 0)
            {
                var created = await SimCardsService.CreateSimCardAsync(payload);
                if (!created.Ok)
                {
                    Snackbar.Add(created.ErrorMessage ?? L["Error.Save"], Severity.Error);
                    return;
                }

                Snackbar.Add(L["Toast.Saved"], Severity.Success);
                NavigateBack();
                return;
            }

            var updated = await SimCardsService.UpdateSimCardAsync(payload);
            if (!updated.Ok)
            {
                Snackbar.Add(updated.ErrorMessage ?? L["Error.Save"], Severity.Error);
                return;
            }

            Snackbar.Add(L["Toast.Saved"], Severity.Success);
            NavigateBack();
        }
        catch
        {
            Snackbar.Add(L["Error.SaveGeneric"], Severity.Error);
        }
        finally
        {
            _isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CloseAsync()
    {
        if (_isSaving)
            return;

        if (_isEditEnabled && _isDirty)
        {
            var discard = await DialogService.ShowMessageBox(
                title: L["Dialog.Unsaved.Title"],
                message: L["Dialog.Unsaved.Message"],
                yesText: L["Dialog.Unsaved.YesDiscard"],
                cancelText: L["Dialog.Unsaved.NoStay"]
            );

            if (discard != true)
                return;
        }

        NavigateBack();
    }

    private void NavigateBack()
        => Nav.NavigateTo("/assets/simcards");

    private async Task CopyToClipboardAsync(string? value, string label)
    {
        var v = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(v))
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", v);
            Snackbar.Add(string.Format(L["Toast.Copied"], label), Severity.Success);
        }
        catch
        {
            Snackbar.Add(L["Error.CopyClipboard"], Severity.Error);
        }
    }

    private static Task<IEnumerable<string>> SearchInOptionsAsync(List<string> options, string? search, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();

        var list = options ?? new List<string>();
        var s = (search ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(s))
            return Task.FromResult<IEnumerable<string>>(list);

        var filtered = list
            .Where(x => !string.IsNullOrWhiteSpace(x) && x.Contains(s, StringComparison.OrdinalIgnoreCase))
            .ToList();

        return Task.FromResult<IEnumerable<string>>(filtered);
    }

    private static string GetSafe(string? value, string fallback = "")
    {
        var v = (value ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(v) ? fallback : v;
    }
}
