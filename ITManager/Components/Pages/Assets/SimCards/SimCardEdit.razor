@page "/assets/simcards/new"
@page "/assets/simcards/edit/{Id:int}"
@rendermode InteractiveServer

@attribute [Authorize(Policy = "Perm:Assets.Sim.View")]

@* File: Components/Pages/Assets/SimCards/SimCardEdit.razor
   Description: Ekran dodawania i edycji karty SIM (bez dialogu). UX spójny z DeviceEditDialog:
                Summary + zakładki ze scrollem, start w trybie read-only (dla istniejących),
                Enable edit odblokowuje edycję, listy z wyszukiwaniem (MudAutocomplete),
                słowniki pobierane z bazy przez GetSimCardsFilterLookupsAsync().
   Version: 1.03
   Updated: 2026-02-09
   Change log:
     - 1.03 (2026-02-09) i18n: dodany IStringLocalizer + klucze do resx, usunięte twarde stringi z UI.
     - 1.02 (2026-02-09) UX: usunięty nagłówek (title+refresh+cancel), usunięte wycofywanie zmian,
                              kontener full-width jak inne podstrony (bez max-width i centrowania).
*@

@using System
@using System.Linq
@using System.Threading
@using System.Threading.Tasks
@using System.Collections.Generic
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using MudBlazor
@using ITManager.Models
@using ITManager.Services
@using ITManager.Services.Auth

@inject SimCardsService SimCardsService
@inject CurrentUserContextService CurrentUserContextService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IStringLocalizer<SimCardEdit> L

<MudPaper Class="pa-4 sim-edit-root" Elevation="0">

    <MudStack Spacing="2">

        @if (!_canViewSim)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">
                @L["NoAccess.View"]
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
                    @_errorMessage
                </MudAlert>
            }

            @if (_isLoading)
            {
                <MudPaper Class="pa-6" Elevation="0">
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="sim-loading">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1" Class="mt-2">@L["Loading.Data"]</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="sim-summary">
                    <MudStack Spacing="1">

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="sim-summary-top">
                            <MudText Typo="Typo.h6" Class="sim-summary-title">
                                @BuildSimTitle()
                            </MudText>

                            @if (!string.IsNullOrWhiteSpace(GetSafe(_edit.Type)))
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Class="ml-2">
                                    @GetSafe(_edit.Type)
                                </MudChip>
                            }

                            @if (!string.IsNullOrWhiteSpace(GetSafe(_edit.Status)))
                            {
                                <MudChip T="string"
                                         Variant="Variant.Outlined"
                                         Color="@GetStatusChipColor(_edit.Status)"
                                         Class="ml-2">
                                    @GetSafe(_edit.Status)
                                </MudChip>
                            }

                            @if (!_canEditSim)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" Class="ml-2">
                                    @L["Badge.ReadOnly"]
                                </MudChip>
                            }

                            @if (_isEditEnabled && _canEditSim && _isDirty)
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Class="ml-2">
                                    @L["Badge.Unsaved"]
                                </MudChip>
                            }

                            <MudSpacer />
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="sim-summary-subtitle">
                            @BuildSimSubtitle()
                        </MudText>

                        <MudGrid Spacing="1" AlignItems="AlignItems.Center" Class="sim-summary-grid">

                            <MudItem xs="12" sm="6" md="6" Class="sim-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="sim-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>@L["Field.User"]:</b> @GetSafe(_edit.User, L["Common.Dash"])
                                    </MudText>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="6" Class="sim-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="sim-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>@L["Field.MobileNumberShort"]:</b> <span class="sim-mono">@GetSafe(_edit.MobileNumber, L["Common.Dash"])</span>
                                    </MudText>

                                    <MudTooltip Text="@L["Tooltip.CopyMobile"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Size="Size.Medium"
                                                       Color="Color.Default"
                                                       Variant="Variant.Text"
                                                       Disabled="@string.IsNullOrWhiteSpace(GetSafe(_edit.MobileNumber))"
                                                       Class="ml-1"
                                                       OnClick="@(() => CopyToClipboardAsync(_edit.MobileNumber, L["Clipboard.Mobile"]))" />
                                    </MudTooltip>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="6" Class="sim-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="sim-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.SimCard" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>@L["Field.SimCardNumberShort"]:</b> <span class="sim-mono">@GetSafe(_edit.SimCardNumber, L["Common.Dash"])</span>
                                    </MudText>

                                    <MudTooltip Text="@L["Tooltip.CopySim"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Size="Size.Medium"
                                                       Color="Color.Default"
                                                       Variant="Variant.Text"
                                                       Disabled="@string.IsNullOrWhiteSpace(GetSafe(_edit.SimCardNumber))"
                                                       Class="ml-1"
                                                       OnClick="@(() => CopyToClipboardAsync(_edit.SimCardNumber, L["Clipboard.Sim"]))" />
                                    </MudTooltip>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="6" Class="sim-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="sim-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>@L["Field.Operator"]:</b> @GetSafe(_edit.Operator, L["Common.Dash"])
                                    </MudText>
                                </MudStack>
                            </MudItem>

                        </MudGrid>

                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0" Class="sim-tabs">
                    <MudTabs Rounded="true" Elevation="0" KeepPanelsAlive="true">

                        <MudTabPanel Text="@L["Tab.General"]">
                            <div class="sim-tab-scroll">
                                <MudForm @ref="_form">
                                    <MudGrid Spacing="2">

                                        <MudItem xs="12" md="4">
                                            @if (_isEditEnabled)
                                            {
                                                <MudAutocomplete T="string"
                                                                 Label="@L["Field.Type"]"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Disabled="@IsUiLocked"
                                                                 Clearable="true"
                                                                 Value="@_edit.Type"
                                                                 ValueChanged="v => SetEditString(x => _edit.Type = x, v)"
                                                                 SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_typeOptions, s, ct) )"
                                                                 DebounceInterval="150"
                                                                 CoerceText="true"
                                                                 ResetValueOnEmptyText="true" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string"
                                                              Label="@L["Field.Type"]"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              ReadOnly="true"
                                                              Value="@GetSafe(_edit.Type, L["Common.Dash"])"
                                                              Adornment="@LockAdornment"
                                                              AdornmentIcon="@LockIcon"
                                                              AdornmentColor="Color.Default" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            @if (_isEditEnabled)
                                            {
                                                <MudAutocomplete T="string"
                                                                 Label="@L["Field.Operator"]"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Disabled="@IsUiLocked"
                                                                 Clearable="true"
                                                                 Value="@_edit.Operator"
                                                                 ValueChanged="v => SetEditString(x => _edit.Operator = x, v)"
                                                                 SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_operatorOptions, s, ct) )"
                                                                 DebounceInterval="150"
                                                                 CoerceText="true"
                                                                 ResetValueOnEmptyText="true" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string"
                                                              Label="@L["Field.Operator"]"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              ReadOnly="true"
                                                              Value="@GetSafe(_edit.Operator, L["Common.Dash"])"
                                                              Adornment="@LockAdornment"
                                                              AdornmentIcon="@LockIcon"
                                                              AdornmentColor="Color.Default" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            @if (_isEditEnabled)
                                            {
                                                <MudAutocomplete T="string"
                                                                 Label="@L["Field.Plan"]"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Disabled="@IsUiLocked"
                                                                 Clearable="true"
                                                                 Value="@_edit.Plan"
                                                                 ValueChanged="v => SetEditString(x => _edit.Plan = x, v)"
                                                                 SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_planOptions, s, ct) )"
                                                                 DebounceInterval="150"
                                                                 CoerceText="true"
                                                                 ResetValueOnEmptyText="true" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string"
                                                              Label="@L["Field.Plan"]"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              ReadOnly="true"
                                                              Value="@GetSafe(_edit.Plan, L["Common.Dash"])"
                                                              Adornment="@LockAdornment"
                                                              AdornmentIcon="@LockIcon"
                                                              AdornmentColor="Color.Default" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            @if (_isEditEnabled)
                                            {
                                                <MudAutocomplete T="string"
                                                                 Label="@L["Field.Status"]"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Disabled="@IsUiLocked"
                                                                 Clearable="true"
                                                                 Value="@_edit.Status"
                                                                 ValueChanged="v => SetEditString(x => _edit.Status = x, v)"
                                                                 SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_statusOptions, s, ct) )"
                                                                 DebounceInterval="150"
                                                                 CoerceText="true"
                                                                 ResetValueOnEmptyText="true" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string"
                                                              Label="@L["Field.Status"]"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              ReadOnly="true"
                                                              Value="@GetSafe(_edit.Status, L["Common.Dash"])"
                                                              Adornment="@LockAdornment"
                                                              AdornmentIcon="@LockIcon"
                                                              AdornmentColor="Color.Default" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" md="8">
                                            @if (_isEditEnabled)
                                            {
                                                <MudAutocomplete T="string"
                                                                 Label="@L["Field.User"]"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Disabled="@IsUiLocked"
                                                                 Clearable="true"
                                                                 Value="@_edit.User"
                                                                 ValueChanged="v => SetEditString(x => _edit.User = x, v)"
                                                                 SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_userOptions, s, ct) )"
                                                                 DebounceInterval="150"
                                                                 CoerceText="true"
                                                                 ResetValueOnEmptyText="true" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string"
                                                              Label="@L["Field.User"]"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              ReadOnly="true"
                                                              Value="@GetSafe(_edit.User, L["Common.Dash"])"
                                                              Adornment="@LockAdornment"
                                                              AdornmentIcon="@LockIcon"
                                                              AdornmentColor="Color.Default" />
                                            }
                                        </MudItem>

                                    </MudGrid>
                                </MudForm>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="@L["Tab.Numbers"]">
                            <div class="sim-tab-scroll">
                                <MudGrid Spacing="2">

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="@L["Field.MobileNumber"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="@(!_isEditEnabled)"
                                                      Disabled="@IsUiLocked"
                                                      Value="@_edit.MobileNumber"
                                                      ValueChanged="v => SetEditString(x => _edit.MobileNumber = x, v)"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="@L["Field.SimCardNumber"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="@(!_isEditEnabled)"
                                                      Disabled="@IsUiLocked"
                                                      Value="@_edit.SimCardNumber"
                                                      ValueChanged="v => SetEditString(x => _edit.SimCardNumber = x, v)"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                </MudGrid>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="@L["Tab.Note"]">
                            <div class="sim-tab-scroll">
                                <MudTextField T="string"
                                              Label="@L["Field.NoteLabelBlank"]"
                                              Lines="16"
                                              AutoGrow="false"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="@(!_isEditEnabled)"
                                              Disabled="@IsUiLocked"
                                              Value="@_edit.Note"
                                              ValueChanged="v => SetEditString(x => _edit.Note = x, v)"
                                              Adornment="@LockAdornment"
                                              AdornmentIcon="@LockIcon"
                                              AdornmentColor="Color.Default" />
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="@L["Tab.History"]">
                            <div class="sim-tab-scroll">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                    @L["History.Todo"]
                                </MudAlert>
                            </div>
                        </MudTabPanel>

                    </MudTabs>
                </MudPaper>

                <MudPaper Elevation="0" Class="sim-footer">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="sim-footer-inner">

                        <MudButton Variant="Variant.Outlined"
                                   Color="@(_isEditEnabled ? Color.Default : Color.Primary)"
                                   StartIcon="@(_isEditEnabled ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                                   OnClick="ToggleEditMode"
                                   Disabled="@(_isLoading || _isSaving || !_canEditSim)">
                            @(_isEditEnabled? L["Button.Lock"] : L["Button.EnableEdit"])
                        </MudButton>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveAsync"
                                       Disabled="@(!_isEditEnabled || _isLoading || _isSaving || !_isDirty || !_canEditSim)">
                                @L["Button.Save"]
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Close"
                                       OnClick="CloseAsync"
                                       Disabled="@(_isSaving)">
                                @L["Button.Close"]
                            </MudButton>
                        </MudStack>

                    </MudStack>
                </MudPaper>

                <MudOverlay Visible="@(_isSaving)" DarkBackground="true" AutoClose="false" Class="sim-overlay">
                    <MudPaper Class="pa-6 sim-overlay-card" Elevation="0">
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1">@L["Saving"]</MudText>
                        </MudStack>
                    </MudPaper>
                </MudOverlay>
            }
        }

    </MudStack>

</MudPaper>

<style>
