    private void ToggleEditMode()
    {
        if (_isSaving || _isLoading || !_canEditSystems)
            return;

        _isEditEnabled = !_isEditEnabled;

        if (!_isEditEnabled)
            RevertChanges();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _isLoaded = false;
        _loadError = string.Empty;

        await InvokeAsync(StateHasChanged);

        try
        {
            var cs = Configuration.GetConnectionString(ConnectionStringName);
            if (string.IsNullOrWhiteSpace(cs))
            {
                _loadError = $"Brak ConnectionString '{ConnectionStringName}'.";
                return;
            }

            using var con = new SqlConnection(cs);
            await con.OpenAsync();

            await LoadLookupsAsync(con);

            if (_isCreateMode)
            {
                _model = new SystemEditModel { Id = 0 };
                _isLoaded = true;
                SyncSelectedFromModel();
                SnapshotOriginal();
                return;
            }

            if (SystemId <= 0)
            {
                _loadError = "Nieprawidłowe ID systemu.";
                return;
            }

            await LoadSystemAsync(con, SystemId);

            if (string.IsNullOrWhiteSpace(_loadError))
            {
                _isLoaded = true;
                SyncSelectedFromModel();
                SnapshotOriginal();
                _isEditEnabled = false;
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[SystemEdit] ERROR: {ex}");
            _loadError = "Błąd podczas ładowania danych systemu.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SnapshotOriginal()
    {
        _originalJson = JsonSerializer.Serialize(_model ?? new SystemEditModel());
        _isDirty = false;
    }

    private void MarkDirty()
    {
        if (string.IsNullOrWhiteSpace(_originalJson))
        {
            _isDirty = true;
            return;
        }

        var current = JsonSerializer.Serialize(_model ?? new SystemEditModel());
        _isDirty = !string.Equals(_originalJson, current, StringComparison.Ordinal);
    }

    private void RevertChanges()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_originalJson))
                return;

            var restored = JsonSerializer.Deserialize<SystemEditModel>(_originalJson);
            if (restored == null)
                return;

            _model = restored;
            _isDirty = false;

            SyncSelectedFromModel();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[SystemEdit] RevertChanges ERROR: {ex}");
            Snackbar.Add("Nie udało się przywrócić zmian.", Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        if (!_canEditSystems || !_isEditEnabled || _isSaving || _isLoading || !_isLoaded || !_isDirty)
            return;

        if (string.IsNullOrWhiteSpace(_model.SystemName))
        {
            Snackbar.Add("Uzupełnij nazwę systemu.", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            var cs = Configuration.GetConnectionString(ConnectionStringName);
            if (string.IsNullOrWhiteSpace(cs))
            {
                Snackbar.Add($"Brak ConnectionString '{ConnectionStringName}'.", Severity.Error);
                return;
            }

            using var con = new SqlConnection(cs);
            await con.OpenAsync();

            if (_isCreateMode || _model.Id <= 0)
            {
                var newId = await InsertSystemAsync(con, _model);
                if (newId <= 0)
                {
                    Snackbar.Add("Nie udało się dodać systemu.", Severity.Error);
                    return;
                }

                _model.Id = newId;
                Snackbar.Add("Dodano system.", Severity.Success);
                SnapshotOriginal();
                NavigateBack(force: true);
                return;
            }

            var affected = await UpdateSystemAsync(con, _model);
            if (affected <= 0)
            {
                Snackbar.Add("Nie zapisano zmian (brak zaktualizowanych rekordów).", Severity.Warning);
                return;
            }

            Snackbar.Add("Zapisano zmiany.", Severity.Success);
            SnapshotOriginal();
            NavigateBack(force: true);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[SystemEdit] SAVE ERROR: {ex}");
            Snackbar.Add("Błąd zapisu danych systemu.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            await InvokeAsync(StateHasChanged);
