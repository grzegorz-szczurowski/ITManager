@page "/assets/systems/edit/{SystemId:int}"
@page "/assets/systems/create"
@namespace ITManager.Components.Pages.Assets.Systems
@rendermode InteractiveServer

@attribute [Authorize(Policy = "Perm:Assets.Systems.View")]

@* File: Components/Pages/Assets/Systems/SystemEdit.razor
   Description: Ekran edycji systemu jako page (bez modala). UX/UI spójny z UserEdit:
                - Stały układ: summary header + tabs ze scrollem
                - Start read-only, Enable edit odblokowuje edycję
                - Lookupi jako MudAutocomplete z filtrowaniem po wpisywanym tekście
                - UI blokowane tylko podczas zapisu
                - Dirty tracking (snapshot JSON) + potwierdzenie wyjścia przy niezapisanych zmianach
   Version: 1.01
   Updated: 2026-02-08
   Change log:
     - 1.01 (2026-02-08) UI: usunięty przycisk Back z topbara i stary dolny zestaw akcji.
                              Cancel changes przeniesiony na górę (tylko akcja w edycji),
                              a sticky footer: Enable edit (lewo), Save + Close (prawo).
   Notes:
     - Routing:
         /assets/systems/edit/{SystemId}  (edycja istniejącego)
         /assets/systems/create           (nowy)
     - Uprawnienia:
         View: Assets.Systems.View (page-level policy)
         Edit: Assets.Systems.Edit (Enable edit + zapis)
     - returnUrl:
         query string ?returnUrl=... (powrót po Close / po zapisie)
*@

@using System
@using System.Collections.Generic
@using System.Data
@using System.Data.SqlClient
@using System.Linq
@using System.Text.Json
@using System.Threading
@using System.Threading.Tasks
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Configuration
@using MudBlazor
@using ITManager.Services.Auth

@inject IConfiguration Configuration
@inject CurrentUserContextService CurrentUserContextService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<MudPaper Elevation="0" Class="system-edit-root pa-4">

    <MudStack Spacing="2">

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-2">
                @_loadError
            </MudAlert>
        }

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="system-edit-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.subtitle1" Class="mt-2">Ładowanie danych...</MudText>
            </MudStack>
        }
        else if (!_canViewSystems)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">
                Brak uprawnień do podglądu systemu.
            </MudAlert>
        }
        else
        {
            <div class="system-edit-content">

                <MudPaper Elevation="0" Class="system-summary">
                    <MudStack Spacing="1">

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="system-summary-top">
                            <MudText Typo="Typo.h6" Class="system-summary-title">
                                @GetSafe(_model.SystemName, _isCreateMode ? "New system" : "System")
                            </MudText>

                            @if (_isCreateMode)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Class="ml-2">
                                    New
                                </MudChip>
                            }

                            @if (!_canEditSystems)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" Class="ml-2">
                                    Read-only
                                </MudChip>
                            }

                            @if (_isEditEnabled && _canEditSystems && _isDirty)
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Class="ml-2">
                                    Unsaved
                                </MudChip>
                            }

                            @if (!string.IsNullOrWhiteSpace(LookupName(_lookupCriticalities, _model.SystemCriticalityId)))
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Class="ml-2">
                                    @LookupName(_lookupCriticalities, _model.SystemCriticalityId)
                                </MudChip>
                            }

                            <MudSpacer />
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="system-summary-sub">
                            @GetSummaryLine()
                        </MudText>

                        <MudGrid Spacing="1" AlignItems="AlignItems.Center" Class="system-summary-grid">

                            <MudItem xs="12" sm="6" md="6" Class="system-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="system-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Dns" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>Server:</b> <span class="system-mono">@GetSafe(_model.ServerName, "-")</span>
                                    </MudText>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="6" Class="system-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="system-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>DB:</b> <span class="system-mono">@GetSafe(_model.DbName, "-")</span>
                                    </MudText>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="6" Class="system-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="system-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>Type:</b> @GetSafe(LookupName(_lookupTypes, _model.SystemTypeId), "-")
                                    </MudText>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="6" Class="system-summary-cell">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="system-summary-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        <b>Scope:</b> @GetSafe(LookupName(_lookupScopes, _model.SystemScopeId), "-")
                                    </MudText>
                                </MudStack>
                            </MudItem>

                        </MudGrid>

                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0" Class="system-tabs">
                    <MudTabs Rounded="true" Elevation="0" KeepPanelsAlive="true">

                        <MudTabPanel Text="General">
                            <div class="system-tab-scroll">
                                <MudGrid Spacing="2">

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="System name"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Required="true"
                                                      RequiredError="Nazwa systemu jest wymagana"
                                                      Disabled="@_isUiLocked"
                                                      ReadOnly="@IsReadOnly"
                                                      Value="@_model.SystemName"
                                                      ValueChanged="@(v => OnSystemNameChanged(v))"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="Short description"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Disabled="@_isUiLocked"
                                                      ReadOnly="@IsReadOnly"
                                                      Value="@_model.ShortDescription"
                                                      ValueChanged="@(v => OnShortDescriptionChanged(v))"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="Server name"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Disabled="@_isUiLocked"
                                                      ReadOnly="@IsReadOnly"
                                                      Value="@_model.ServerName"
                                                      ValueChanged="@(v => OnServerNameChanged(v))"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="DB name"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Disabled="@_isUiLocked"
                                                      ReadOnly="@IsReadOnly"
                                                      Value="@_model.DbName"
                                                      ValueChanged="@(v => OnDbNameChanged(v))"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                </MudGrid>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="Classification">
                            <div class="system-tab-scroll">
                                <MudGrid Spacing="2">

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="LookupItemMini"
                                                             Label="Type"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedType"
                                                             ValueChanged="OnSelectedTypeChangedAsync"
                                                             SearchFunc="SearchTypesAsync"
                                                             ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Type"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(LookupName(_lookupTypes, _model.SystemTypeId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="LookupItemMini"
                                                             Label="Scope"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedScope"
                                                             ValueChanged="OnSelectedScopeChangedAsync"
                                                             SearchFunc="SearchScopesAsync"
                                                             ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Scope"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(LookupName(_lookupScopes, _model.SystemScopeId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="LookupItemMini"
                                                             Label="Criticality"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedCriticality"
                                                             ValueChanged="OnSelectedCriticalityChangedAsync"
                                                             SearchFunc="SearchCriticalitiesAsync"
                                                             ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Criticality"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(LookupName(_lookupCriticalities, _model.SystemCriticalityId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="LookupItemMini"
                                                             Label="Hosting type"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedHostingType"
                                                             ValueChanged="OnSelectedHostingTypeChangedAsync"
                                                             SearchFunc="SearchHostingTypesAsync"
                                                             ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Hosting type"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(LookupName(_lookupHostingTypes, _model.SystemHostingTypeId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                </MudGrid>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="Owners and admins">
                            <div class="system-tab-scroll">
                                <MudGrid Spacing="2">

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="UserLookupMini"
                                                             Label="System owner"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedSystemOwner"
                                                             ValueChanged="OnSelectedSystemOwnerChangedAsync"
                                                             SearchFunc="SearchUsersAsync"
                                                             ToStringFunc="@(x => x?.Display ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="System owner"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(UserName(_model.SystemOwnerId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="UserLookupMini"
                                                             Label="Data owner"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedDataOwner"
                                                             ValueChanged="OnSelectedDataOwnerChangedAsync"
                                                             SearchFunc="SearchUsersAsync"
                                                             ToStringFunc="@(x => x?.Display ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Data owner"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(UserName(_model.DataOwnerId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="UserLookupMini"
                                                             Label="Primary administrator"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedPrimaryAdmin"
                                                             ValueChanged="OnSelectedPrimaryAdminChangedAsync"
                                                             SearchFunc="SearchUsersAsync"
                                                             ToStringFunc="@(x => x?.Display ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Primary administrator"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(UserName(_model.PrimaryAdministratorId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudAutocomplete T="UserLookupMini"
                                                             Label="Secondary administrator"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true"
                                                             CoerceText="true"
                                                             ResetValueOnEmptyText="true"
                                                             Disabled="@_isUiLocked"
                                                             Value="@_selectedSecondaryAdmin"
                                                             ValueChanged="OnSelectedSecondaryAdminChangedAsync"
                                                             SearchFunc="SearchUsersAsync"
                                                             ToStringFunc="@(x => x?.Display ?? string.Empty)"
                                                             DebounceInterval="150"
                                                             MaxItems="1000" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Secondary administrator"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@GetSafe(UserName(_model.SecondaryAdministratorId), "-")"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                </MudGrid>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="Backup">
                            <div class="system-tab-scroll">
                                <MudGrid Spacing="2">

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="Last backup status"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Disabled="@_isUiLocked"
                                                      ReadOnly="@IsReadOnly"
                                                      Value="@_model.LastBackupStatus"
                                                      ValueChanged="@(v => OnLastBackupStatusChanged(v))"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string"
                                                      Label="Backup frequency"
                                                      HelperText="np. daily, weekly, monthly"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Disabled="@_isUiLocked"
                                                      ReadOnly="@IsReadOnly"
                                                      Value="@_model.BackupFrequently"
                                                      ValueChanged="@(v => OnBackupFrequentlyChanged(v))"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        @if (!IsReadOnly)
                                        {
                                            <MudDatePicker Label="Last backup date"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Editable="true"
                                                           Clearable="true"
                                                           Disabled="@_isUiLocked"
                                                           Date="@_model.LastBackupDate"
                                                           DateChanged="@(d => OnLastBackupDateChanged(d))" />
                                        }
                                        else
                                        {
                                            <MudTextField T="string"
                                                          Label="Last backup date"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="true"
                                                          Value="@FormatDate(_model.LastBackupDate)"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        }
                                    </MudItem>

                                </MudGrid>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="Notes">
                            <div class="system-tab-scroll">
                                <MudTextField T="string"
                                              Label=" "
                                              Lines="12"
                                              AutoGrow="true"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@_isUiLocked"
                                              ReadOnly="@IsReadOnly"
                                              Value="@_model.Notes"
                                              ValueChanged="@(v => OnNotesChanged(v))"
                                              Adornment="@LockAdornment"
                                              AdornmentIcon="@LockIcon"
                                              AdornmentColor="Color.Default" />
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text="RBAC">
                            <div class="system-tab-scroll">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                    Assets.Systems.View: @(_canViewSystems ? "Yes" : "No")<br />
                                    Assets.Systems.Edit: @(_canEditSystems ? "Yes" : "No")
                                </MudAlert>
                            </div>
                        </MudTabPanel>

                    </MudTabs>
                </MudPaper>

            </div>

            <MudPaper Elevation="0" Class="system-footer">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="system-footer-inner">

                    <MudButton Variant="Variant.Outlined"
                               Color="@(_isEditEnabled ? Color.Default : Color.Primary)"
                               StartIcon="@(_isEditEnabled ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                               OnClick="ToggleEditMode"
                               Disabled="@(!_canEditSystems || _isSaving || _isLoading)">
                        @(_isEditEnabled ? "Lock" : "Enable edit")
                    </MudButton>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SaveAsync"
                                   Disabled="@(!_isEditEnabled || !_canEditSystems || _isSaving || _isLoading || !_isLoaded || !_isDirty)">
                            Save
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="CloseAsync"
                                   Disabled="@_isSaving">
                            Close
                        </MudButton>
                    </MudStack>

                </MudStack>
            </MudPaper>
        }

    </MudStack>

</MudPaper>

<style>
    .system-edit-root {
        width: 100%;
        box-sizing: border-box;
        position: relative;
        padding-bottom: 78px;
    }

    .system-edit-content {
        width: 100%;
        height: 720px;
        max-height: 720px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    .system-edit-loading {
        height: 720px;
    }

    .system-summary {
        padding: 14px;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 10px;
        margin-bottom: 12px;
        background: rgba(255,255,255,0.02);
        flex: 0 0 auto;
        box-sizing: border-box;
    }

    .system-summary-top {
        min-width: 0;
    }

    .system-summary-title {
        font-weight: 700;
        letter-spacing: 0.2px;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .system-summary-sub {
        opacity: 0.85;
        margin-top: 2px;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .system-summary-grid {
        margin-top: 6px;
    }

    .system-summary-cell {
        display: flex;
        min-width: 0;
    }

    .system-summary-item {
        width: 100%;
        min-height: 30px;
        line-height: 1.2;
        min-width: 0;
    }

