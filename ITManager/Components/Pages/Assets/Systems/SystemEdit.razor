    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _loadError = string.Empty;

        try
        {
            await CurrentUserContextService.EnsureInitializedAsync();
            var ctx = CurrentUserContextService.CurrentUser;

            if (ctx == null || !ctx.IsAuthenticated || ctx.IsActive != true || !ctx.Has("Assets.Systems.View"))
            {
                _canViewSystems = false;
                _canEditSystems = false;
                return;
            }

            _canViewSystems = true;
            _canEditSystems = ctx.Has("Assets.Systems.Edit");

            await LoadAsync();

            _isEditEnabled = _isCreateMode && _canEditSystems;
