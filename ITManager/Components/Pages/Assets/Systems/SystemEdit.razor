    private static void AddSystemParams(SqlCommand cmd, SystemEditModel m, bool includeId)
    {
        if (includeId)
            cmd.Parameters.Add(new SqlParameter("@id", SqlDbType.Int) { Value = m.Id });

        cmd.Parameters.Add(new SqlParameter("@name", SqlDbType.NVarChar, 200) { Value = ToDbNullable(m.SystemName) });
        cmd.Parameters.Add(new SqlParameter("@db_name", SqlDbType.NVarChar, 200) { Value = ToDbNullable(m.DbName) });
        cmd.Parameters.Add(new SqlParameter("@server_name", SqlDbType.NVarChar, 200) { Value = ToDbNullable(m.ServerName) });
        cmd.Parameters.Add(new SqlParameter("@short_description", SqlDbType.NVarChar, 500) { Value = ToDbNullable(m.ShortDescription) });

        cmd.Parameters.Add(new SqlParameter("@system_type_id", SqlDbType.Int) { Value = ToDbNullable(m.SystemTypeId) });
        cmd.Parameters.Add(new SqlParameter("@system_scope_id", SqlDbType.Int) { Value = ToDbNullable(m.SystemScopeId) });
        cmd.Parameters.Add(new SqlParameter("@system_criticality_id", SqlDbType.Int) { Value = ToDbNullable(m.SystemCriticalityId) });
        cmd.Parameters.Add(new SqlParameter("@system_hosting_type_id", SqlDbType.Int) { Value = ToDbNullable(m.SystemHostingTypeId) });

        cmd.Parameters.Add(new SqlParameter("@system_owner_id", SqlDbType.Int) { Value = ToDbNullable(m.SystemOwnerId) });
        cmd.Parameters.Add(new SqlParameter("@data_owner_id", SqlDbType.Int) { Value = ToDbNullable(m.DataOwnerId) });
        cmd.Parameters.Add(new SqlParameter("@primary_administrator_id", SqlDbType.Int) { Value = ToDbNullable(m.PrimaryAdministratorId) });
        cmd.Parameters.Add(new SqlParameter("@secondary_administrator_id", SqlDbType.Int) { Value = ToDbNullable(m.SecondaryAdministratorId) });

        cmd.Parameters.Add(new SqlParameter("@last_backup_status", SqlDbType.NVarChar, 200) { Value = ToDbNullable(m.LastBackupStatus) });
        cmd.Parameters.Add(new SqlParameter("@last_backup_date", SqlDbType.DateTime2) { Value = ToDbNullable(m.LastBackupDate) });
        cmd.Parameters.Add(new SqlParameter("@backup_frequently", SqlDbType.NVarChar, 100) { Value = ToDbNullable(m.BackupFrequently) });

        cmd.Parameters.Add(new SqlParameter("@notes", SqlDbType.NVarChar) { Value = ToDbNullable(m.Notes) });
    }

    private static async Task<List<LookupItemMini>> LoadSimpleLookupAsync(SqlConnection con, string tableName)
    {
        var sql = $@"
SELECT id, name, sort_order
FROM {tableName}
ORDER BY ISNULL(sort_order, 2147483647), name;";

        using var cmd = new SqlCommand(sql, con) { CommandType = CommandType.Text, CommandTimeout = 25 };
        using var r = await cmd.ExecuteReaderAsync();

        var list = new List<LookupItemMini>();
        while (await r.ReadAsync())
        {
            list.Add(new LookupItemMini
            {
                Id = SafeInt(r, "id"),
                Name = SafeString(r, "name"),
                SortOrder = SafeNullableInt(r, "sort_order")
            });
        }

        return list;
    }

    private static async Task<List<UserLookupMini>> LoadUsersLookupAsync(SqlConnection con)
    {
        var displayCol = await DetectUsersDisplayColumnAsync(con);

        var sql = $@"
SELECT TOP 5000
    id,
    Display = CAST({QuoteName(displayCol)} AS nvarchar(255))
FROM dbo.users
ORDER BY Display;";

        using var cmd = new SqlCommand(sql, con) { CommandType = CommandType.Text, CommandTimeout = 25 };
        using var r = await cmd.ExecuteReaderAsync();

        var list = new List<UserLookupMini>();
        while (await r.ReadAsync())
        {
            list.Add(new UserLookupMini
            {
                Id = SafeInt(r, "id"),
                Display = SafeString(r, "Display")
            });
        }

        return list;
    }

    private static async Task<string> DetectUsersDisplayColumnAsync(SqlConnection con)
    {
        var candidates = new[]
        {
            "DisplayName",
            "display_name",
            "full_name",
            "user_name",
            "login",
            "name",
            "email",
            "EmailAddress",
            "SamAccountName",
            "samaccountname"
        };

        foreach (var col in candidates)
        {
            if (await ColumnExistsAsync(con, "dbo.users", col))
                return col;
        }

        return "id";
    }

    private static async Task<bool> ColumnExistsAsync(SqlConnection con, string tableName, string columnName)
    {
        const string sql = @"SELECT CASE WHEN COL_LENGTH(@table, @col) IS NOT NULL THEN 1 ELSE 0 END;";
        using var cmd = new SqlCommand(sql, con) { CommandType = CommandType.Text, CommandTimeout = 25 };
        cmd.Parameters.Add(new SqlParameter("@table", SqlDbType.NVarChar, 256) { Value = tableName });
        cmd.Parameters.Add(new SqlParameter("@col", SqlDbType.NVarChar, 128) { Value = columnName });

        var obj = await cmd.ExecuteScalarAsync();
        return Convert.ToInt32(obj) == 1;
    }

    private static string QuoteName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "[id]";

        return "[" + name.Replace("]", "]]") + "]";
    }

    private static object ToDbNullable(string? v)
        => string.IsNullOrWhiteSpace(v) ? DBNull.Value : v.Trim();

    private static object ToDbNullable(int? v)
        => v.HasValue ? v.Value : DBNull.Value;

    private static object ToDbNullable(DateTime? v)
        => v.HasValue ? v.Value : DBNull.Value;

    private static string GetSafe(string? value, string fallback = "")
    {
        var v = (value ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(v) ? fallback : v;
    }

    private static string FormatDate(DateTime? dt)
        => dt.HasValue ? dt.Value.ToString("yyyy-MM-dd") : "-";

    private string GetSummaryLine()
    {
        var parts = new List<string>();

        var server = GetSafe(_model.ServerName);
        var db = GetSafe(_model.DbName);

        if (!string.IsNullOrWhiteSpace(server) || !string.IsNullOrWhiteSpace(db))
        {
            if (!string.IsNullOrWhiteSpace(server) && !string.IsNullOrWhiteSpace(db))
                parts.Add($"{server}\\{db}");
            else
                parts.Add(!string.IsNullOrWhiteSpace(server) ? server : db);
        }

        var typeName = LookupName(_lookupTypes, _model.SystemTypeId);
        var scopeName = LookupName(_lookupScopes, _model.SystemScopeId);
        var critName = LookupName(_lookupCriticalities, _model.SystemCriticalityId);
        var hostName = LookupName(_lookupHostingTypes, _model.SystemHostingTypeId);

        var cls = string.Join(", ", new[] { typeName, scopeName, critName, hostName }.Where(x => !string.IsNullOrWhiteSpace(x)));
        if (!string.IsNullOrWhiteSpace(cls))
            parts.Add(cls);

        var txt = string.Join(" | ", parts);
        return string.IsNullOrWhiteSpace(txt) ? " " : txt;
    }

    private static string LookupName(List<LookupItemMini> list, int? id)
    {
        if (!id.HasValue || id.Value <= 0 || list == null || list.Count == 0)
            return string.Empty;

        var it = list.FirstOrDefault(x => x.Id == id.Value);
        return it?.Name ?? string.Empty;
    }

    private string UserName(int? id)
    {
        if (!id.HasValue || id.Value <= 0 || _lookupUsers == null || _lookupUsers.Count == 0)
            return string.Empty;

        var u = _lookupUsers.FirstOrDefault(x => x.Id == id.Value);
        return u?.Display ?? string.Empty;
    }

