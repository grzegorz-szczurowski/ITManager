    private static async Task<int> InsertSystemAsync(SqlConnection con, SystemEditModel m)
    {
        var sql = @"
INSERT INTO dbo.systems
(
    name,
    db_name,
    server_name,
    short_description,

    system_type_id,
    system_scope_id,
    system_criticality_id,
    system_hosting_type_id,

    system_owner_id,
    data_owner_id,
    primary_administrator_id,
    secondary_administrator_id,

    last_backup_status,
    last_backup_date,
    backup_frequently,

    notes
)
OUTPUT INSERTED.id
VALUES
(
    @name,
    @db_name,
    @server_name,
    @short_description,

    @system_type_id,
    @system_scope_id,
    @system_criticality_id,
    @system_hosting_type_id,

    @system_owner_id,
    @data_owner_id,
    @primary_administrator_id,
    @secondary_administrator_id,

    @last_backup_status,
    @last_backup_date,
    @backup_frequently,

    @notes
);";

        using var cmd = new SqlCommand(sql, con) { CommandType = CommandType.Text, CommandTimeout = 25 };
        AddSystemParams(cmd, m, includeId: false);

        var obj = await cmd.ExecuteScalarAsync();
        if (obj == null || obj == DBNull.Value)
            return 0;

        return Convert.ToInt32(obj);
    }

