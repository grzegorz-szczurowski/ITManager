@code
{
    private const string PermLicensesView = "Assets.Licenses.View";
    private const string PermLicensesEdit = "Assets.Licenses.Edit";

    [Parameter] public int Id { get; set; }

    [SupplyParameterFromQuery] public string? returnUrl { get; set; }
    [SupplyParameterFromQuery] public int? readonlyMode { get; set; }

    private bool _ready;
    private bool _loading = true;

    private bool _isNew;
    private bool _isEditEnabled;

    private bool _isDirty;
    private string _originalJson = string.Empty;

    private bool _canView;
    private bool _canEdit;

    private string _errorMessage = string.Empty;

    private MudForm? _form;

    private LicenseUpdateModel _edit = new();
    private LicenseFilterLookups _lookups = new();

    private LookupItem? _typeSelected;
    private LookupItem? _statusSelected;
    private LookupItem? _producerSelected;
    private LookupItem? _modelSelected;
    private LookupItem? _userSelected;

    private Adornment LockAdornment => !_isEditEnabled ? Adornment.End : Adornment.None;
    private string? LockIcon => !_isEditEnabled ? Icons.Material.Filled.Lock : null;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _errorMessage = string.Empty;

        try
        {
            await CurrentUserContextService.EnsureInitializedAsync();

            var ctx = CurrentUserContextService.CurrentUser;
            var isAuth = ctx != null && ctx.IsAuthenticated && ctx.IsActive == true;
            var hasAccess = CurrentUserContextService.HasAccess;

            _canView = isAuth && hasAccess && CurrentUserContextService.Can(PermLicensesView);
            _canEdit = _canView && CurrentUserContextService.Can(PermLicensesEdit);

            _ready = true;

            if (!_canView)
                return;

            await LoadLookupsAsync();
            await LoadAsync();

            if (readonlyMode == 1)
            {
                _isEditEnabled = false;
                if (_canEdit)
                    Snackbar.Add("Tryb podglądu (readonly=1).", Severity.Info);
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private string BuildPageTitle()
        => _isNew ? L["NewTitle"] : L["License"];

    private async Task LoadLookupsAsync()
    {
        try
        {
            var res = await LicensesService.GetLicensesFilterLookupsAsync();
            if (!res.Ok)
            {
                _lookups = new LicenseFilterLookups();
                _errorMessage = res.ErrorMessage ?? L["LookupsLoadFailed"];
                return;
            }

            _lookups = res.Lookups ?? new LicenseFilterLookups();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[LicenseEdit] LoadLookupsAsync error.");
            _lookups = new LicenseFilterLookups();
            _errorMessage = L["LookupsLoadFailed"];
        }
    }

    private async Task LoadAsync()
    {
        _errorMessage = string.Empty;

        try
        {
            _isNew = Id <= 0;

            if (_isNew)
            {
                _edit = new LicenseUpdateModel { Id = 0 };
                _typeSelected = null;
                _statusSelected = null;
                _producerSelected = null;
                _modelSelected = null;
                _userSelected = null;

                Snapshot();

                _isEditEnabled = _canEdit;
                if (!_canEdit)
                    Snackbar.Add(L["NoEditPermission"], Severity.Warning);

                return;
            }

            var get = await LicensesService.GetLicenseByIdAsync(Id);

            if (!get.Ok)
            {
                _errorMessage = get.ErrorMessage ?? L["LoadFailed"];
                _edit = new LicenseUpdateModel();
                Snapshot();
                _isEditEnabled = false;
                return;
            }

            if (get.Row == null)
            {
                _errorMessage = string.Format(L["NotFoundFmt"], Id);
                _edit = new LicenseUpdateModel();
                Snapshot();
                _isEditEnabled = false;
                return;
            }

            _edit = new LicenseUpdateModel
            {
                Id = get.Row.Id,
                TypeId = get.Row.TypeId,
                StatusId = get.Row.StatusId,
                ProducerId = get.Row.ProducerId,
                ModelId = get.Row.ModelId,

                Name = get.Row.Name ?? string.Empty,
                InventoryNo = get.Row.InventoryNo ?? string.Empty,

                UserId = get.Row.UserId,
                UserName = get.Row.User ?? string.Empty,

                SubscriptionStarts = get.Row.SubscriptionStarts,
                SubscriptionEnds = get.Row.SubscriptionEnds,

                Note = get.Row.Note ?? string.Empty
            };

            _typeSelected = FindById(_lookups.Types, _edit.TypeId);
            _statusSelected = FindById(_lookups.Statuses, _edit.StatusId);
            _producerSelected = FindById(_lookups.Producers, _edit.ProducerId);
            _modelSelected = FindById(_lookups.Models, _edit.ModelId);
            _userSelected = FindById(_lookups.Users, _edit.UserId);

            Snapshot();
            _isEditEnabled = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[LicenseEdit] LoadAsync error. Id={Id}", Id);
            _errorMessage = L["LoadFailedTryLater"];
            _edit = new LicenseUpdateModel();
            Snapshot();
            _isEditEnabled = false;
        }
    }

    private void ToggleEditMode()
    {
        if (_loading || !_canEdit)
            return;

        _isEditEnabled = !_isEditEnabled;

        if (!_isEditEnabled)
            RevertChanges();
    }

    private string BuildTitle()
    {
        if (_isNew || _edit.Id <= 0)
            return L["NewTitle"];

        var name = Safe(_edit.Name);
        if (!string.IsNullOrWhiteSpace(name))
            return name;

        var inv = Safe(_edit.InventoryNo);
        if (!string.IsNullOrWhiteSpace(inv))
            return $"{L["License"]} {inv}";

        return L["License"];
    }

    private string BuildSubtitle()
    {
        var parts = new List<string>();

        var producer = Safe(SelectedProducerName());
        var model = Safe(SelectedModelName());
        var user = Safe(SelectedUserName());

        var left = string.Join(" ", new[] { producer, model }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        if (!string.IsNullOrWhiteSpace(left))
            parts.Add(left);

        if (!string.IsNullOrWhiteSpace(user))
            parts.Add(string.Format(L["SubtitleUserFmt"], user));

        if (parts.Count == 0)
            return L["SubtitleDefault"];

        return string.Join(" | ", parts);
    }

    private Color GetStatusColor(string? status)
    {
        var s = (status ?? string.Empty).Trim();

        if (s.Equals("Active", StringComparison.OrdinalIgnoreCase))
            return Color.Success;

        if (s.Equals("Expired", StringComparison.OrdinalIgnoreCase))
            return Color.Error;

        return Color.Default;
    }

    private void Snapshot()
    {
        var snap = new SnapshotModel
        {
            Edit = _edit ?? new LicenseUpdateModel(),
            TypeSelectedId = _typeSelected?.Id,
            StatusSelectedId = _statusSelected?.Id,
            ProducerSelectedId = _producerSelected?.Id,
            ModelSelectedId = _modelSelected?.Id,
            UserSelectedId = _userSelected?.Id
        };

        _originalJson = JsonSerializer.Serialize(snap, new JsonSerializerOptions
        {
            WriteIndented = false,
            PropertyNamingPolicy = null
        });

        _isDirty = false;
    }

    private void MarkDirty()
    {
        if (string.IsNullOrWhiteSpace(_originalJson))
        {
            _isDirty = true;
            return;
        }

        var snap = new SnapshotModel
        {
            Edit = _edit ?? new LicenseUpdateModel(),
            TypeSelectedId = _typeSelected?.Id,
            StatusSelectedId = _statusSelected?.Id,
            ProducerSelectedId = _producerSelected?.Id,
            ModelSelectedId = _modelSelected?.Id,
            UserSelectedId = _userSelected?.Id
        };

        var current = JsonSerializer.Serialize(snap, new JsonSerializerOptions
        {
            WriteIndented = false,
            PropertyNamingPolicy = null
        });

        _isDirty = !string.Equals(_originalJson, current, StringComparison.Ordinal);
    }

    private void SetEditString(Action<string> setter, string? value)
    {
        setter(value ?? string.Empty);
        MarkDirty();
    }

    private void SetEditDate(Action<DateTime?> setter, DateTime? value)
    {
        setter(value);
        MarkDirty();
    }

    private void RevertChanges()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_originalJson))
                return;

            var restored = JsonSerializer.Deserialize<SnapshotModel>(_originalJson);
            if (restored == null)
                return;

            _edit = restored.Edit ?? new LicenseUpdateModel();

            _typeSelected = FindById(_lookups.Types, restored.TypeSelectedId);
            _statusSelected = FindById(_lookups.Statuses, restored.StatusSelectedId);
            _producerSelected = FindById(_lookups.Producers, restored.ProducerSelectedId);
            _modelSelected = FindById(_lookups.Models, restored.ModelSelectedId);
            _userSelected = FindById(_lookups.Users, restored.UserSelectedId);

            _isDirty = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[LicenseEdit] RevertChanges error.");
            Snackbar.Add(L["RevertFailed"], Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        if (!_canView || !_canEdit)
        {
            Snackbar.Add(L["NoEditPermission"], Severity.Warning);
            return;
        }

        if (!_isEditEnabled || _loading || !_isDirty)
            return;

        _loading = true;

        try
        {
            if (_form != null)
                await _form.Validate();

            var payload = new LicenseUpdateModel
            {
                Id = _isNew ? 0 : _edit.Id,

                TypeId = _typeSelected?.Id,
                StatusId = _statusSelected?.Id,
                ProducerId = _producerSelected?.Id,
                ModelId = _modelSelected?.Id,

                Name = Safe(_edit.Name),
                InventoryNo = Safe(_edit.InventoryNo),

                UserId = _userSelected?.Id,
                UserName = Safe(_userSelected?.Name),

                SubscriptionStarts = _edit.SubscriptionStarts,
                SubscriptionEnds = _edit.SubscriptionEnds,

                Note = _edit.Note ?? string.Empty
            };

            if (_isNew || payload.Id <= 0)
            {
                var created = await LicensesService.CreateLicenseAsync(payload);
                if (!created.Ok)
                {
                    Snackbar.Add(created.ErrorMessage ?? L["SaveFailed"], Severity.Error);
                    return;
                }

                Snackbar.Add(L["Saved"], Severity.Success);
                _isDirty = false;
                NavigateBack();
                return;
            }

            var updated = await LicensesService.UpdateLicenseAsync(payload);
            if (!updated.Ok)
            {
                Snackbar.Add(updated.ErrorMessage ?? L["SaveFailed"], Severity.Error);
                return;
            }

            Snackbar.Add(L["Saved"], Severity.Success);
            _isDirty = false;
            NavigateBack();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[LicenseEdit] SaveAsync error. Id={Id}", Id);
            Snackbar.Add(L["SaveError"], Severity.Error);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task BackAsync()
    {
        if (_loading)
            return;

        if (_isEditEnabled && _isDirty)
        {
            var discard = await DialogService.ShowMessageBox(
                title: L["UnsavedTitle"],
                message: L["UnsavedMessage"],
                yesText: L["DiscardAndClose"],
                cancelText: L["Stay"]
            );

            if (discard != true)
                return;
        }

        NavigateBack();
    }

    private void NavigateBack()
    {
        var target = Safe(returnUrl);
        if (!string.IsNullOrWhiteSpace(target))
        {
            NavigationManager.NavigateTo(target);
            return;
        }

        NavigationManager.NavigateTo("/assets/licenses");
    }

    private async Task CopyToClipboardAsync(string? value, string label)
    {
        var v = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(v))
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", v);
            Snackbar.Add(string.Format(L["CopiedFmt"], label), Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[LicenseEdit] CopyToClipboardAsync failed.");
            Snackbar.Add(L["CopyFailed"], Severity.Error);
        }
    }

    private static Task<IEnumerable<LookupItem>> SearchLookupAsync(List<LookupItem> options, string? search, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();

        var list = options ?? new List<LookupItem>();
        var s = (search ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(s))
            return Task.FromResult<IEnumerable<LookupItem>>(list);

        var filtered = list
            .Where(x => x != null && !string.IsNullOrWhiteSpace(x.Name) && x.Name.Contains(s, StringComparison.OrdinalIgnoreCase))
            .ToList();

        return Task.FromResult<IEnumerable<LookupItem>>(filtered);
    }

    private void OnTypeChanged(LookupItem? v)
    {
        _typeSelected = v;
        MarkDirty();
    }

    private void OnStatusChanged(LookupItem? v)
    {
        _statusSelected = v;
        MarkDirty();
    }

    private void OnProducerChanged(LookupItem? v)
    {
        _producerSelected = v;
        MarkDirty();
    }

    private void OnModelChanged(LookupItem? v)
    {
        _modelSelected = v;
        MarkDirty();
    }

    private void OnUserChanged(LookupItem? v)
    {
        _userSelected = v;
        MarkDirty();
    }

    private static LookupItem? FindById(List<LookupItem> list, int? id)
    {
        if (id == null || id.Value <= 0)
            return null;

        return (list ?? new List<LookupItem>()).FirstOrDefault(x => x != null && x.Id == id.Value);
    }

    private string SelectedTypeName() => _typeSelected?.Name ?? string.Empty;
    private string SelectedStatusName() => _statusSelected?.Name ?? string.Empty;
    private string SelectedProducerName() => _producerSelected?.Name ?? string.Empty;
    private string SelectedModelName() => _modelSelected?.Name ?? string.Empty;

    private string SelectedUserName()
    {
        if (_userSelected != null && !string.IsNullOrWhiteSpace(_userSelected.Name))
            return _userSelected.Name;

        return Safe(_edit.UserName);
    }

    private static string Safe(string? value, string fallback = "")
    {
        var v = (value ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(v) ? fallback : v;
    }

    private sealed class SnapshotModel
    {
        public LicenseUpdateModel? Edit { get; set; }

        public int? TypeSelectedId { get; set; }
        public int? StatusSelectedId { get; set; }
        public int? ProducerSelectedId { get; set; }
        public int? ModelSelectedId { get; set; }
        public int? UserSelectedId { get; set; }
    }
}
