@page "/assets/licenses/edit/{Id:int}"
@page "/assets/licenses/create"
@namespace ITManager.Components.Pages.Assets.Licenses
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Perm:Assets.Licenses.View")]

@* File: Components/Pages/Assets/Licenses/LicenseEdit.razor
   Description: Ekran (page) dodawania i edycji licencji, bazujący na LicenseEditDialog, ale bez modala.
                UX:
                  - Summary header + tabs ze scrollem
                  - Dla istniejących: start w trybie read-only, Enable edit odblokowuje edycję
                  - Dla nowych: start w trybie edycji (jeśli user ma Edit)
                  - Kłódka na polach read-only
                  - Lookupy jako MudAutocomplete (LookupItem) z wyszukiwaniem
   Version: 1.01
   Updated: 2026-02-08
   Notes:
     - Uprawnienia: Assets.Licenses.View, Assets.Licenses.Edit
     - Pracujemy na *_Id + UserName, zgodnie z LicensesService
   Change log:
     - 1.01 (2026-02-08) UI: usunięty Back. Przeniesione: Enable edit na dół po lewej, Save na dół po prawej.
*@

@using System
@using System.Linq
@using System.Threading
@using System.Threading.Tasks
@using System.Collections.Generic
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@using MudBlazor
@using ITManager.Models
@using ITManager.Services.Auth

@inject LicensesService LicensesService
@inject CurrentUserContextService CurrentUserContextService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<LicenseEdit> L
@inject IJSRuntime JS
@inject ILogger<LicenseEdit> Logger

<MudPaper Class="pa-4 license-edit-root" Elevation="0">

    <MudStack Spacing="2">

        @if (!_ready)
        {
            <MudProgressCircular Size="Size.Large" Class="mx-auto" />
        }
        else if (!_canView)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                @L["NoViewPermission"]
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
                    @_errorMessage
                </MudAlert>
            }

            <div class="license-page-container">

                @if (_loading)
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="license-page-loading">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1" Class="mt-2">@L["Loading"]</MudText>
                    </MudStack>
                }
                else
                {
                    <MudPaper Elevation="0" Class="license-summary">
                        <MudStack Spacing="1">

                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="license-summary-top">
                                <MudText Typo="Typo.h6" Class="license-summary-title">
                                    @BuildTitle()
                                </MudText>

                                @if (!string.IsNullOrWhiteSpace(Safe(SelectedTypeName())))
                                {
                                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Class="ml-2">
                                        @Safe(SelectedTypeName())
                                    </MudChip>
                                }

                                @if (!string.IsNullOrWhiteSpace(Safe(SelectedStatusName())))
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@GetStatusColor(SelectedStatusName())" Class="ml-2">
                                        @Safe(SelectedStatusName())
                                    </MudChip>
                                }

                                <MudSpacer />

                                @if (!_canEdit)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Default">
                                        @L["NoEditPermission"]
                                    </MudChip>
                                }
                            </MudStack>

                            <MudText Typo="Typo.body2" Class="license-summary-subtitle">
                                @BuildSubtitle()
                            </MudText>

                            <MudGrid Spacing="1" AlignItems="AlignItems.Center" Class="license-summary-grid">

                                <MudItem xs="12" sm="6" md="6" Class="license-summary-cell">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="license-summary-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                                        <MudText Typo="Typo.body2">
                                            <b>@L["Fields.InventoryNo"]</b> <span class="license-mono">@Safe(_edit.InventoryNo, "-")</span>
                                        </MudText>

                                        <MudTooltip Text="@L["CopyInventoryNo"]">
                                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                           Size="Size.Medium"
                                                           Color="Color.Default"
                                                           Variant="Variant.Text"
                                                           Disabled="@string.IsNullOrWhiteSpace(Safe(_edit.InventoryNo))"
                                                           Class="ml-1"
                                                           OnClick="@(() => CopyToClipboardAsync(_edit.InventoryNo, L["Fields.InventoryNo"]))" />
                                        </MudTooltip>
                                    </MudStack>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="6" Class="license-summary-cell">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="license-summary-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                        <MudText Typo="Typo.body2">
                                            <b>@L["Fields.User"]</b> @Safe(SelectedUserName(), "-")
                                        </MudText>
                                    </MudStack>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="6" Class="license-summary-cell">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="license-summary-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Factory" Size="Size.Small" />
                                        <MudText Typo="Typo.body2">
                                            <b>@L["Fields.Producer"]</b> @Safe(SelectedProducerName(), "-")
                                        </MudText>
                                    </MudStack>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="6" Class="license-summary-cell">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="license-summary-item">
                                        <MudIcon Icon="@Icons.Material.Filled.ViewInAr" Size="Size.Small" />
                                        <MudText Typo="Typo.body2">
                                            <b>@L["Fields.Model"]</b> @Safe(SelectedModelName(), "-")
                                        </MudText>
                                    </MudStack>
                                </MudItem>

                            </MudGrid>

                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="license-tabs">
                        <MudTabs Rounded="true" Elevation="0" KeepPanelsAlive="true">

                            <MudTabPanel Text="@L["Tabs.General"]">
                                <div class="license-tab-scroll">
                                    <MudForm @ref="_form">
                                        <MudGrid Spacing="2">

                                            <MudItem xs="12" md="4">
                                                @if (_isEditEnabled)
                                                {
                                                    <MudAutocomplete T="LookupItem"
                                                                     Label="@L["Fields.Type"]"
                                                                     Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense"
                                                                     Dense="true"
                                                                     Disabled="@(_loading || !_canEdit)"
                                                                     Clearable="true"
                                                                     ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                                     Value="@_typeSelected"
                                                                     ValueChanged="OnTypeChanged"
                                                                     SearchFunc="@((string s, CancellationToken ct) => SearchLookupAsync(_lookups.Types, s, ct))"
                                                                     DebounceInterval="150"
                                                                     ResetValueOnEmptyText="true" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Label="@L["Fields.Type"]"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  ReadOnly="true"
                                                                  Value="@Safe(SelectedTypeName(), "-")"
                                                                  Adornment="@LockAdornment"
                                                                  AdornmentIcon="@LockIcon"
                                                                  AdornmentColor="Color.Default" />
                                                }
                                            </MudItem>

                                            <MudItem xs="12" md="4">
                                                @if (_isEditEnabled)
                                                {
                                                    <MudAutocomplete T="LookupItem"
                                                                     Label="@L["Fields.Status"]"
                                                                     Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense"
                                                                     Dense="true"
                                                                     Disabled="@(_loading || !_canEdit)"
                                                                     Clearable="true"
                                                                     ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                                     Value="@_statusSelected"
                                                                     ValueChanged="OnStatusChanged"
                                                                     SearchFunc="@((string s, CancellationToken ct) => SearchLookupAsync(_lookups.Statuses, s, ct))"
                                                                     DebounceInterval="150"
                                                                     ResetValueOnEmptyText="true" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Label="@L["Fields.Status"]"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  ReadOnly="true"
                                                                  Value="@Safe(SelectedStatusName(), "-")"
                                                                  Adornment="@LockAdornment"
                                                                  AdornmentIcon="@LockIcon"
                                                                  AdornmentColor="Color.Default" />
                                                }
                                            </MudItem>

                                            <MudItem xs="12" md="4">
                                                @if (_isEditEnabled)
                                                {
                                                    <MudAutocomplete T="LookupItem"
                                                                     Label="@L["Fields.User"]"
                                                                     Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense"
                                                                     Dense="true"
                                                                     Disabled="@(_loading || !_canEdit)"
                                                                     Clearable="true"
                                                                     ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                                     Value="@_userSelected"
                                                                     ValueChanged="OnUserChanged"
                                                                     SearchFunc="@((string s, CancellationToken ct) => SearchLookupAsync(_lookups.Users, s, ct))"
                                                                     DebounceInterval="150"
                                                                     ResetValueOnEmptyText="true" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Label="@L["Fields.User"]"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  ReadOnly="true"
                                                                  Value="@Safe(SelectedUserName(), "-")"
                                                                  Adornment="@LockAdornment"
                                                                  AdornmentIcon="@LockIcon"
                                                                  AdornmentColor="Color.Default" />
                                                }
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                @if (_isEditEnabled)
                                                {
                                                    <MudAutocomplete T="LookupItem"
                                                                     Label="@L["Fields.Producer"]"
                                                                     Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense"
                                                                     Dense="true"
                                                                     Disabled="@(_loading || !_canEdit)"
                                                                     Clearable="true"
                                                                     ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                                     Value="@_producerSelected"
                                                                     ValueChanged="OnProducerChanged"
                                                                     SearchFunc="@((string s, CancellationToken ct) => SearchLookupAsync(_lookups.Producers, s, ct))"
                                                                     DebounceInterval="150"
                                                                     ResetValueOnEmptyText="true" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Label="@L["Fields.Producer"]"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  ReadOnly="true"
                                                                  Value="@Safe(SelectedProducerName(), "-")"
                                                                  Adornment="@LockAdornment"
                                                                  AdornmentIcon="@LockIcon"
                                                                  AdornmentColor="Color.Default" />
                                                }
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                @if (_isEditEnabled)
                                                {
                                                    <MudAutocomplete T="LookupItem"
                                                                     Label="@L["Fields.Model"]"
                                                                     Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense"
                                                                     Dense="true"
                                                                     Disabled="@(_loading || !_canEdit)"
                                                                     Clearable="true"
                                                                     ToStringFunc="@(x => x?.Name ?? string.Empty)"
                                                                     Value="@_modelSelected"
                                                                     ValueChanged="OnModelChanged"
                                                                     SearchFunc="@((string s, CancellationToken ct) => SearchLookupAsync(_lookups.Models, s, ct))"
                                                                     DebounceInterval="150"
                                                                     ResetValueOnEmptyText="true" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Label="@L["Fields.Model"]"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  ReadOnly="true"
                                                                  Value="@Safe(SelectedModelName(), "-")"
                                                                  Adornment="@LockAdornment"
                                                                  AdornmentIcon="@LockIcon"
                                                                  AdornmentColor="Color.Default" />
                                                }
                                            </MudItem>

                                        </MudGrid>
                                    </MudForm>
                                </div>
                            </MudTabPanel>

                            <MudTabPanel Text="@L["Tabs.Subscription"]">
                                <div class="license-tab-scroll">
                                    <MudGrid Spacing="2">

                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="@L["Fields.SubscriptionStart"]"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Disabled="@_loading"
                                                           ReadOnly="@(!_isEditEnabled || !_canEdit)"
                                                           Date="@_edit.SubscriptionStarts"
                                                           DateChanged="d => SetEditDate(v => _edit.SubscriptionStarts = v, d)"
                                                           Adornment="@LockAdornment"
                                                           AdornmentIcon="@LockIcon"
                                                           AdornmentColor="Color.Default" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="@L["Fields.SubscriptionEnd"]"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Disabled="@_loading"
                                                           ReadOnly="@(!_isEditEnabled || !_canEdit)"
                                                           Date="@_edit.SubscriptionEnds"
                                                           DateChanged="d => SetEditDate(v => _edit.SubscriptionEnds = v, d)"
                                                           Adornment="@LockAdornment"
                                                           AdornmentIcon="@LockIcon"
                                                           AdornmentColor="Color.Default" />
                                        </MudItem>

                                    </MudGrid>
                                </div>
                            </MudTabPanel>

                            <MudTabPanel Text="@L["Tabs.Details"]">
                                <div class="license-tab-scroll">
                                    <MudGrid Spacing="2">

                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="@L["Fields.Name"]"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="@(!_isEditEnabled || !_canEdit)"
                                                          Disabled="@_loading"
                                                          Value="@_edit.Name"
                                                          ValueChanged="v => SetEditString(x => _edit.Name = x, v)"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="@L["Fields.InventoryNo"]"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="@(!_isEditEnabled || !_canEdit)"
                                                          Disabled="@_loading"
                                                          Value="@_edit.InventoryNo"
                                                          ValueChanged="v => SetEditString(x => _edit.InventoryNo = x, v)"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        </MudItem>

                                        <MudItem xs="12">
                                            <MudTextField T="string"
                                                          Label="@L["Fields.Note"]"
                                                          Lines="10"
                                                          AutoGrow="false"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          ReadOnly="@(!_isEditEnabled || !_canEdit)"
                                                          Disabled="@_loading"
                                                          Value="@_edit.Note"
                                                          ValueChanged="v => SetEditString(x => _edit.Note = x, v)"
                                                          Adornment="@LockAdornment"
                                                          AdornmentIcon="@LockIcon"
                                                          AdornmentColor="Color.Default" />
                                        </MudItem>

                                    </MudGrid>
                                </div>
                            </MudTabPanel>

                        </MudTabs>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="license-footer">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="license-footer-inner">

                            <MudButton Variant="Variant.Outlined"
                                       Color="@(_isEditEnabled ? Color.Default : Color.Primary)"
                                       StartIcon="@(_isEditEnabled ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                                       OnClick="ToggleEditMode"
                                       Disabled="@(_loading || !_canEdit || !_canView)">
                                @(_isEditEnabled? L["Lock"] : L["EnableEdit"])
                            </MudButton>

                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="SaveAsync"
                                           Disabled="@(!_isEditEnabled || _loading || !_isDirty || !_canEdit || !_canView)">
                                    @L["Save"]
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Close"
                                           OnClick="BackAsync"
                                           Disabled="@_loading">
                                    @L["Close"]
                                </MudButton>
                            </MudStack>

                        </MudStack>
                    </MudPaper>
                }

            </div>
        }

    </MudStack>

</MudPaper>

