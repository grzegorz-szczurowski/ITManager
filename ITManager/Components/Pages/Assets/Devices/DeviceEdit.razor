@page "/assets/devices/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Perm:Assets.Devices.View")]

@namespace ITManager.Components.Pages.Assets.Devices

@* File: Components/Pages/Assets/Devices/DeviceEdit.razor
   Description: Strona szczegółów urządzenia (bez okna dialogowego). Układ i logika jak wcześniej w DeviceEditDialog.
                Start w trybie read-only, przycisk Enable edit odblokowuje edycję.
                Create mode: Id=0.
   Version: 1.02
   Created: 2026-02-08
   Change log:
   - 1.00 (2026-02-08) Migracja z DeviceEditDialog do strony. Rezygnacja z okien dialogowych, zamknięcie przez nawigację.
   - 1.01 (2026-02-08) Confirm przy wyjściu bez snackbar callback. Mały dialog: Zapisz, Odrzuć, Zostań.
   - 1.02 (2026-02-08) UI: usunięty przycisk Back. Przeniesione: Enable edit na dół po lewej, Save/Close na dół po prawej.
*@

@using System
@using System.Collections.Generic
@using System.Globalization
@using System.Linq
@using System.Reflection
@using System.Text.Json
@using System.Threading
@using System.Threading.Tasks
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using MudBlazor
@using ITManager.Models
@using ITManager.Services
@using ITManager.Services.Auth

@inject DevicesService DevicesService
@inject CurrentUserContextService CurrentUserContextService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer<DeviceEdit> L

<MudPaper Class="pa-4 device-edit-root" Elevation="0">

    <MudStack Spacing="2">

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
                @_errorMessage
            </MudAlert>
        }

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:520px;">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.subtitle1" Class="mt-2">@L["LoadingData"]</MudText>
            </MudStack>
        }
        else
        {
            <MudPaper Elevation="0" Class="device-summary">
                <MudStack Spacing="1">

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="device-summary-top">
                        <MudText Typo="Typo.h6" Class="device-summary-title">
                            @GetSafe(_edit.Hostname, fallback: L["Fallback.DeviceTitle"])
                        </MudText>

                        @if (!string.IsNullOrWhiteSpace(GetSafe(_edit.Kind)))
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Class="ml-2">
                                @GetSafe(_edit.Kind)
                            </MudChip>
                        }

                        @if (!string.IsNullOrWhiteSpace(GetSafe(_edit.Status)))
                        {
                            <MudChip T="string"
                                     Variant="Variant.Outlined"
                                     Color="@GetStatusChipColor(_edit.Status)"
                                     Class="ml-2">
                                @GetSafe(_edit.Status)
                            </MudChip>
                        }

                        <MudSpacer />

                        @if (_edit.WarrantyEnds.HasValue)
                        {
                            <MudStack Row="true"
                                      AlignItems="AlignItems.Center"
                                      Spacing="1"
                                      Class="device-summary-warranty">
                                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="@GetWarrantyTextColor()">
                                    @BuildWarrantyEndsInfo()
                                </MudText>
                            </MudStack>
                        }
                    </MudStack>

                    <MudText Typo="Typo.body2" Class="device-summary-subtitle">
                        @BuildDeviceSubtitle()
                    </MudText>

                    <MudGrid Spacing="1" AlignItems="AlignItems.Center" Class="device-summary-grid">

                        <MudItem xs="12" sm="6" md="6" Class="device-summary-cell">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="device-summary-item">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                <MudText Typo="Typo.body2">
                                    <b>@L["Summary.User"]:</b> @GetSafe(_edit.User, L["Common.Dash"])
                                </MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="6" Class="device-summary-cell">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="device-summary-item">
                                <MudIcon Icon="@Icons.Material.Filled.Router" Size="Size.Small" />
                                <MudText Typo="Typo.body2">
                                    <b>@L["Summary.IP"]:</b> <span class="device-mono">@GetSafe(_edit.IpAddress, L["Common.Dash"])</span>
                                </MudText>

                                <MudTooltip Text="@L["Tooltip.CopyIP"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Size="Size.Medium"
                                                   Color="Color.Default"
                                                   Variant="Variant.Text"
                                                   Disabled="@string.IsNullOrWhiteSpace(GetSafe(_edit.IpAddress))"
                                                   Class="ml-1"
                                                   OnClick="@(() => CopyToClipboardAsync(_edit.IpAddress, L["Label.IP"]))" />
                                </MudTooltip>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="6" Class="device-summary-cell">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="device-summary-item">
                                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                                <MudText Typo="Typo.body2">
                                    <b>@L["Summary.Location"]:</b> @GetSafe(_edit.Location, L["Common.Dash"])
                                </MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="6" Class="device-summary-cell">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="device-summary-item">
                                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Size="Size.Small" />
                                <MudText Typo="Typo.body2">
                                    <b>@L["Summary.AssetNo"]:</b> <span class="device-mono">@GetSafe(_edit.AssetNo, L["Common.Dash"])</span>
                                </MudText>

                                <MudTooltip Text="@L["Tooltip.CopyAssetNo"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Size="Size.Medium"
                                                   Color="Color.Default"
                                                   Variant="Variant.Text"
                                                   Disabled="@string.IsNullOrWhiteSpace(GetSafe(_edit.AssetNo))"
                                                   Class="ml-1"
                                                   OnClick="@(() => CopyToClipboardAsync(_edit.AssetNo, L["Label.AssetNo"]))" />
                                </MudTooltip>
                            </MudStack>
                        </MudItem>

                    </MudGrid>

                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="device-tabs">
                <MudTabs Rounded="true" Elevation="0" KeepPanelsAlive="true">

                    <MudTabPanel Text="@L["Tab.General"]">
                        <div class="device-tab-scroll">
                            <MudGrid Spacing="2">

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.Type"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.Type"
                                                         ValueChanged="v => SetEditString(x => _edit.Type = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_typeOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.Type"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.Type, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.Kind"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.Kind"
                                                         ValueChanged="v => SetEditString(x => _edit.Kind = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_kindOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.Kind"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.Kind, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.Status"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.Status"
                                                         ValueChanged="v => SetEditString(x => _edit.Status = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_statusOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.Status"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.Status, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.Producer"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.Producer"
                                                         ValueChanged="v => SetEditString(x => _edit.Producer = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_producerOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.Producer"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.Producer, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.Model"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.Model"
                                                         ValueChanged="v => SetEditString(x => _edit.Model = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_modelOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.Model"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.Model, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.SerialNumber"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.SerialNumber"
                                                  ValueChanged="v => SetEditString(x => _edit.SerialNumber = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                            </MudGrid>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="@L["Tab.Network"]">
                        <div class="device-tab-scroll">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.Hostname"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.Hostname"
                                                  ValueChanged="v => SetEditString(x => _edit.Hostname = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.IPAddress"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.IpAddress"
                                                  ValueChanged="v => SetEditString(x => _edit.IpAddress = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.MacEthernet"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.MacEthernet"
                                                  ValueChanged="v => SetEditString(x => _edit.MacEthernet = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.MacWlan"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.MacWlan"
                                                  ValueChanged="v => SetEditString(x => _edit.MacWlan = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.IMEI1"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.Imei1"
                                                  ValueChanged="v => SetEditString(x => _edit.Imei1 = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.IMEI2"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.Imei2"
                                                  ValueChanged="v => SetEditString(x => _edit.Imei2 = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>
                            </MudGrid>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="@L["Tab.UserLocation"]">
                        <div class="device-tab-scroll">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.User"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.User"
                                                         ValueChanged="v => SetEditString(x => _edit.User = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_userOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.User"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.User, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    @if (_isEditEnabled)
                                    {
                                        <MudAutocomplete T="string"
                                                         Label="@L["Field.Location"]"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@_loading"
                                                         Clearable="true"
                                                         Value="@_edit.Location"
                                                         ValueChanged="v => SetEditString(x => _edit.Location = x, v)"
                                                         SearchFunc="@( (string s, CancellationToken ct) => SearchInOptionsAsync(_locationOptions, s, ct) )"
                                                         DebounceInterval="150"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         MaxItems="@((int?)null)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.Location"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@GetSafe(_edit.Location, L["Common.Dash"])"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>
                            </MudGrid>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="@L["Tab.Warranty"]">
                        <div class="device-tab-scroll">
                            <MudGrid Spacing="2">

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudDatePicker Label="@L["Field.WarrantyStart"]"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Disabled="@_loading"
                                                       Date="_edit.WarrantyStarts"
                                                       DateChanged="d => SetEditDate(x => _edit.WarrantyStarts = x, d)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.WarrantyStart"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@FormatDate(_edit.WarrantyStarts)"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    @if (_isEditEnabled)
                                    {
                                        <MudDatePicker Label="@L["Field.WarrantyEnd"]"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Disabled="@_loading"
                                                       Date="_edit.WarrantyEnds"
                                                       DateChanged="d => SetEditDate(x => _edit.WarrantyEnds = x, d)" />
                                    }
                                    else
                                    {
                                        <MudTextField T="string"
                                                      Label="@L["Field.WarrantyEnd"]"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="true"
                                                      Value="@FormatDate(_edit.WarrantyEnds)"
                                                      Adornment="@LockAdornment"
                                                      AdornmentIcon="@LockIcon"
                                                      AdornmentColor="Color.Default" />
                                    }
                                </MudItem>

                            </MudGrid>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="@L["Tab.Assets"]">
                        <div class="device-tab-scroll">
                            <MudGrid Spacing="2">

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.InventoryNo"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.InventoryNo"
                                                  ValueChanged="v => SetEditString(x => _edit.InventoryNo = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  Label="@L["Field.AssetNo"]"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="@(!_isEditEnabled)"
                                                  Disabled="@_loading"
                                                  Value="@_edit.AssetNo"
                                                  ValueChanged="v => SetEditString(x => _edit.AssetNo = x, v)"
                                                  Adornment="@LockAdornment"
                                                  AdornmentIcon="@LockIcon"
                                                  AdornmentColor="Color.Default" />
                                </MudItem>

                            </MudGrid>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="@L["Tab.Note"]">
                        <div class="device-tab-scroll">
                            <MudTextField T="string"
                                          Label="@L["Field.Note"]"
                                          Lines="16"
                                          AutoGrow="false"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          ReadOnly="@(!_isEditEnabled)"
                                          Disabled="@_loading"
                                          Value="@_edit.Note"
                                          ValueChanged="v => SetEditString(x => _edit.Note = x, v)"
                                          Adornment="@LockAdornment"
                                          AdornmentIcon="@LockIcon"
                                          AdornmentColor="Color.Default" />
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="@L["Tab.History"]">
                        <div class="device-tab-scroll">
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                @L["History.NotImplemented"]
                            </MudAlert>
                        </div>
                    </MudTabPanel>

                </MudTabs>
            </MudPaper>

            <MudPaper Elevation="0" Class="device-footer">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="device-footer-inner">

                    <MudButton Variant="Variant.Outlined"
                               Color="@(_isEditEnabled ? Color.Default : Color.Primary)"
                               StartIcon="@(_isEditEnabled ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                               OnClick="ToggleEditMode"
                               Disabled="@(_loading || !_canEnableEdit)">
                        @(_isEditEnabled? L["Action.Lock"] : L["Action.EnableEdit"])
                    </MudButton>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SaveAsync"
                                   Disabled="@(!_isEditEnabled || _loading || !_isDirty || !_canSave)">
                            @L["Action.Save"]
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="RequestCancelAsync"
                                   Disabled="@_loading">
                            @L["Action.Close"]
                        </MudButton>
                    </MudStack>

                </MudStack>
            </MudPaper>
        }

    </MudStack>

</MudPaper>

