@code
{
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private bool _isNew;
    private bool _isEditEnabled;

    private bool _isDirty;
    private string _originalEditJson = string.Empty;

    private string _errorMessage = string.Empty;

    private bool _canView;
    private bool _canEdit;
    private bool _canCreate;

    private bool _canEnableEdit;
    private bool _canSave;

    private DeviceListRow? _device;
    private DeviceUpdateModel _edit = new();

    private List<string> _typeOptions = new();
    private List<string> _kindOptions = new();
    private List<string> _statusOptions = new();
    private List<string> _producerOptions = new();
    private List<string> _modelOptions = new();
    private List<string> _userOptions = new();
    private List<string> _locationOptions = new();

    private Adornment LockAdornment => !_isEditEnabled ? Adornment.End : Adornment.None;
    private string? LockIcon => !_isEditEnabled ? Icons.Material.Filled.Lock : null;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUserContextService.EnsureInitializedAsync();

        var ctx = CurrentUserContextService.CurrentUser;
        var isAuth = ctx != null && ctx.IsAuthenticated && ctx.IsActive == true;
        var hasAccess = CurrentUserContextService.HasAccess;

        _canView = isAuth && hasAccess && CurrentUserContextService.Can("Assets.Devices.View");
        _canEdit = _canView && CurrentUserContextService.Can("Assets.Devices.Edit");
        _canCreate = _canView && CurrentUserContextService.Can("Assets.Devices.Create");

        _isNew = Id <= 0;

        _canEnableEdit = _isNew ? _canCreate : _canEdit;
        _canSave = _canEnableEdit;

        _loading = true;
        _errorMessage = string.Empty;

        try
        {
            await LoadLookupsAsync();
            await LoadAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private string BuildPageTitle()
    {
        if (_isNew)
            return L["Title.NewDevice"];

        var host = GetSafe(_edit.Hostname);
        return string.IsNullOrWhiteSpace(host) ? L["Title.Device"] : host;
    }

    private void ToggleEditMode()
    {
        if (_loading || !_canEnableEdit)
            return;

        _isEditEnabled = !_isEditEnabled;

        if (!_isEditEnabled)
            RevertChanges();
    }

    private string BuildDeviceSubtitle()
    {
        var producer = GetSafe(_edit.Producer);
        var model = GetSafe(_edit.Model);
        var sn = GetSafe(_edit.SerialNumber, L["Common.Dash"]);

        var left = string.Join(" ", new[] { producer, model }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        if (string.IsNullOrWhiteSpace(left))
            left = L["Fallback.DeviceTitle"];

        return string.Format(CultureInfo.CurrentCulture, L["Subtitle.Format"], left, sn);
    }

    private Color GetStatusChipColor(string? status)
    {
        var s = (status ?? string.Empty).Trim();
        if (s.Equals("Active", StringComparison.OrdinalIgnoreCase))
            return Color.Success;

        return Color.Default;
    }

    private string BuildWarrantyEndsInfo()
    {
        if (!_edit.WarrantyEnds.HasValue)
            return string.Empty;

        var end = _edit.WarrantyEnds.Value.Date;
        var today = DateTime.Today;
        var days = (end - today).Days;

        if (days >= 0)
            return string.Format(CultureInfo.CurrentCulture, L["Warranty.Ends.Format"], end, days);

        return string.Format(CultureInfo.CurrentCulture, L["Warranty.Ended.Format"], end, Math.Abs(days));
    }

    private Color GetWarrantyTextColor()
    {
        if (!_edit.WarrantyEnds.HasValue)
            return Color.Default;

        var end = _edit.WarrantyEnds.Value.Date;
        var days = (end - DateTime.Today).Days;

        if (days < 0)
            return Color.Error;

        if (days <= 30)
            return Color.Warning;

        return Color.Default;
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var result = await DevicesService.GetDevicesFilterLookupsAsync();
            if (!result.Ok)
            {
                ClearOptions();
                _errorMessage = result.ErrorMessage ?? L["Error.Lookups.LoadFailed"];
                return;
            }

            var lookups = result.Lookups ?? new DeviceFilterLookups();

            _typeOptions = NormalizeLookupList(lookups.Types);
            _kindOptions = NormalizeLookupList(lookups.Kinds);
            _statusOptions = NormalizeLookupList(lookups.Statuses);
            _producerOptions = NormalizeLookupList(lookups.Producers);
            _modelOptions = NormalizeLookupList(lookups.Models);
            _locationOptions = NormalizeLookupList(lookups.Locations);
            _userOptions = NormalizeLookupList(lookups.Users);
        }
        catch
        {
            ClearOptions();
            _errorMessage = L["Error.Lookups.LoadFailed"];
        }
    }

    private void ClearOptions()
    {
        _typeOptions = new();
        _kindOptions = new();
        _statusOptions = new();
        _producerOptions = new();
        _modelOptions = new();
        _userOptions = new();
        _locationOptions = new();
    }

    private static List<string> NormalizeLookupList<T>(IEnumerable<T>? items)
    {
        return (items ?? Enumerable.Empty<T>())
            .Select(ExtractLookupText)
            .Select(x => (x ?? string.Empty).Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string ExtractLookupText<T>(T item)
    {
        if (item == null)
            return string.Empty;

        if (item is string s)
            return s;

        var obj = (object)item;
        var type = obj.GetType();

        var candidates = new[]
        {
            "Name",
            "Text",
            "DisplayName",
            "DisplayText",
            "Value",
            "Label",
            "Title"
        };

        foreach (var propName in candidates)
        {
            var p = type.GetProperty(propName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (p == null)
                continue;

            var v = p.GetValue(obj);
            if (v == null)
                continue;

            var txt = Convert.ToString(v) ?? string.Empty;
            if (!string.IsNullOrWhiteSpace(txt))
                return txt;
        }

        return obj.ToString() ?? string.Empty;
    }

    private async Task LoadAsync()
    {
        _errorMessage = string.Empty;

        try
        {
            if (_isNew)
            {
                _device = new DeviceListRow { Id = 0 };
                _edit = new DeviceUpdateModel { Id = 0 };

                SnapshotOriginal();
                _isEditEnabled = _canCreate;

                if (!_canCreate)
                    _errorMessage = L["Error.NoCreatePermission"];

                return;
            }

            var result = await DevicesService.GetDeviceByIdAsync(Id);
            if (!result.Ok)
            {
                _errorMessage = result.ErrorMessage ?? L["Error.Device.LoadFailed"];
                _device = null;
                SnapshotOriginal();
                _isEditEnabled = false;
                return;
            }

            _device = result.Row;
            if (_device == null)
            {
                _errorMessage = string.Format(CultureInfo.CurrentCulture, L["Error.Device.NotFoundById"], Id);
                SnapshotOriginal();
                _isEditEnabled = false;
                return;
            }

            _edit = MapRowToUpdateModel(_device);
            SnapshotOriginal();

            _isEditEnabled = false;
        }
        catch
        {
            _errorMessage = L["Error.Device.LoadTryLater"];
            _device = null;
            SnapshotOriginal();
            _isEditEnabled = false;
        }
    }

    private void SnapshotOriginal()
    {
        _originalEditJson = SerializeEdit(_edit);
        _isDirty = false;
    }

    private void MarkDirty()
    {
        if (string.IsNullOrWhiteSpace(_originalEditJson))
        {
            _isDirty = true;
            return;
        }

        var current = SerializeEdit(_edit);
        _isDirty = !string.Equals(_originalEditJson, current, StringComparison.Ordinal);
    }

    private static string SerializeEdit(DeviceUpdateModel model)
    {
        var options = new JsonSerializerOptions
        {
            WriteIndented = false,
            PropertyNamingPolicy = null
        };

        return JsonSerializer.Serialize(model ?? new DeviceUpdateModel(), options);
    }

    private void SetEditString(Action<string> setter, string? value)
    {
        var v = value ?? string.Empty;
        setter(v);
        MarkDirty();
    }

    private void SetEditDate(Action<DateTime?> setter, DateTime? value)
    {
        setter(value);
        MarkDirty();
    }

    private void RevertChanges()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_originalEditJson))
                return;

            var restored = JsonSerializer.Deserialize<DeviceUpdateModel>(_originalEditJson);
            if (restored == null)
                return;

            _edit = restored;
            _isDirty = false;
        }
        catch
        {
            Snackbar.Add(L["Snackbar.RevertFailed"], Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        if (!_isEditEnabled || _loading || !_isDirty || !_canSave)
            return;

        _loading = true;
        try
        {
            if (_isNew || _edit.Id <= 0)
            {
                var create = await DevicesService.CreateDeviceAsync(_edit);
                if (!create.Ok)
                {
                    Snackbar.Add(create.ErrorMessage ?? L["Snackbar.SaveFailed"], Severity.Error);
                    return;
                }

                Snackbar.Add(L["Snackbar.Saved"], Severity.Success);
                NavigateBackToList();
                return;
            }

            var save = await DevicesService.UpdateDeviceAsync(_edit);
            if (!save.Ok)
            {
                Snackbar.Add(save.ErrorMessage ?? L["Snackbar.SaveFailed"], Severity.Error);
                return;
            }

            Snackbar.Add(L["Snackbar.Saved"], Severity.Success);
            NavigateBackToList();
        }
        catch
        {
            Snackbar.Add(L["Snackbar.SaveError"], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RequestCancelAsync()
    {
        if (_loading)
            return;

        if (_isEditEnabled && _isDirty)
        {
            var action = await DialogService.ShowMessageBox(
                title: L["Confirm.Unsaved.Title"],
                message: L["Confirm.Unsaved.Message"],
                yesText: L["Confirm.Unsaved.Save"],
                noText: L["Confirm.Unsaved.Discard"],
                cancelText: L["Confirm.Unsaved.Stay"]
            );

            if (action == true)
            {
                await SaveAsync();
                return;
            }

            if (action == false)
            {
                NavigateBackToList();
                return;
            }

            return;
        }

        NavigateBackToList();
    }

    private void NavigateBackToList()
    {
        NavigationManager.NavigateTo("/assets/devices");
    }

    private async Task CopyToClipboardAsync(string? value, string label)
    {
        var v = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(v))
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", v);
            Snackbar.Add(string.Format(CultureInfo.CurrentCulture, L["Snackbar.CopiedFormat"], label), Severity.Success);
        }
        catch
        {
            Snackbar.Add(L["Snackbar.CopyFailed"], Severity.Error);
        }
    }

    private static string FormatDate(DateTime? dt)
        => dt.HasValue ? dt.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) : "-";

    private static string GetSafe(string? value, string fallback = "")
    {
        var v = (value ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(v) ? fallback : v;
    }

    private static DeviceUpdateModel MapRowToUpdateModel(DeviceListRow row)
    {
        return new DeviceUpdateModel
        {
            Id = row.Id,

            Type = row.Type ?? string.Empty,
            Kind = row.Kind ?? string.Empty,
            Status = row.Status ?? string.Empty,
            Producer = row.Producer ?? string.Empty,
            Model = row.Model ?? string.Empty,
            SerialNumber = row.SerialNumber ?? string.Empty,

            User = row.User ?? string.Empty,
            Location = row.Location ?? string.Empty,

            Hostname = row.Hostname ?? string.Empty,
            IpAddress = row.IpAddress ?? string.Empty,
            MacEthernet = row.MacEthernet ?? string.Empty,
            MacWlan = row.MacWlan ?? string.Empty,
            Imei1 = row.Imei1 ?? string.Empty,
            Imei2 = row.Imei2 ?? string.Empty,

            WarrantyStarts = row.WarrantyStarts,
            WarrantyEnds = row.WarrantyEnds,

            InventoryNo = row.InventoryNo ?? string.Empty,
            AssetNo = row.AssetNo ?? string.Empty,

            Note = row.Note ?? string.Empty
        };
    }

    private static Task<IEnumerable<string>> SearchInOptionsAsync(List<string> options, string? search, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();

        var list = options ?? new List<string>();
        var s = (search ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(s))
            return Task.FromResult<IEnumerable<string>>(list);

        var filtered = list
            .Where(x => !string.IsNullOrWhiteSpace(x) && x.Contains(s, StringComparison.OrdinalIgnoreCase))
            .ToList();

        return Task.FromResult<IEnumerable<string>>(filtered);
    }
}
